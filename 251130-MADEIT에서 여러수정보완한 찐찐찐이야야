                        c1_cache[m] = f.result() or []
                    except:
                        c1_cache[m] = []

            found = 0
            for m in shard:
                c1 = c1_cache.get(m, [])
                if not c1: continue

                # === 프로브 2.0 트리거 체크 (옵션) ===
                if PROBE_V2_ENABLED:
                    # 이미 포지션이 있으면 스킵
                    with _POSITION_LOCK:
                        if m in OPEN_POSITIONS:
                            continue

                    # 이미 프로브 2.0 상태가 있으면 스킵
                    with _PROBE_V2_LOCK:
                        if m in PROBE_V2_STATES:
                            continue

                    # 선필터
                    ob_data = obc.get(m)
                    if ob_data and probe_v2_prefilter(c1, ob_data):
                        # 3가지 트리거 중 하나라도 발동
                        trigger_type = None
                        if probe_v2_trigger_breakout(c1):
                            trigger_type = "A_BREAKOUT"
                        elif probe_v2_trigger_momentum(c1):
                            trigger_type = "B_MOMENTUM"
                        elif probe_v2_trigger_trend(c1):
                            trigger_type = "C_TREND"

                        if trigger_type:
                            # ★ 중복 방지: recent_alerts 체크 (기존 로직과 충돌 방지)
                            with _ALERT_LOCK:
                                if m in recent_alerts and time.time() - recent_alerts[m] < ALERT_TTL:
                                    continue
                                recent_alerts[m] = time.time()

                            # 프로브 2.0 상태 추가
                            probe_v2_add_state(m, trigger_type)

                            # 프로브 진입 실행
                            if AUTO_TRADE and m not in OPEN_POSITIONS:
                                # 프로브 크기 계산
                                krw_bal = get_krw_balance()
                                probe_size_krw = int(krw_bal * PROBE_V2_SIZE_PROBE)
                                probe_size_krw = max(min(probe_size_krw, 10000), 5000)  # 5k~10k

                                # pre dict 생성 (open_auto_position 시그니처 맞춤)
                                pre = {
                                    "price": c1[-1]["trade_price"],
                                    "entry_mode": "probe",  # probe_v2가 아닌 probe로 (기존 로직 활용)
                                    "ign_ok": False,
                                    "mega_ok": False,
                                    "early_ok": True,
                                    "ticks": [],
                                    "tape": {"n": 0, "buy_ratio": 0, "krw": 0, "krw_per_sec": 0},
                                    "ob": ob_data if ob_data else {"depth_krw": 0, "spread": 99},
                                }

                                # 동적 손절가 계산
                                dyn_stop, eff_sl = dynamic_stop_loss(pre["price"], c1)

                                # 진입 (override_krw로 안전하게 전달)
                                open_auto_position(m, pre, dyn_stop, eff_sl, override_krw=probe_size_krw)

                                # 알림 (단순화)
                                tg_send(
                                    f"🔬 <b>프로브 2.0 진입</b> {m} <code>#{trigger_type}</code>\n"
                                    f"💰 <b>금액</b> {probe_size_krw:,}원\n"
                                    f"📊 <b>점수</b> 0 (관찰 시작)"
                                )
                                found += 1

                            continue  # 프로브 2.0 진입했으면 기존 로직 스킵

                # === 기존 로직 (프로브 2.0 미사용 또는 미발동 시) ===
                pre = detect_leader_stock(m, obc, c1, tight_mode=tight_mode)
                if not pre: continue

                # detect_leader_stock()가 이미 entry_mode를 결정했으므로 재판단 금지
                # (프로브 postcheck 스킵 등이 무효화되는 치명적 버그 방지)

                payload = final_check_leader(m, pre, tight_mode=tight_mode)
                if not payload: continue

                # === 6초 포스트체크 (컨펌만 적용, 프로브는 패스) ===
                if pre.get("entry_mode") == "probe":
                    ok_post, post_reason = True, "SKIP_FOR_PROBE"
                else:
                    ok_post, post_reason = postcheck_6s(m, pre)
                    if not ok_post:
                        cut("POSTCHECK_DROP", f"{m} postcheck fail: {post_reason}")
                        continue

                # ★ 중복 알림 방지 (락으로 원자적 체크+업데이트)
                with _ALERT_LOCK:
                    if m in recent_alerts and time.time() - recent_alerts[m] < ALERT_TTL:
                        continue
                    # 체크 통과 즉시 마킹 (다른 스레드가 중복 통과 못하게)
                    recent_alerts[m] = time.time()

                reason = "ign" if pre.get("ign_ok") else (
                    "early" if pre.get("early_ok") else
                    ("mega" if pre.get("mega_ok") else "normal"))
                if not cooldown_ok(m, pre['price'], reason=reason):
                    continue

                last_signal_at[m] = time.time()
                last_price_at_alert[m] = pre['price']
                last_reason[m] = reason

                # 동적 손절가
                dyn_stop, eff_sl_pct = dynamic_stop_loss(pre['price'], c1)

                # ★ 추가 체크 정보 계산 (디버깅용)
                try:
                    cur_p = pre['price']
                    ema5_chk = ema_last([c["trade_price"] for c in c1], 5) if len(c1) >= 5 else None
                    ema5_gap_pct = ((cur_p / ema5_chk - 1) * 100) if ema5_chk else 0
                    green_cnt = 0
                    for c in reversed(c1[-7:]):
                        if c["trade_price"] > c["opening_price"]:
                            green_cnt += 1
                        else:
                            break
                    recent_vols = [c["candle_acc_trade_volume"] for c in c1[-5:]]
                    peak_bars_ago = 0
                    if len(recent_vols) >= 2:
                        peak_idx = recent_vols.index(max(recent_vols))
                        peak_bars_ago = len(recent_vols) - 1 - peak_idx
                    chk_info = f"EMA5+{ema5_gap_pct:.1f}% | 양봉{green_cnt}연 | 피크{peak_bars_ago}봉전"
                except Exception:
                    chk_info = ""

                txt = (
                    f"⚡ <b>초입 신호</b> {m} <code>#{reason}</code>\n"
                    f"💵 <b>현재가</b> {fmt_price(pre['price'])}원\n"
                    f"📊 등락 {payload['chg']}% | 거래증가 {payload['volume_surge']}배 | 회전 {payload['turn']}%\n"
                    f"🔸매수 {payload['buy']}% | 틱 {payload['n']} | 스프레드 {payload['spread']}%\n"
                    f"🧯 손절가: {fmt_price(dyn_stop)}원 (동적SL {eff_sl_pct*100:.2f}%)\n"
                    f"🔍 체크: {chk_info}\n"
                    f"🧠 근거: {( '점화/5m돌파' if pre.get('ign_ok') else ('초기누적(TWAP)' if pre.get('botacc_ok') else ('메가브레이크아웃' if pre.get('mega_ok') else ('초기흐름(early)' if pre.get('early_ok') else '패턴종합'))) )}\n"
                    f"{link_for(m)}")

                sent = tg_send(txt, retry=2)

                if sent:
                    found += 1
                    # --- 로그 CSV 기록 (기존 그대로) ---
                    try:
                        c5 = get_minutes_candles(5, m, 2) or []
                        c15 = get_minutes_candles(15, m, 2) or []
                        chg_1m = (c1[-1]["trade_price"] /
                                  max(c1[-2]["trade_price"], 1) -
                                  1) if len(c1) >= 2 else 0.0
                        chg_5m = (c5[-1]["trade_price"] /
                                  max(c5[-2]["trade_price"], 1) -
                                  1) if len(c5) >= 2 else ""
                        chg_15m = (c15[-1]["trade_price"] /
                                   max(c15[-2]["trade_price"], 1) -
                                   1) if len(c15) >= 2 else ""

                        cbtc1 = get_minutes_candles(1, "KRW-BTC", 2) or []
                        btc1m = (cbtc1[-1]["trade_price"] /
                                 max(cbtc1[-2]["trade_price"], 1) -
                                 1) if len(cbtc1) >= 2 else 0.0
                        cbtc5 = get_minutes_candles(5, "KRW-BTC", 2) or []
                        btc5m = (cbtc5[-1]["trade_price"] /
                                 max(cbtc5[-2]["trade_price"], 1) -
                                 1) if len(cbtc5) >= 2 else 0.0

                        t15_now = micro_tape_stats_from_ticks(pre["ticks"], 15)
                        ob = pre["ob"]
                        flags = {
                            "chg_1m":
                            chg_1m,
                            "chg_5m":
                            chg_5m,
                            "chg_15m":
                            chg_15m,
                            "zscore":
                            zscore_krw_1m(c1, 30),
                            "vwap_gap": (c1[-1]["trade_price"] /
                                         max(vwap_from_candles_1m(c1, 20), 1) -
                                         1) if len(c1) >= 1 else 0.0,
                            "turn":
                            round((t15_now["krw"] / max(ob["depth_krw"], 1)) *
                                  100, 2),
                            "two_green_break":
                            pre.get("two_green_break", False),
                            "ignition_ok":
                            pre.get("ign_ok", False),
                            "early_ok":
                            pre.get("early_ok", False),
                            "uptick_ok":
                            True
                        }
                        row = snapshot_row(m, pre["price"], payload, pre, c1,
                                           ob, t15_now, btc1m, btc5m, flags)
                        append_csv(row)
                    except Exception as e:
                        print("[LOG_ERR]", e)

                    # --- 🔥 자동매수 진입 ---
                    try:
                        open_auto_position(m, pre, dyn_stop, eff_sl_pct)
                    except Exception as e:
                        print("[AUTO_OPEN_ERR]", e)

                    # --- 🧵 모니터는 스레드풀에서 비동기로 실행 ---
                    launched = False  # ✅ 기본값으로 초기화
                    try:
                        launched = launch_monitor(m, pre, tight_mode=tight_mode)
                        if not launched:
                            print(f"[MON_SKIP] {m} 모니터 시작 보류/중복")
                    except Exception as e:
                        print("[MON_LAUNCH_ERR]", e)

                    # --- 모니터 비동기 실행 (동시성 제한) ---
                    try:
                        LAST_PRE[m] = pre  # 워치독에서 재기동 시 참조
                        if not launched:
                            print(f"[MONITOR_SKIP] {m} 모니터 시작 보류/중복")
                    except Exception as e:
                        print("[MON_ERR]", e)


            cut_summary()
            if found == 0:
                req_summary()
            # 시간대별 동적 스캔 간격 적용
            aligned_sleep(get_scan_interval())

        except KeyboardInterrupt:
            print("Stopped by user.")
            break
        except Exception as e:
            print("[MAIN_ERR]", e)
            traceback.print_exc()
            print("[MAIN] 5초 후 재시작...")
            time.sleep(5)
            continue  # 💡 다시 루프 시작

if __name__ == "__main__":
    validate_config()
    if AUTO_TRADE:
        if not startup_selfcheck():
            print("⛔ 인증 실패 → AUTO_TRADE 강제 OFF")
            AUTO_TRADE = False
    else:
        print("ℹ️  AUTO_TRADE=0 → Upbit selfcheck 생략")
    bot_start_time = time.time()
    start_health_server()
    start_monitor_watchdog()  # 워치독 시작
    start_probe_v2_monitor()  # 프로브 2.0 모니터링 시작

    try:
        main()
    finally:
        try:
            MONITOR_POOL.shutdown(wait=False, cancel_futures=True)
        except Exception:
            pass
