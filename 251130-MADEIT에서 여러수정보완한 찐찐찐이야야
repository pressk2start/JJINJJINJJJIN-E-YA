# ★ 모니터링 시간 결정 (신규 추가)
# =========================
def decide_monitor_secs(pre: dict, tight_mode: bool = False) -> int:
    """
    포지션 모니터링 총 시간(초)을 상황별로 결정.
    - early_ok: 비교적 짧게 추세 확인
    - ignition_ok / mega_ok: 상대적으로 길게 (추세 이어질 가능성)
    - 시장 모드(TIGHT), 야간, BTC 모멘텀, 오더북 깊이 등에 따라 가/감
    """
    try:
        r = relax_knob()  # 0.0 ~ 1.5
    except Exception:
        r = 0.0

    base = 150  # 기본값

    # 신호 유형 가중
    if pre.get("mega_ok"):
        base = 300
    elif pre.get("ign_ok"):
        base = 240
    elif pre.get("botacc_ok"):
        base = 210
    elif pre.get("early_ok"):
        base = 180
    elif pre.get("two_green_break"):
        base = 210

    # 오더북 깊이 기반 (깊으면 여유 있게)
    ob_depth = 0
    try:
        ob_depth = pre.get("ob", {}).get("depth_krw", 0) or 0
    except Exception:
        pass
    if ob_depth >= 30_000_000:
        base += 30
    elif ob_depth <= 6_000_000:
        base -= 30

    # BTC 5분 모멘텀
    try:
        b5 = btc_5m_change()
    except Exception:
        b5 = 0.0
    if b5 >= 0.006:
        base += 30
    elif b5 <= -0.008:
        base -= 30

    # 야간(00~06 KST)엔 흔들림 대비 약간 단축
    h = now_kst().hour
    if 0 <= h < 6:
        base -= 15

    # 장세 완화 노브 반영
    base += int(10 * r)

    # 타이트 모드(급락 방어)면 단축
    if tight_mode:
        base -= 30

    # 하한/상한 클램프
    base = max(90, min(base, 360))
    return int(base)


# =========================
# 끝알람 권고 생성 (END RECO)
# =========================
def _end_reco(m, entry_price, last_price, ret_pct, c1, ticks, ob_depth_krw, ctx_thr=3):

    try:
        ctx_score, ctx_reasons = context_exit_score(
            m,
            ticks or [],
            ob_depth_krw or 10_000_000,
            entry_price,
            last_price,
            c1 or [],
        )
    except Exception:
        ctx_score, ctx_reasons = (0, [])

    # 테이프(최근 15s)
    t15 = micro_tape_stats_from_ticks(ticks or [], 15)
    buy = t15.get("buy_ratio", 0.0)
    n = t15.get("n", 0)

    # 컨텍스트(EMA5 / VWAP)
    vwap = vwap_from_candles_1m(c1 or [], 20) if c1 else 0
    ema5 = ema_last([x["trade_price"] for x in (c1 or [])], 5) if c1 else 0
    vwap_ok = bool(vwap and last_price >= vwap)
    ema_ok = bool(ema5 and last_price >= ema5)

    # 💎 거래 둔화 + 약상승 → 본절 익절 유도
    if -0.2 <= ret_pct <= 0.4 and t15.get("krw_per_sec", 0) < 12000 and ctx_score <= ctx_thr:

        action = "부분 청산(본절)"
        rationale = f"거래둔화 구간 본절 익절 ({ret_pct:+.2f}%)"
        return action, rationale

    # -----------------------------
    # 1) 전량 청산 권고 조건 (강한 청산)
    # -----------------------------
    full_exit = False
    why_full = []

    # (1) 손실이 많이 커졌을 때
    if ret_pct <= -2.0:
        full_exit = True
        why_full.append(f"손실 {ret_pct:+.2f}%")

    # (2) 컨텍스트 스코어가 임계치보다 많이 높고, VWAP/EMA도 깨져 있을 때
    if ctx_score >= (ctx_thr + 1) and not vwap_ok and not ema_ok:
        full_exit = True
        why_full.append(f"컨텍스트 {ctx_score}/{ctx_thr}")

    # (3) 약손실 상태에서 매수세·테이프가 많이 죽은 경우
    if ret_pct < -0.8 and buy < 0.50 and n >= 4:
        full_exit = True
        why_full.append(f"매수비 {buy*100:.1f}% / 틱 {n}")

    if full_exit:
        action = "전량 청산 권고"
        rationale = " · ".join(why_full) if why_full else "리스크 우위"
        return action, rationale

    # -----------------------------
    # 2) 부분 청산 권고 (애매/경고 구간)
    # -----------------------------
    partial_exit = False
    why_partial = []

    # 수익이 크지 않은 구간
    if -0.8 < ret_pct < 0.8:
        partial_exit = True
        why_partial.append(f"수익 {ret_pct:+.2f}%")

    # 컨텍스트 경고 레벨
    if ctx_score == ctx_thr:
        partial_exit = True
        why_partial.append(f"컨텍스트 경고 {ctx_score}/{ctx_thr}")

    # 매수비 약하고 틱은 많은 경우
    if buy < 0.55 and n >= 6:
        partial_exit = True
        why_partial.append(f"매수비 {buy*100:.1f}% / 틱 {n}")

    # 🚀 거래둔화 시 자동 부분익절 권고
    if ret_pct >= 1.5 and t15["krw_per_sec"] < 15000:
        partial_exit = True
        why_partial.append(f"거래속도 둔화 {t15['krw_per_sec']:.0f} KRW/s")

    # VWAP/EMA 둘 다 하방일 때
    if not vwap_ok and not ema_ok:
        partial_exit = True
        why_partial.append("VWAP·EMA5 하방")

    if partial_exit:
        action = "부분 청산(50%) 권고"
        rationale = " · ".join(why_partial) if why_partial else "불확실 구간"
        return action, rationale

    # -----------------------------
    # 3) 유지 권고 (추세 유지)
    # -----------------------------
    why_keep = [f"수익 {ret_pct:+.2f}%"]
    if vwap_ok:
        why_keep.append("VWAP 상방")
    if ema_ok:
        why_keep.append("EMA5 상방")
    if buy >= 0.60 and n >= 4:
        why_keep.append(f"매수비 {buy*100:.1f}% / 틱 {n}")

    rationale = " · ".join(why_keep)
    return "유지 권고", rationale


# =========================
# 모니터링(최종형)
# =========================
def monitor_position(m,
                     entry_price,
                     pre,
                     tight_mode=False,
                     horizon=None,
                     reentry=False):
    c1 = get_minutes_candles(1, m, 20)
    base_stop, eff_sl_pct = dynamic_stop_loss(entry_price, c1)

    # horizon이 안 들어오면 자동 결정, 들어오면 그 값 사용
    if horizon is None:
        horizon = decide_monitor_secs(pre, tight_mode=tight_mode)
    start_ts = time.time()
    MAX_RUNTIME = horizon * 1.5  # 최대 허용 실행시간 (정상시간의 1.5배)


    # 디바운스/트레일 상태
    # 손절 디바운스용
    stop_first_seen_ts = 0.0
    stop_hits = 0
    # 컨텍스트 청산 디바운스용
    ctx_first_seen_ts = 0.0
    ctx_hits = 0

    trail_armed = False
    trail_stop = 0.0

    # 스캘프 미세익절 제어 (순이익 보장)
    micro_arm = False
    micro_floor = 0.0

    # VWAP 과열→복귀 감지용
    peak_vwap_gap = 0.0

    # 이익락 제어 (고정 가격, 상향만 가능)
    profit_lock_active = False
    profit_lock_price = 0.0

    # 스파이크/그레이스 기존 로직 재활용
    consecutive_failures = 0
    MAX_CONSECUTIVE_FAILURES = 10
    grace_used = False
    spike_recovery_used = False

    ob = pre.get("ob")
    ob_depth_default = ob.get("depth_krw", 10_000_000) if ob else 10_000_000

    last_price = entry_price
    best = entry_price
    worst = entry_price

    # 📊 MFE/MAE 트래킹 (Maximum Favorable/Adverse Excursion)
    mfe_pct = 0.0  # 진입 후 최대 수익률
    mae_pct = 0.0  # 진입 후 최대 손실률

    # 🛡️ 동적 수익 보호 (Break-even Floor)
    # 트레일링과 별개로 최소 수익 하한선 보장 (절대 하향 금지)
    breakeven_floor = None  # None이면 미활성, 설정되면 entry_price 대비 %

    # 🚨 절대 손실 하드 캡 2단계 (최종 안전망)
    hard_cap_warning_sent = False  # -2.0% 경고 발송 여부

    # ★ 정체 감지용 상태 변수
    best_ts = time.time()        # 마지막 신고점 찍은 시각
    stall_arm_ts = None          # 정체 시작 후보 시각(디바운싱용)

    # 실제 보유 수량 확보 (익절 시 매도용)
    with _POSITION_LOCK:
        entry_volume = OPEN_POSITIONS.get(m, {}).get("volume", 0.0)

    verdict = None
    outcome_extra = ""

    # === 포지션 모드 (probe / confirm) ===
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m, {})
    entry_mode = pos.get("entry_mode", "confirm")

    try:
        exit_reason = None  # ✅ 루프 내에서는 사유만 기록
        while time.time() - start_ts <= horizon:
            time.sleep(RECHECK_SEC)

            ticks = get_recent_ticks(m, 100)
            if not ticks or len(ticks) < 3:
                consecutive_failures += 1
                if consecutive_failures >= MAX_CONSECUTIVE_FAILURES:
                    time.sleep(3)
                    ticks = get_recent_ticks(m, 100)
                    if not ticks:
                        verdict = "데이터 수신 실패"
                        break
                    consecutive_failures = 0
                continue
            consecutive_failures = 0

            # 현재가
            cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
            if not cur_js or len(cur_js) == 0:
                continue
            curp = cur_js[0].get("trade_price", last_price)

            # 🔧 신고점/신저점 '갱신' 감지를 위해 이전값 저장
            prev_best = best
            prev_worst = worst

            last_price = curp
            best = max(best, curp)
            worst = min(worst, curp)

            # 📊 MFE/MAE 실시간 갱신
            current_gain = (curp / entry_price - 1.0) * 100.0  # %
            mfe_pct = max(mfe_pct, current_gain)  # 최대 수익률
            mae_pct = min(mae_pct, current_gain)  # 최대 손실률 (음수)

            # OPEN_POSITIONS에 실시간 저장 (완전 종료 시 record_trade에 전달용)
            with _POSITION_LOCK:
                pos_update = OPEN_POSITIONS.get(m)
                if pos_update:
                    pos_update["mfe_pct"] = mfe_pct
                    pos_update["mae_pct"] = mae_pct
                    OPEN_POSITIONS[m] = pos_update

            # 수익률 계산 (여러 블록에서 사용)
            gain_from_entry = (curp / entry_price - 1.0)

            # 🛡️ 동적 수익 보호: 계단식 하한선 상향 (절대 하향 금지)
            if gain_from_entry >= 0.020:  # +2.0% 도달
                breakeven_floor = max(breakeven_floor or 0.0, 0.010)  # 최소 +1.0% 보장
            elif gain_from_entry >= 0.015:  # +1.5% 도달
                breakeven_floor = max(breakeven_floor or 0.0, 0.005)  # 최소 +0.5% 보장
            elif gain_from_entry >= 0.010:  # +1.0% 도달
                breakeven_floor = max(breakeven_floor or 0.0, 0.000)  # 본절 보장

            # 🛡️ Break-even Floor 위반 체크 (소익/본절 보호)
            if breakeven_floor is not None:
                floor_price = entry_price * (1.0 + breakeven_floor)
                if curp < floor_price:
                    exit_reason = "BREAKEVEN_FLOOR"
                    verdict = f"수익 보호 하한선 위반 (최소 {breakeven_floor*100:+.1f}% 보장)"
                    break

            # ★ 신고점 갱신 시 정체 타이머 리셋
            if best > prev_best:
                best_ts = time.time()
                stall_arm_ts = None

            # === 1) 웜업 구간: 소폭 되돌림 무시 (단, 급락은 즉시 컷)
            alive_sec = time.time() - start_ts
            dd_now = (curp / best - 1.0)
            if alive_sec < WARMUP_SEC:
                if (curp / entry_price - 1.0) <= -HARD_STOP_DD:
                    exit_reason = "HARD_STOP"  # ← finally에서 실청산되도록 추가
                    verdict = "급락 즉시 손절"
                    outcome_extra = f"(DD {dd_now*100:.2f}%)"
                    break  # 청산은 finally에서 한 번만
                # 웜업 중엔 소프트 스탑 미적용
                continue

            # 🚨 절대 손실 하드 캡 2단계 (최종 안전망)
            # ✅ 개선: -2.5%→-1.5% 강화 (대손 방지)
            loss_from_entry = (curp / entry_price - 1.0)
            if loss_from_entry <= -0.015:  # -1.5% 도달 → 즉시 청산 (디바운스 없음)
                exit_reason = "ABSOLUTE_HARD_CAP_1_5"
                verdict = "절대 손실 -1.5% 하드 캡 (즉시 청산)"
                tg_send_mid(f"🚨 {m} 절대 손실 -1.5% 하드 캡 도달 → 즉시 청산")
                break
            elif loss_from_entry <= -0.012 and not hard_cap_warning_sent:  # -1.2% 도달 → 경고
                hard_cap_warning_sent = True
                tg_send_mid(f"⚠️ {m} 절대 손실 -1.2% 경고 (하드 캡 근접)")

            # ⏰ 시간 기반 손절 (Time Stop Loss)
            if alive_sec >= 300:  # 5분 경과
                if loss_from_entry <= -0.005:  # -0.5% 이상 손실
                    exit_reason = "TIME_STOP_5MIN"
                    verdict = f"시간 기반 손절 (5분 경과, {loss_from_entry*100:.2f}%)"
                    break
            elif alive_sec >= 180:  # 3분 경과
                if loss_from_entry < 0:  # 손실 상태
                    exit_reason = "TIME_STOP_3MIN"
                    verdict = f"시간 기반 손절 (3분 경과, 손실 {loss_from_entry*100:.2f}%)"
                    break

            # === 2) 트레일링 손절: 이익이 나야만 무장

            # === 📊 스캘프 vs 추세 분기: run_from_entry 기준 ===
            run_from_entry = (best / entry_price - 1.0)

            # === PROBE → CONFIRM 전환 로직 (1차 추매: 가장 엄격한 허들) ===
            with _POSITION_LOCK:
                pos = (OPEN_POSITIONS.get(m) or {}).copy()  # ✅ 안전 읽기

            if pos.get("entry_mode") == "probe":
                # ★ v2: 현재시각 기준 + 금액가중 buy ratio (밤사이 손실 방지)
                t15_now = micro_tape_stats_from_ticks_v2(ticks, 15, use_now_anchor=True, winsor_p=0.95)
                t30_now = micro_tape_stats_from_ticks_v2(ticks, 30, use_now_anchor=True, winsor_p=0.95)

                gain_now = (float(curp) / float(entry_price) - 1.0)  # float 통일

                c1m_ema = get_minutes_candles(1, m, 20)
                ema3_cross = ema_last([c["trade_price"] for c in c1m_ema], 3)
                ema8_cross = ema_last([c["trade_price"] for c in c1m_ema], 8)
                ema_crossover = (ema3_cross and ema8_cross) and (ema3_cross > ema8_cross)

                # ★ 1차 추매 엄격 조건 (손절 방지)
                # 1) 가격 상승 체크: +0.4% 이상 (0.3→0.4 강화)
                gain_ok = (gain_now >= ADD1_MIN_GAIN)

                # 2) 전고 돌파 체크 (최근 6개 봉)
                break_ok = False
                if c1m_ema and len(c1m_ema) >= 6:
                    recent_high = max(c["high_price"] for c in c1m_ema[-6:])
                    break_ok = (curp > recent_high)

                # 3) 상대 가속 체크: t15 ≥ 1.25×t30 (신규 추가)
                accel_ok = (t15_now["krw_per_sec"] >= ADD1_MIN_ACCEL * max(t30_now["krw_per_sec"], 1)) and \
                           (t15_now["krw_per_sec"] >= ADD1_MIN_KRWPSEC)

                # 4) 매수비 체크: 금액가중(value-weighted) + 하이브리드 임계값 (밤사이 손실 방지)
                #    - 기본: buy_value_ratio >= 0.58 AND buy_count_ratio >= 0.56
                #    - 강유입: buy_value_ratio >= 0.64면 buy_count_ratio >= 0.53 허용
                #    - 큰손매수: big_buy_detected면 buy_value_ratio >= 0.54 허용 (신규)
                #    - 총거래대금: >= 1.5M KRW (저유동성 회피)
                buy_val_ratio = t15_now.get("buy_value_ratio", 0.0)
                buy_cnt_ratio = t15_now.get("buy_count_ratio", 0.0)
                total_val = t15_now.get("total_val", 0.0)
                big_buy = t15_now.get("big_buy_detected", False)  # ★ 큰손 매수 감지

                buy_ok = (total_val >= 1_500_000) and (
                    (buy_val_ratio >= 0.58 and buy_cnt_ratio >= 0.56) or
                    (buy_val_ratio >= 0.64 and buy_cnt_ratio >= 0.53) or
                    (big_buy and buy_val_ratio >= 0.54 and buy_cnt_ratio >= 0.52)  # ★ 큰손 매수 시 완화
                )

                # 5) VWAP 과열 방지 (기존 가드 유지)
                vgap_ok = True
                try:
                    vwap20 = vwap_from_candles_1m(c1m_ema, 20)
                    if vwap20 and vwap20 > 0:
                        vgap_ok = (curp / vwap20 - 1.0) <= 0.015  # 1.5% 이내
                except Exception:
                    pass

                # 6) EMA 골든크로스 체크
                ema_ok = bool(ema_crossover)

                # ★★ 1차 추매 최종 조건 (가장 높은 허들):
                # (가격상승 + 전고돌파) 또는 (EMA골든크로스 + 가격상승)
                # + 상대가속 + 매수비 + VWAP안전
                first_add_ok = (
                    ((gain_ok and break_ok) or (ema_ok and gain_ok)) and
                    accel_ok and buy_ok and vgap_ok
                )

                if first_add_ok:
                    ok_add, new_entry = add_auto_position(m, curp)
                    if ok_add and new_entry:
                        with _POSITION_LOCK:
                            if m in OPEN_POSITIONS:
                                OPEN_POSITIONS[m].update({
                                    "entry_mode": "confirm",
                                    "entry_price": float(new_entry),
                                    "last_add_ts": time.time(),
                                })

                        big_buy_msg = "🐋 큰손매수!" if big_buy else ""
                        tg_send_mid(
                            f"🔥 {m} 상승 확정 → probe ➜ confirm 전환 {big_buy_msg}\n"
                            f"추매 후 평단: {fmt_price(new_entry)}원\n"
                            f"(gain≥{ADD1_MIN_GAIN*100:.1f}%, "
                            f"buy_val={buy_val_ratio*100:.0f}%/cnt={buy_cnt_ratio*100:.0f}%, "
                            f"t15≥{ADD1_MIN_ACCEL:.2f}×t30 & ≥{ADD1_MIN_KRWPSEC:,}/s)"
                        )

                        # ★ 추매 후 스탑은 절대 위로 당기지 않음 (정상 눌림 보호)
                        c1_for_sl = get_minutes_candles(1, m, 20)
                        old_stop = base_stop
                        new_stop, new_sl_pct = dynamic_stop_loss(new_entry, c1_for_sl)
                        base_stop = min(old_stop, new_stop)  # 스탑은 절대 상향 안됨
                        eff_sl_pct = min(eff_sl_pct, new_sl_pct)
                        trail_armed = False

            if (not trail_armed) and gain_from_entry >= TRAIL_ARM_GAIN:
                trail_armed = True
                # 초기 트레일: ATR 기준 혹은 최소거리
                atr = atr14_from_candles(get_minutes_candles(1, m, 20), 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = curp * (1.0 - trail_dist)

            # === PROBE 미세익절: +0.25% 찍고 밀리면 즉시 본절-소익 확정 (강화) ===
            with _POSITION_LOCK:
                pos_probe = (OPEN_POSITIONS.get(m) or {})
            if pos_probe.get("entry_mode") == "probe":
                run_from_entry_probe = (best / entry_price - 1.0)
                drop_from_best = (curp / best - 1.0)
                # 프로브가 +0.25% 이상 찍고 -0.10% 되밀리면 즉시 청산 (0.15→0.10 강화)
                if run_from_entry_probe >= 0.0025 and drop_from_best <= -0.0010:
                    exit_reason = "PROBE_MICRO_PROFIT"
                    verdict = f"probe 미세익절 (고점 {run_from_entry_probe*100:.2f}%, 현재 {gain_from_entry*100:.2f}%)"
                    break

            # === ★ 추매 직후 45초 검증 (실패하면 추가분만 롤백) ===
            with _POSITION_LOCK:
                p_check = OPEN_POSITIONS.get(m) or {}
            last_add_ts = p_check.get("last_add_ts", 0.0)
            last_add_vol = p_check.get("last_add_volume", 0.0)
            last_add_px = p_check.get("last_add_price", 0.0)

            if last_add_vol > 0 and (time.time() - last_add_ts) <= 45:
                # ★ v2: 추매 검증도 금액가중 ratio 사용
                t15_now = micro_tape_stats_from_ticks_v2(ticks, 15, use_now_anchor=True, winsor_p=0.95)
                t30_now = micro_tape_stats_from_ticks_v2(ticks, 30, use_now_anchor=True, winsor_p=0.95)
                made_new_high = curp >= best * 0.999  # 신고점 재도전
                reaccel = (t15_now["krw_per_sec"] >= 1.15 * max(t30_now["krw_per_sec"], 1)
                          and t15_now.get("buy_value_ratio", 0) >= 0.58)

                # 실패 조건: 신고점 미갱신 + 재가속 실패 or 가격 이탈
                fail_add = (not made_new_high and not reaccel) or (curp <= last_add_px * 0.997)

                if fail_add:
                    # 추가분만 롤백 (부분 매도)
                    current_vol = p_check.get("volume", 1e-12)
                    current_entry = p_check.get("entry_price", 1.0)
                    current_adds = p_check.get("adds", 0)

                    rollback_ratio = min(1.0, last_add_vol / max(current_vol, 1e-12))
                    ok_rb, _, exec_rb = safe_partial_sell(m, sell_ratio=rollback_ratio, reason="추매 실패 롤백")

                    if ok_rb and exec_rb > 0:
                        print(f"[ADD_ROLLBACK] {m} 추매 검증 실패 → {exec_rb:.6f} 롤백")

                        # ★ 전량 롤백 (100%)이면 포지션 완전 종료
                        if rollback_ratio >= 0.99:
                            with _POSITION_LOCK:
                                OPEN_POSITIONS.pop(m, None)
                                LAST_EXIT_AT[m] = time.time()
                            print(f"[ADD_ROLLBACK] {m} 전량 롤백 → 포지션 종료")
                            break  # 모니터링 루프 탈출

                        # 🔁 부분 롤백일 때만 원복 (adds/entry_price/last_add 전부 복구)
                        with _POSITION_LOCK:
                            q = OPEN_POSITIONS.get(m)
                            if q:
                                # 추매 카운트 원복
                                q["adds"] = max(0, current_adds - 1)

                                # 평단 원복 (역가중평균 계산)
                                vol_before_add = current_vol - last_add_vol
                                if vol_before_add > 1e-8:
                                    restored_entry = (current_entry * current_vol - last_add_px * last_add_vol) / vol_before_add
                                    q["entry_price"] = max(1.0, restored_entry)

                                # 추매 메타 초기화 (재검증 방지)
                                q["last_add_volume"] = 0.0
                                q["last_add_price"] = 0.0
                                q["last_add_ts"] = 0.0

                                OPEN_POSITIONS[m] = q
                                print(f"[ADD_ROLLBACK] {m} 상태 완전 원복: adds={q['adds']}, entry={q['entry_price']:.1f}")

            # === ★ 공통 STALL(정체) 감지 ===
            # 최근 0~5초 vs 5~20초 비교 + 신고점 정지 시간
            w_now = _win_stats(ticks, 0, 5)      # 최근
            w_early = _win_stats(ticks, 5, 20)   # 직전
            stall_age = time.time() - best_ts

            # 거래속도/매수비가 직전 대비 명확히 둔화 & 신고점 갱신 정지
            flow_decel = (w_now["krw_per_sec"] <= w_early["krw_per_sec"] * 0.6)
            buy_drop   = (w_now["buy_ratio"]   <= w_early["buy_ratio"]   - 0.10)
            tick_slow  = (w_now["rate"]        <= max(0.25, w_early["rate"] * 0.6))

            is_stall_candidate = (stall_age >= 5.0) and (flow_decel or buy_drop or tick_slow)

            # 1초 디바운싱(연속 확인)
            if is_stall_candidate and stall_arm_ts is None:
                stall_arm_ts = time.time()
            elif not is_stall_candidate:
                stall_arm_ts = None
            is_stall = bool(stall_arm_ts and (time.time() - stall_arm_ts >= 1.0))

            # === PROBE 타임아웃 + 정체 청산: 충분히 관찰 후 판단 ===
            if pos_probe.get("entry_mode") == "probe":
                if alive_sec >= PROBE_TIMEOUT_SEC:
                    gain_now = (curp / entry_price - 1.0)
                    # 본절 근처 또는 손실이면 정리
                    if gain_now <= PROBE_BREAKEVEN_EXIT:  # -0.3% 이하면 청산
                        exit_reason = "PROBE_TIMEOUT_CUT"
                        verdict = "probe 타임아웃 손절"
                        break

                # ★ 정체 청산: 구조까지 무너졌을 때만 (VWAP/EMA/매수세 동시 확인)
                if is_stall and alive_sec >= 30:  # 최소 30초 경과 후에만 정체 판단
                    gain_now = (curp / entry_price - 1.0)

                    if gain_now < -0.003:  # -0.3% 이하 손실
                        # ★ 구조 체크: VWAP/EMA5 이탈 + 매수세 약화 확인
                        c1m_stall = get_minutes_candles(1, m, 20)
                        vwap20_stall = vwap_from_candles_1m(c1m_stall, 20)
                        ema5_stall = ema_last([c["trade_price"] for c in c1m_stall], 5)

                        # 구조 이탈: VWAP 아래 AND EMA5 아래
                        under_structure = (
                            (vwap20_stall and curp < vwap20_stall) and
                            (ema5_stall and curp < ema5_stall)
                        )

                        # 매수세 약화: 금액가중 매수비 < 53% OR 거래속도 < 9k/s
                        t15_stall = micro_tape_stats_from_ticks_v2(ticks, 15, use_now_anchor=True, winsor_p=0.95)
                        buyer_weak = (
                            t15_stall.get("buy_value_ratio", 0) < 0.53 or
                            t15_stall.get("krw_per_sec", 0) < 9000
                        )

                        # ★★★ 추세 지속 예외 (continuation hold) ★★★
                        # 1) ADX/DI 추세 필터: ADX > 20 & +DI 우위 >= 5 → 강한 추세 중
                        adx_data = adx_di(c1m_stall, period=14)
                        adx_trend_hold = False
                        if adx_data:
                            adx_val = adx_data.get("adx", 0)
                            plus_di = adx_data.get("plus_di", 0)
                            minus_di = adx_data.get("minus_di", 0)
                            adx_trend_hold = (adx_val > 20 and (plus_di - minus_di) >= 5)

                        # 2) 상단밴드 워크 예외: 가격이 Upper~5MA 사이 + 밴드폭 확장 중
                        bb_stall = bollinger_bands(c1m_stall, period=20, std_mult=2.0)
                        bb_prev = bollinger_bands(c1m_stall[:-3], period=20, std_mult=2.0) if len(c1m_stall) > 23 else None
                        band_walk_hold = False
                        if bb_stall and ema5_stall:
                            in_upper_zone = (ema5_stall <= curp <= bb_stall["upper"] * 1.005)  # 5MA~Upper 사이
                            bw_expanding = (bb_prev and bb_stall["bandwidth"] > bb_prev["bandwidth"])  # 밴드 확장 중
                            band_walk_hold = (in_upper_zone and bw_expanding)

                        # 3) 임펄스 타임락: 가변 대기시간 (기본 180초, 강추세 300초)
                        # ADX > 25 & +DI 우위면 5분까지 연장 (강추세에서 더 오래 기다림)
                        if adx_data and adx_data.get("adx", 0) > 25 and adx_data.get("plus_di", 0) > adx_data.get("minus_di", 0):
                            patience_sec = 300  # 강추세: 5분
                        else:
                            patience_sec = 180  # 기본: 3분
                        impulse_hold = (alive_sec < patience_sec)

                        # 4) EMA20 기울기 체크: 기울기 > 0 이면 아직 상승추세
                        ema20_stall = ema_last([c["trade_price"] for c in c1m_stall], 20)
                        ema20_prev = ema_last([c["trade_price"] for c in c1m_stall[:-3]], 20) if len(c1m_stall) > 23 else None
                        ema20_slope_hold = False
                        if ema20_stall and ema20_prev:
                            ema20_slope = (ema20_stall - ema20_prev) / max(ema20_prev, 1)
                            ema20_slope_hold = (ema20_slope > 0 and curp > ema20_stall)  # 기울기+ & 가격>EMA20

                        # 5) BB 수축 감지 (깃발/수렴 패턴): 밴드폭이 줄어드는 중 → 터지기 전 숨고르기
                        bb_contraction_hold = False
                        if bb_stall and bb_prev:
                            bw_contracting = (bb_stall["bandwidth"] < bb_prev["bandwidth"] * 0.95)  # 5% 이상 수축
                            bb_contraction_hold = bw_contracting

                        # 6) 거래량 수축 감지: 저거래량 = 숨고르기 (매도 압력 아님)
                        vol_contraction_hold = False
                        if len(c1m_stall) >= 20:
                            vol_list = [c["candle_acc_trade_volume"] for c in c1m_stall]
                            vol_sma5 = sum(vol_list[-5:]) / 5
                            vol_sma20 = sum(vol_list[-20:]) / 20
                            vol_contraction_hold = (vol_sma5 <= vol_sma20)  # 최근 거래량 감소 = 숨고르기

                        # ★ 추세 지속 신호 1개 이상이면 stall cut 보류
                        trend_signals = [adx_trend_hold, band_walk_hold, impulse_hold,
                                        ema20_slope_hold, bb_contraction_hold, vol_contraction_hold]
                        trend_hold_cnt = sum(trend_signals)
                        trend_hold = (trend_hold_cnt >= 1)  # 1개만 있어도 보류 (보수적)

                        if trend_hold and not (under_structure and buyer_weak):
                            # 추세 신호 있고 구조 완전 붕괴 아님 → 컷 보류, 계속 관찰
                            hold_reasons = []
                            if adx_trend_hold:
                                hold_reasons.append("ADX추세")
                            if band_walk_hold:
                                hold_reasons.append("밴드워크")
                            if impulse_hold:
                                hold_reasons.append(f"초동보호({int(alive_sec)}/{patience_sec}s)")
                            if ema20_slope_hold:
                                hold_reasons.append("EMA20↑")
                            if bb_contraction_hold:
                                hold_reasons.append("BB수축")
                            if vol_contraction_hold:
                                hold_reasons.append("거래량↓")
                            print(f"[TREND_HOLD] {m} 정체지만 추세 유지 신호: {', '.join(hold_reasons)} → 컷 보류")
                            # 컷 안하고 continue
                        else:
                            # ★ 부분청산 횟수 체크 (계속 횡보 대응)
                            with _POSITION_LOCK:
                                stall_partial_cnt = (OPEN_POSITIONS.get(m) or {}).get("stall_partial_cnt", 0)

                            if under_structure and buyer_weak:
                                # ★ 구조 + 매수세 둘 다 무너짐 → 전량 청산
                                exit_reason = "PROBE_STALL_CUT"
                                verdict = f"probe 정체 손절 ({gain_now*100:+.2f}%, 구조이탈)"
                                break
                            elif stall_partial_cnt >= 2:
                                # ★ 2회 부분청산 후에도 계속 정체 → 포기하고 전량 청산
                                exit_reason = "PROBE_STALL_CUT"
                                verdict = f"probe 정체 손절 ({gain_now*100:+.2f}%, 2회 축소 후 지속)"
                                break
                            else:
                                # ★ 구조 살아있음 → 30% 부분청산만 (재상승 기회 보존)
                                ok, _, ex = safe_partial_sell(m, sell_ratio=0.3, reason=f"probe 정체 30% 축소 ({gain_now*100:+.2f}%)")
                                if ok and ex > 0:
                                    stall_arm_ts = None  # 디바운스 리셋
                                    with _POSITION_LOCK:
                                        p = OPEN_POSITIONS.get(m)
                                        if p:
                                            p["stall_partial_cnt"] = stall_partial_cnt + 1
                                    tg_send_mid(f"⚡ {m} 정체 중 구조 유지 → 30% 축소 ({stall_partial_cnt+1}/2)")
                                # 전량 청산 안 함 → continue
                    # 수익 중이면 정체여도 유지 (추세 기다림)

            # === ★ 상승세 판정 (추매용) ===
            strong_up = (
                uptick_streak_from_ticks(ticks, need=2)
                and w_now["buy_ratio"] >= 0.58
                and w_now["krw_per_sec"] >= max(14000, 0.7 * w_early["krw_per_sec"])
            )

            # === 2-1) 피라미딩(추매): 상승세면 추매 / 정체면 부분청산 ===
            if pos_probe.get("entry_mode") != "probe":  # ✅ current_mode → pos_probe.get() 사용
                if strong_up and USE_PYRAMIDING and AUTO_TRADE:
                    # ★ v2: 피라미딩도 금액가중 ratio 사용
                    t15_now = micro_tape_stats_from_ticks_v2(ticks, 15, use_now_anchor=True, winsor_p=0.95)
                    t30_now = micro_tape_stats_from_ticks_v2(ticks, 30, use_now_anchor=True, winsor_p=0.95)

                    # 단기 EMA 상승 전환
                    c1m = get_minutes_candles(1, m, 20)
                    ema3 = ema_last([c["trade_price"] for c in c1m], 3)
                    ema8 = ema_last([c["trade_price"] for c in c1m], 8)
                    short_term_up = (ema3 is not None and ema8 is not None and ema3 > ema8)

                    with _POSITION_LOCK:
                        pos = OPEN_POSITIONS.get(m)
                        adds_used = pos.get("adds", 0) if pos else MAX_ADDS
                        last_add_ts = pos.get("last_add_ts", 0.0) if pos else 0.0

                    # ★ VWAP 과열 방지 (추매만 더 보수적)
                    vwap20 = vwap_from_candles_1m(c1m, 20)
                    vgap = (curp / max(vwap20, 1) - 1.0) if vwap20 else 0.0
                    vgap_ok = (vgap <= 0.015)  # VWAP 대비 1.5% 이내만 추매 허용 (1.8→1.5 강화)

                    # ★ 버스트 소진 가드 (속도 저하 시 추매 금지)
                    t5_now = micro_tape_stats_from_ticks_v2(ticks, 5, use_now_anchor=True, winsor_p=0.95)
                    burst_exhausted = (t5_now["krw_per_sec"] < t30_now["krw_per_sec"] * 0.85)  # 15% 이상 둔화

                    # ★★★ 1차 추매 (probe→confirm): 조건 완화 (추매 실패 감소)
                    if adds_used == 0:
                        first_add_ok = (
                            alive_sec >= 15 and  # 최소 15초 관찰
                            curp > entry_price * 1.003 and  # 실제 +0.3% 이상 상승 (0.5→0.3 완화)
                            t15_now["krw_per_sec"] >= t30_now["krw_per_sec"] * 1.15 and  # 거래량 15% 가속 (30→15 완화)
                            t15_now.get("buy_value_ratio", 0) >= 0.54 and  # 매수비 54% 이상 (금액가중, 60→54 완화)
                            short_term_up and
                            vgap_ok and  # ★ VWAP 과열 방지
                            not burst_exhausted and  # ★ 버스트 소진 체크
                            last_two_ticks_fresh(ticks)
                        )
                        flow_ok = first_add_ok
                    # ★★★ 2차+ 추매: 상승세 계속되면 빠르게 (완화)
                    else:
                        flow_ok = (
                            t15_now["krw_per_sec"] >= t30_now["krw_per_sec"] * 1.15 and  # 가속도 15%+
                            t15_now.get("buy_value_ratio", 0) >= 0.58 and                # 매수비 58%+ (금액가중)
                            last_two_ticks_fresh(ticks) and
                            short_term_up and
                            vgap_ok and  # ★ VWAP 과열 방지
                            strong_up  # 위에서 계산된 단기 강세 플래그
                        )

                    if flow_ok:
                        # 쿨다운: 1차는 없음, 2차+는 60% 단축 (6초)
                        if adds_used == 0:
                            cooldown_ok = True  # 1차 추매는 쿨다운 없음
                        else:
                            cooldown_ok = (time.time() - last_add_ts) >= (PYRAMID_ADD_COOLDOWN_SEC * 0.4)  # 0.6→0.4 (더 빠르게)

                        if pos and (adds_used < MAX_ADDS) and cooldown_ok:
                            ok_add, new_entry = add_auto_position(m, curp)
                            if ok_add and new_entry:
                                entry_price = new_entry
                                # ★ 추매 후 스탑은 절대 위로 당기지 않음 (정상 눌림 보호)
                                c1_for_sl = get_minutes_candles(1, m, 20)
                                old_stop = base_stop
                                new_stop, new_sl_pct = dynamic_stop_loss(entry_price, c1_for_sl)
                                base_stop = min(old_stop, new_stop)  # 스탑은 절대 상향 안됨
                                eff_sl_pct = min(eff_sl_pct, new_sl_pct)
                                tg_send_mid(
                                    f"➕ <b>{m}</b> 상승세 추매 체결<br>"
                                    f"💵 새 평단 {fmt_price(entry_price)}원<br>"
                                    f"🧯 손절 {fmt_price(base_stop)}원 ({eff_sl_pct*100:.2f}%)"
                                )

                elif is_stall:
                    # ★ 정체면 부분익절 → 재정체면 전량
                    # 수익이 충분하면 50%, 애매하면 30%
                    sell_ratio = 0.50 if gain_from_entry >= 0.012 else 0.30
                    ok, _, executed = safe_partial_sell(m, sell_ratio=sell_ratio, reason="stall 부분청산")
                    if ok and executed > 0:
                        # 추가로 계속 정체면 전량
                        if stall_age >= 10.0:
                            exit_reason = "STALL_FULL_EXIT"
                            verdict = "정체 지속 전량 청산"
                            break


            # 트레일 업데이트(이익 확대 시에만 상향) — '신고점 갱신' 기준
            # ★ ATR 실패 시 동결 (상향 금지, 조기청산 방지)
            if trail_armed and best > prev_best:
                atr = atr14_from_candles(get_minutes_candles(1, m, 20), 14)
                if atr and atr > 0:  # ★ 정상 ATR일 때만 상향
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                    trail_stop = max(trail_stop, curp * (1.0 - trail_dist))
                # else: ATR 실패 시 동결 (trail_stop 유지)


            # 유효 스탑 = max(기본 동적 SL, 트레일링)
            effective_stop = max(base_stop, trail_stop if trail_armed else 0.0)

            # === 🎯 스캘프 모드: run < 3%면 미세익절 우선 (단, PROBE는 제외!) ===
            # 프로브는 탐색 모드이므로 빠른 정리 없이 컨펌 전환 기회를 줘야 함
            with _POSITION_LOCK:
                current_mode = (OPEN_POSITIONS.get(m) or {}).get("entry_mode", "confirm")

            if run_from_entry < TREND_THRESHOLD and current_mode != "probe":
                # 🔒 최저 청산가 (수수료+마진 보장)
                if micro_floor == 0.0:
                    micro_floor = entry_price * (1.0 + FEE_RATE + SCALP_MICRO_MARGIN + 0.0001)  # +0.01% 쿠션


                # 목표가 도달 시 락 armed
                if curp >= micro_floor:
                    micro_arm = True

                # 🎯 미세익절 청산 조건 (순이익 보장)
                if micro_arm:
                    drop_from_high = (best - curp) / max(best, 1)
                    # 1) 현재가가 최저 청산가 이하로 내려오면 → 즉시 청산 (순이익 확정)
                    # 2) 또는 고점대비 0.05% 하락이면서 여전히 최저가 이상 → 청산
                    if (curp <= micro_floor) or (drop_from_high >= 0.0005 and curp >= micro_floor):
                        exit_reason = "SCALP_MICRO_EXIT"
                        verdict = f"스캘프 미세익절 확정 (gain={gain_from_entry*100:.2f}%, 순익보장)"
                        break

                # 📉 스캘프 모드 손절: 일반보다 타이트하게 (-0.8%)
                if gain_from_entry <= -0.008:
                    exit_reason = "SCALP_STOP"
                    verdict = f"스캘프 손절 (gain={gain_from_entry*100:.2f}%)"
                    break

                # ⏰ 스캘프 타임아웃: ★ 제거 - 시간만으로 손절 금지 (친구 조언)
                # 30초는 너무 짧음. 가격 기반 손절만 사용.
                # if alive_sec >= 30 and -0.002 <= gain_from_entry <= 0.002:
                #     exit_reason = "SCALP_TIMEOUT"
                #     verdict = f"스캘프 타임아웃 본전청산 (gain={gain_from_entry*100:.2f}%)"
                #     break

                # 스캘프 모드에서는 복잡한 상단추적 로직 스킵
                continue

            # === 🔥 추세 모드: run ≥ 3%, 심플매도 로직 (익절 우선 + 이익락 + 거래량감속) ===
            t15 = micro_tape_stats_from_ticks(ticks, 15)
            t30 = micro_tape_stats_from_ticks(ticks, 30)
            avg_ref = (t15["krw_per_sec"] + t30["krw_per_sec"]) / 2
            drop_ratio = t15["krw_per_sec"] / max(t30["krw_per_sec"], 1)
            vdrop_trigger = drop_ratio < 0.65 and t15["buy_ratio"] < 0.55

            cur_gain = (curp / entry_price - 1.0)
            drop_from_high = (best - curp) / best

            # === 🎯 TP_EARLY/TP0/TP1/TP2/TP3 사다리 익절 (소익 확보 + 스탑 잠금) ===
            run_from_entry = (best / entry_price - 1.0)

            # TP_EARLY (+0.2%): 30% 선익절 (승률 극대화, 확실한 수익 확보)
            # ✅ 신규: 작은 수익이라도 확실하게 챙기기
            if cur_gain >= 0.002 and not pos_probe.get("tp_early_done", False):
                ok, _, execd = safe_partial_sell(m, sell_ratio=0.30, reason="TP_EARLY +0.2% 선익절")
                if ok and execd > 0:
                    with _POSITION_LOCK:
                        p = OPEN_POSITIONS.get(m, {}) or {}
                        p["tp_early_done"] = True
                        OPEN_POSITIONS[m] = p
                    tg_send_mid(f"🎯 {m} TP_EARLY(+0.2%) → 30% 선익절 (승률↑)")

            # TP0 (+0.6%): 20% 익절 (소익 조기 확보, 러너 보존)
            # ✅ 개선: 30% → 20% (큰 상승 시 수익 극대화)
            if cur_gain >= 0.006 and not pos_probe.get("tp0_done", False):
                ok, _, execd = safe_partial_sell(m, sell_ratio=0.20, reason="TP0 +0.6% 부분익절")
                if ok and execd > 0:
                    with _POSITION_LOCK:
                        p = OPEN_POSITIONS.get(m, {}) or {}
                        p["tp0_done"] = True
                        OPEN_POSITIONS[m] = p
                    tg_send_mid(f"💰 {m} TP0(+0.6%) → 20% 익절")

            # TP1 (+1.0%): 30% 익절 + 스탑을 본전(BE) 위로
            if cur_gain >= 0.010 and not pos_probe.get("tp1_done", False):
                ok, _, execd = safe_partial_sell(m, sell_ratio=0.30, reason="TP1 +1.0% 부분익절")
                if ok and execd > 0:
                    with _POSITION_LOCK:
                        p = OPEN_POSITIONS.get(m, {}) or {}
                        p["tp1_done"] = True
                        OPEN_POSITIONS[m] = p
                    # BE 락 (수수료 + 소폭 마진)
                    be_lock = entry_price * (1.0 + FEE_RATE + SCALP_MICRO_LOCK)
                    base_stop = max(base_stop, be_lock)  # 로컬 스탑 상향
                    with _POSITION_LOCK:  # 포지션에도 반영
                        q = OPEN_POSITIONS.get(m, {}) or {}
                        q["stop"] = max(float(q.get("stop", 0.0)), float(base_stop))
                        OPEN_POSITIONS[m] = q
                    tg_send_mid(f"🔒 {m} TP1(+1.0%) → 30% 익절 + 본전 잠금 {fmt_price(be_lock)}")

            # TP2 (+1.5%): 20% 익절 + 스탑을 +0.5%로
            if run_from_entry >= 0.015 and not pos_probe.get("tp2_done", False):
                ok, _, execd = safe_partial_sell(m, sell_ratio=0.20, reason="TP2 +1.5% 부분익절")
                if ok and execd > 0:
                    with _POSITION_LOCK:
                        p = OPEN_POSITIONS.get(m, {}) or {}
                        p["tp2_done"] = True
                        OPEN_POSITIONS[m] = p
                    # +0.5% 잠금
                    lock_0_5 = entry_price * 1.005
                    base_stop = max(base_stop, lock_0_5)
                    with _POSITION_LOCK:
                        q = OPEN_POSITIONS.get(m, {}) or {}
                        q["stop"] = max(float(q.get("stop", 0.0)), float(base_stop))
                        OPEN_POSITIONS[m] = q
                    tg_send_mid(f"🔒 {m} TP2(+1.5%) → 20% 익절 + 스탑 +0.5% 잠금 {fmt_price(lock_0_5)}")

            # TP3 (+2.5%): 15% 익절 + 스탑을 +1.2%로 (대박 상승 포착)
            # ✅ 신규: 큰 상승 시 추가 수익 확보
            if run_from_entry >= 0.025 and not pos_probe.get("tp3_done", False):
                ok, _, execd = safe_partial_sell(m, sell_ratio=0.15, reason="TP3 +2.5% 부분익절")
                if ok and execd > 0:
                    with _POSITION_LOCK:
                        p = OPEN_POSITIONS.get(m, {}) or {}
                        p["tp3_done"] = True
                        OPEN_POSITIONS[m] = p
                    # +1.2% 잠금 (안전 마진)
                    lock_1_2 = entry_price * 1.012
                    base_stop = max(base_stop, lock_1_2)
                    with _POSITION_LOCK:
                        q = OPEN_POSITIONS.get(m, {}) or {}
                        q["stop"] = max(float(q.get("stop", 0.0)), float(base_stop))
                        OPEN_POSITIONS[m] = q
                    tg_send_mid(f"🎉 {m} TP3(+2.5%) → 15% 익절 + 스탑 +1.2% 잠금 {fmt_price(lock_1_2)}")

            # === 🎯 Patch #2: 수직 확장 상단 캡처 (고점에서 파기) ===
            # 스파이크 감지: EMA3/VWAP 갭 과도 + 가속→감속 전환
            try:
                c1m_spike = get_minutes_candles(1, m, 20)
                vwap20_spike = vwap_from_candles_1m(c1m_spike, 20)
                ema3_spike = ema_last([c["trade_price"] for c in c1m_spike], 3)

                # VWAP 대비 갭, EMA3 대비 갭
                vwap_gap = (curp / max(vwap20_spike, 1) - 1.0) if vwap20_spike else 0.0
                ema3_gap = (curp / max(ema3_spike, 1) - 1.0) if ema3_spike else 0.0

                # 스파이크 조건: VWAP 갭 ≥ 2.2% OR EMA3 갭 ≥ 2.5%
                spike_detected = (vwap_gap >= 0.022 or ema3_gap >= 0.025)

                # 감속 조건: drop_ratio < 0.70 (거래량 30% 이상 하락)
                decel_detected = drop_ratio < 0.70

                # 스파이크 + 감속 → 부분 익절 (30-50%)
                if spike_detected and decel_detected and cur_gain >= 0.015:
                    # 갭이 클수록 더 많이 매도 (2.2% → 30%, 3.0%+ → 50%)
                    sell_ratio = 0.30 if max(vwap_gap, ema3_gap) < 0.030 else 0.50
                    safe_partial_sell(m, sell_ratio=sell_ratio, reason=f"수직확장상단캡처 {sell_ratio*100:.0f}%")

                    # 트레일링 스탑 조이기 (0.6%)
                    if trail_armed:
                        tight_trail = curp * 0.994  # 0.6% 트레일
                        trail_stop = max(trail_stop, tight_trail)
                        print(f"[SPIKE_TOP] {m} 스파이크 상단 감지 → 트레일 0.6%로 조임 (vwap_gap={vwap_gap:.3f}, ema3_gap={ema3_gap:.3f})")
            except Exception as e:
                # 스파이크 감지 실패 시 무시
                pass

            # === 🎯 Patch #4: 수익 구간 트레일 조이기 ===
            # 수익 +1.2% 이상 & 거래량 감소 시 → 트레일 0.6%로 타이트하게
            if trail_armed and cur_gain >= 0.012 and drop_ratio < 0.75:
                tight_profit_trail = curp * 0.994  # 0.6% 트레일
                if tight_profit_trail > trail_stop:
                    trail_stop = tight_profit_trail
                    print(f"[PROFIT_TRAIL] {m} 수익구간 트레일 조임 → 0.6% (gain={cur_gain*100:.2f}%, drop_ratio={drop_ratio:.2f})")

            # === 🎯 PATCH D: 모멘텀 둔화/시간스탑/VWAP 과열→복귀 강제 익절 트리거 ===
            # (1) 모멘텀 둔화 강제 익절 (+1R 이상 찍었을 때만)
            if run_from_entry >= eff_sl_pct:  # 최소 +1R 찍은 뒤에만
                if t15["krw_per_sec"] < 0.75 * max(t30["krw_per_sec"], 1) and t15.get("buy_value_ratio", 0) < 0.52:
                    # ★★★ 강추세 예외: 구조가 건재하면 TAPE_SLOWDOWN 무시 ★★★
                    # (친구 조언: EMA20 위 + PSAR 아래 + +DI 우위면 유지)
                    try:
                        c1m_sd = get_minutes_candles(1, m, 20)
                        if c1m_sd and len(c1m_sd) >= 20:
                            closes_sd = [c["trade_price"] for c in c1m_sd]
                            ema20_sd = ema_last(closes_sd, 20)
                            psar_sd = parabolic_sar(c1m_sd)
                            adx_sd = adx_di(c1m_sd, 14)

                            # 강추세 조건 체크
                            above_ema20 = (ema20_sd and curp > ema20_sd)
                            psar_bullish = (psar_sd and psar_sd.get("is_uptrend", False))
                            di_bullish = (adx_sd and adx_sd.get("plus_di", 0) > adx_sd.get("minus_di", 0))

                            # 3개 중 2개 이상 충족 시 강추세 → 유지
                            strong_trend = sum([above_ema20, psar_bullish, di_bullish]) >= 2
                            if strong_trend:
                                print(f"[TAPE_SLOWDOWN_SKIP] {m} 강추세 유지 (EMA20={above_ema20}, PSAR={psar_bullish}, DI={di_bullish}) → 청산 스킵")
                                pass  # 청산하지 않고 계속 홀드
                            else:
                                exit_reason = "TAPE_SLOWDOWN_EXIT"
                                verdict = f"모멘텀 둔화 익절 (t15={t15['krw_per_sec']:.0f}, buy={t15.get('buy_value_ratio',0)*100:.0f}%)"
                                tg_send_mid(f"🔻 {m} {verdict}")
                                break
                        else:
                            exit_reason = "TAPE_SLOWDOWN_EXIT"
                            verdict = f"모멘텀 둔화 익절 (t15={t15['krw_per_sec']:.0f}, buy={t15.get('buy_value_ratio',0)*100:.0f}%)"
                            tg_send_mid(f"🔻 {m} {verdict}")
                            break
                    except Exception as e:
                        print(f"[TAPE_SLOWDOWN_ERR] {m}: {e}")
                        exit_reason = "TAPE_SLOWDOWN_EXIT"
                        verdict = f"모멘텀 둔화 익절 (t15={t15['krw_per_sec']:.0f}, buy={t15.get('buy_value_ratio',0)*100:.0f}%)"
                        tg_send_mid(f"🔻 {m} {verdict}")
                        break

            # (2) 시간 스탑 (재가속 실패) - ★ 180초로 완화 + 구조 이탈 확인
            if alive_sec >= 180 and t15["krw_per_sec"] < t30["krw_per_sec"]:
                # ★ 추가 조건: 가격도 EMA5 아래여야 손절 (구조 이탈 확인)
                try:
                    c1m_ts = get_minutes_candles(1, m, 10)
                    ema5_ts = ema_last([c["trade_price"] for c in c1m_ts], 5) if c1m_ts else None
                    if ema5_ts and curp >= ema5_ts:
                        # EMA5 위에 있으면 아직 구조 유지 → 스킵
                        pass
                    else:
                        exit_reason = "TIME_STOP"
                        verdict = f"재가속 실패 시간 스탑 (180초+, t15={t15['krw_per_sec']:.0f} < t30={t30['krw_per_sec']:.0f}, EMA5 이탈)"
                        tg_send_mid(f"⏱️ {m} {verdict}")
                        break
                except Exception:
                    pass  # 에러 시 손절 스킵

            # (3) VWAP 과열→복귀 익절 (상단 회수)
            try:
                c1m_v = get_minutes_candles(1, m, 20)
                vwap20_v = vwap_from_candles_1m(c1m_v, 20)
                if vwap20_v:
                    vgap_now = (curp / vwap20_v - 1.0)
                    peak_vwap_gap = max(peak_vwap_gap, vgap_now)
                    # 피크 2.0% 이상 & 현재 1.2% 이하로 복귀 & +1R 이상
                    if peak_vwap_gap >= 0.020 and vgap_now <= 0.012 and run_from_entry >= eff_sl_pct:
                        safe_partial_sell(m, sell_ratio=0.50, reason="VWAP 과열→복귀")
                        tg_send_mid(f"📊 {m} VWAP 과열→복귀 50% 익절 (피크 {peak_vwap_gap*100:.1f}% → 현재 {vgap_now*100:.1f}%)")
                        peak_vwap_gap = 0.0  # 리셋
            except Exception:
                pass

            # ① 급락 즉시 손절 - 최소 보유 시간 예외 (프로파일 설정 HARD_STOP_DD 사용)
            if cur_gain <= -HARD_STOP_DD:
                exit_reason = "HARD_STOP"
                tg_send_mid(f"🩸 {m} 급락 -{HARD_STOP_DD*100:.1f}% 컷(대기)")
                verdict = "HARD_STOP"
                break

            # === 최소 보유 시간 10초 (급락 외에는 적용) ===
            if alive_sec < 10:
                continue  # 10초 미만은 청산 로직 스킵

            # ② 조기익절: 고점 대비 -0.3% & 거래량감속
            if drop_from_high >= 0.003 and vdrop_trigger:
                safe_partial_sell(m, sell_ratio=0.5, reason="조기익절 50%")
                verdict = "PARTIAL_EXIT"

            # ②-2 거래량 급감 조기 청산 (고점 포착)
            if drop_ratio < 0.60 and t15["buy_ratio"] < 0.50 and cur_gain >= 0.005:
                # 거래량 40% 감소 + 매수비 50% 미만 + 최소 0.5% 이익
                exit_reason = "VOLUME_DROP_EARLY"
                tg_send_mid(f"📉 {m} 거래량 급감 감지 → 조기 청산 (gain={cur_gain*100:.2f}%)")
                verdict = "VOLUME_DROP_EXIT"
                break

            # ③ 전량익절: 고점대비 하락 임계치(동적) - ★ 완화 (일찍 청산 방지)
            dyn_drop_thr = 0.013  # 기본 1.3% (1.0→1.3 완화)
            if t15["krw_per_sec"] >= 25000 and t15["buy_ratio"] >= 0.60:
                dyn_drop_thr = 0.018   # 강추세: 더 여유 (1.6→1.8 완화)
            elif t15["krw_per_sec"] <= 12000 or t15["buy_ratio"] < 0.52:
                dyn_drop_thr = 0.010   # 둔화: 더 타이트 (0.8→1.0 완화)

            # ← 임계치 산정과 판정을 분리
            if drop_from_high >= dyn_drop_thr:
                exit_reason = "DROP_FROM_HIGH"
                tg_send_mid(f"🚨 {m} 고점대비 {drop_from_high*100:.2f}% 하락 → 전량익절(대기)")
                verdict = "FULL_EXIT"
                break

            # ④ 이익락 (Profit Lock) — 고정식으로 무장 & 상향만
            if not profit_lock_active and cur_gain >= 0.010:
                # 수익 구간 진입 시 락 무장 (임계에 따라 여유폭 다르게)
                lock_gap = 0.008 if cur_gain >= 0.015 else 0.006  # 0.8% or 0.6%
                profit_lock_price = best * (1.0 - lock_gap)
                profit_lock_active = True
            elif profit_lock_active:
                # 신고점 갱신 시에만 '상향' 조정 (결코 하향 X)
                lock_gap = 0.008 if cur_gain >= 0.015 else 0.006
                profit_lock_price = max(profit_lock_price, best * (1.0 - lock_gap))

            # 트리거 판정은 '고정된' 락 가격으로
            if profit_lock_active and curp <= profit_lock_price:
                exit_reason = "PROFIT_LOCK"
                tg_send_mid(f"💎 {m} 이익락 발동 ({fmt_price(profit_lock_price)}원) → 청산(대기)")
                verdict = "PROFIT_LOCK"
                break

            # ⑤ 트레일링 스탑 (고점 대비 0.5%) — '신고점 갱신' 시만 상향
            if trail_armed and best > prev_best:
                trail_stop = max(trail_stop, best * 0.995)

            # 🔒 트레일 스탑 디바운스 (일시적 되밀림 허위 청산 방지)
            if trail_armed and curp <= trail_stop:
                if stop_first_seen_ts == 0.0:
                    stop_first_seen_ts = time.time()
                    stop_hits = 1
                else:
                    stop_hits += 1
                # EXIT_DEBOUNCE_SEC(6초) 경과 OR EXIT_DEBOUNCE_N(2회) 연속 히트
                if (time.time() - stop_first_seen_ts) >= EXIT_DEBOUNCE_SEC or stop_hits >= EXIT_DEBOUNCE_N:
                    exit_reason = "TRAIL_EXIT"
                    tg_send_mid(f"📉 {m} 트레일링 스탑({fmt_price(trail_stop)}원) 확정 청산")
                    verdict = "TRAIL_EXIT"
                    break
            else:
                # 스탑 위로 복귀 → 디바운스 리셋
                if trail_armed:
                    stop_first_seen_ts = 0.0
                    stop_hits = 0


            # ⑥ 재진입은 remonitor_until_close()가 청산 후 처리하므로 여기서는 불필요

        if verdict is None:
            verdict = "시간 만료(모니터링 종료)"

    finally:
        # ================================
        # 1) 최신 상태 / 수익률 계산
        # ================================
        ticks = get_recent_ticks(m, 100)
        t15 = micro_tape_stats_from_ticks(ticks, 15) if ticks else {
            "buy_ratio": 0,
            "krw": 0,
            "n": 0,
            "krw_per_sec": 0
        }

