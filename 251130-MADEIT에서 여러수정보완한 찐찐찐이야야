# === 🔧 틱버스트 허용 판단 (회전율별 사이징) ===
def allow_tick_burst(buy_ratio, turn_pct, tick_count, spread, symbol_median_spread=None):
    """
    틱버스트 진입 허용 여부 및 사이징 결정
    Returns: (allow, size, reason)
        - allow: True/False
        - size: "normal" / "half" / "probe" / None
        - reason: 차단/허용 사유
    """
    # --- 공통 하드컷 ---
    if tick_count < 5:
        return False, None, "틱수 부족(<5)"

    if buy_ratio <= 0.05:
        return False, None, "매수비 0% 편향"

    # 스프레드 상대화 (기본 0.20%, 종목 중앙값의 1.5배까지 허용)
    # 🔧 캡 0.25 → 0.35 (OPEN 0.31% 승자 커버)
    thr_spread = 0.20
    if symbol_median_spread is not None and symbol_median_spread > 0:
        thr_spread = min(0.35, 1.5 * symbol_median_spread)

    if spread > thr_spread:
        return False, None, f"스프레드 초과({spread:.2f}%>{thr_spread:.2f}%)"

    # 저회전 + 극단 매수 스푸프 차단
    if turn_pct < 8.0 and buy_ratio >= 0.95:
        return False, None, "저회전+극단매수(스푸핑 의심)"

    # --- 유동성 레짐 분기 (하드컷 대신 사이징) ---
    if turn_pct >= 8.0:
        # 고유동: 매수비 완화 (승자 중 0.62~0.70 존재)
        if buy_ratio < 0.62:
            return False, None, f"고회전 매수비 부족({buy_ratio:.0%}<62%)"
        size = "normal"
    elif turn_pct >= 3.0:
        # 중간 유동: 살짝 보수적
        if buy_ratio < 0.75:
            return False, None, f"중회전 매수비 부족({buy_ratio:.0%}<75%)"
        size = "half"
    else:
        # 저유동: 리스크 큼 → 프로브만 허용
        if buy_ratio < 0.85:
            return False, None, f"저회전 매수비 부족({buy_ratio:.0%}<85%)"
        size = "probe"

    return True, size, f"통과(회전{turn_pct:.1f}%,매수{buy_ratio:.0%},사이즈={size})"


def detect_leader_stock(m, obc, c1, tight_mode=False):
    """
    하이브리드 진입 탐지 엔진:
      - Probe(소액): 완화된 early 흐름 감지 → 초기 염탐 진입
      - Confirm(추세): 강한 점화/매집/돌파 → 확정 진입
    """
    if len(c1) < 3:
        return None

    # === 🔧 스테이블코인 차단 (USDT, USDC 등 가격변동 없는 코인) ===
    if any(stable in m.upper() for stable in ["USDT", "USDC", "DAI", "TUSD", "BUSD"]):
        cut("STABLECOIN", f"{m} 스테이블코인 제외")
        return None

    # === 동일 종목 중복 진입 방지 (포지션 보유 시 스킵) ===
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
    if pos:
        # 🔧 FIX: 포지션 보유중이면 무조건 스킵 (재진입은 monitor_position에서 처리)
        return None

    # === 틱 기반 초봉(10초) 선행 진입 시그널 ===
    ticks_now = get_recent_ticks(m, 80)
    if ticks_now:
        t10s = micro_tape_stats_from_ticks(ticks_now, 10)
        t30s = micro_tape_stats_from_ticks(ticks_now, 30)

        sudden_burst = (
            t10s["krw_per_sec"] >= 1.8 * t30s["krw_per_sec"]
            and t10s["buy_ratio"] >= 0.58
            and t10s["n"] >= 3
        )

        fresh = uptick_streak_from_ticks(ticks_now, need=1)

        if sudden_burst and fresh:
            # === 🔧 틱버스트 야간 금지 (01~07시) ===
            h = now_kst().hour
            if 1 <= h < 7:
                cut("TICK_NIGHT", f"{m} 틱버스트 야간(01~07시) 제외")
                # 틱버스트 스킵하고 일반 경로로 진행
                pass
            else:
                # === 🔧 틱버스트 회전율별 사이징 로직 ===
                tape = micro_tape_stats_from_ticks(ticks_now, 15)
                cur_vol = c1[-1].get("candle_acc_trade_price", 0) if c1 else 0
                past_vols = [c["candle_acc_trade_price"] for c in c1[-7:-2] if c.get("candle_acc_trade_price", 0) > 0] if len(c1) >= 3 else []
                avg_past = statistics.mean(past_vols) if past_vols else max(cur_vol / 8, 1)
                vol_surge = cur_vol / max(avg_past, 1)

                ob_tick = obc.get(m)
                ob_spread = ob_tick.get("spread", 999) if ob_tick else 999
                ob_depth = ob_tick.get("depth_krw", 1) if ob_tick else 1
                turn_pct = (tape["krw"] / max(ob_depth, 1)) * 100  # 회전율 %
                buy_ratio = t10s["buy_ratio"]
                tick_count = t10s["n"]

                # 🔧 새로운 allow_tick_burst 함수 사용
                allowed, size_mode, reason = allow_tick_burst(
                    buy_ratio=buy_ratio,
                    turn_pct=turn_pct,
                    tick_count=tick_count,
                    spread=ob_spread,
                    symbol_median_spread=None  # TODO: 종목별 중앙값 캐시 필요시 추가
                )

                if not allowed:
                    cut("TICK_FILTER", f"{m} 틱버스트 {reason}")
                    # 틱버스트 스킵하고 일반 경로로 진행
                    pass
                else:
                    cut("PROBE_TICK", f"{m} 틱버스트 {reason}")
                    # 🔧 FIX: price_change 계산 (등락% 표시용)
                    price_change = (c1[-1]["trade_price"] / max(c1[-2]["trade_price"], 1) - 1) if len(c1) >= 2 else 0.0

                    # 🔧 사이즈 모드에 따른 entry_mode 설정
                    if size_mode == "normal":
                        entry_mode = "confirm"
                    elif size_mode == "half":
                        entry_mode = "half"  # 절반 사이즈
                    else:
                        entry_mode = "probe"  # 소액 탐색

                    pre = {
                        "price": ticks_now[0]["trade_price"],
                        "change": price_change,
                        "ob": ob_tick,
                        "ticks": ticks_now,
                        "tape": tape,
                        "current_volume": cur_vol,
                        "volume_surge": vol_surge,
                        "entry_mode": entry_mode,
                        "tick_size_mode": size_mode,  # 사이징 정보 저장
                        "early_ok": True,
                        "detect_type": "tick_burst",
                        "trigger_type": ["틱버스트"],
                        "allow_precision": False,  # 🔧 틱버스트는 프리시전 비활성화
                    }
                    return pre

    # (이하 기존 detect_leader_stock 코드 계속)

    ob = obc.get(m)
    if not ob or not isinstance(ob.get("raw"), dict):
        return None
    if not ob.get("raw", {}).get("orderbook_units"):
        return None
    if ob.get("depth_krw", 0) <= 0:
        return None

    mega = is_mega_breakout(c1)
    th = get_dynamic_thresholds()
    cur, prev = c1[-1], c1[-2]
    price_change = (cur["trade_price"] / max(prev["trade_price"], 1) - 1)

    # 스프레드 컷
    if ob["spread"] > (MAX_SPREAD_FAST if mega else MAX_SPREAD_BASE):
        cut("SPREAD_HIGH", f"{m} spread {ob['spread']:.2f}%")
        return None

    # 거래량 조건
    current_volume = cur.get("candle_acc_trade_price", 0)
    # 🔍 DEBUG: 캔들 대금 확인
    if current_volume == 0:
        print(f"[DEBUG_VOL] {m} candle_acc_trade_price=0! cur_keys={list(cur.keys())[:5]}")
    if current_volume < MIN_VOLUME_KRW and not mega:
        cut("VOL_LOW", f"{m} vol {int(current_volume)}")
        return None

    # 거래 증가율 체크
    past_volumes = [c["candle_acc_trade_price"] for c in c1[-7:-2] if c["candle_acc_trade_price"] > 0]
    if not meets_volume_surge(current_volume, past_volumes) and not mega:
        ticks_tmp = get_recent_ticks(m, 100)
        t15_tmp = micro_tape_stats_from_ticks(ticks_tmp, 15)
        t45_tmp = micro_tape_stats_from_ticks(ticks_tmp, 45)
        if not (t15_tmp["krw_per_sec"] >= max(55_000, 1.15 * t45_tmp["krw_per_sec"])):
            cut("SURGE_LOW", f"{m} vol_surge_fail")
            return None

    # 약상승 컷
    if price_change < th["min_change"] and not mega:
        cut("PRICE_LOW", f"{m} {price_change*100:.2f}%")
        return None

    # 틱 확보
    ticks = get_recent_ticks(m, 100)
    if not ticks:
        cut("TICKS_LOW", f"{m} no ticks")
        return None

    # === 테이프·EMA 공통 지표 ===
    tape_stats = {k: micro_tape_stats_from_ticks(ticks, k) for k in [10, 15, 30, 45]}
    closes_1m = [x["trade_price"] for x in c1]
    ema5 = ema_last(closes_1m, 5) if closes_1m else None
    dist_ema5 = (cur["trade_price"] / ema5 - 1.0) if ema5 else 0.0
    t10, t15, t30, t45 = tape_stats[10], tape_stats[15], tape_stats[30], tape_stats[45]
    last_upticks_ok = uptick_streak_from_ticks(ticks, need=2)

    # === 점화/브레이크아웃 계열 ===
    ign_ok, ign_reason = ignition_trigger_ok(m, c1, ticks, ob)
    tick_break = tick_breakout_ok(m, c1, ticks, ob)
    ign_ok = ign_ok or tick_break

    botacc_ok, botacc_reason = bot_accum_trigger_ok(m, ticks, ob, c1)
    two_green_and_break = (
        sum(1 for c in c1[-3:] if c["trade_price"] > c["opening_price"]) >= 2
        and c1[-1]["high_price"] > max(c["high_price"] for c in c1[-4:-1])
    )

    # === Early (Probe) 진입 판단 ===
    r = relax_knob()
    twin = t15 if t15["krw_per_sec"] >= t45["krw_per_sec"] else t45
    vgap = (cur["trade_price"] / max(vwap_from_candles_1m(c1, 20), 1) - 1)
    turn = twin["krw"] / max(ob["depth_krw"], 1)
    flow_floor = int(EARLY_FLOW_MIN_KRWPSEC * (0.80 if r >= 1.0 else 1.0))

    early_conds = [
        vgap >= max(th["vwap_gap"] - 0.0003, EARLY_MIN_VWAP_GAP),
        vgap <= EARLY_MAX_VWAP_GAP,
        price_change <= 0.020,
        (ema5 is None) or (dist_ema5 <= EARLY_MAX_EMA5_GAP),
        twin["buy_ratio"] >= max(EARLY_MIN_BUY, 0.51),
        twin["krw_per_sec"] >= flow_floor,
        turn >= max(EARLY_MIN_TURN, 0.015),
        twin["n"] >= EARLY_MIN_TICKS,
        last_two_ticks_fresh(ticks),
    ]

    early_ok = all(early_conds)

    # === 🔧 Early/점화 트리거 비활성화 (성과 0% 기반) ===
    # 점화(ign_ok)와 Early(early_ok)는 현재 승률이 0%이므로 비활성화
    ign_ok = False  # 점화 비활성화
    early_ok = False  # Early 비활성화

    # === Confirm (확정 진입 판단) ===
    confirm_ok = (
        botacc_ok or mega or two_green_and_break
        # ign_ok, early_ok 제외됨
    )

    # === Probe/Confirm 결과 ===
    if not confirm_ok:
        cut("NO_SIGNAL", f"{m} no entry cond (Early/점화 비활성)")
        return None

    entry_mode = "confirm"  # Early 없으므로 항상 confirm

    # === 결과 패키징 ===
    # 2단계: 트리거 타입 결정
    trigger_type = []
    # if ign_ok: trigger_type.append("점화")  # 비활성
    if botacc_ok: trigger_type.append("봇매집")
    if two_green_and_break: trigger_type.append("연속양봉")
    # if early_ok: trigger_type.append("Early")  # 비활성

    pre = {
        "price": cur["trade_price"],
        "change": price_change,
        "current_volume": current_volume,
        "volume_surge": (current_volume / max(statistics.mean(past_volumes) if past_volumes else current_volume / 8, 1)),
        "ob": ob,
        "tape": twin,
        "ticks": ticks,
        "ema5_gap": dist_ema5,
        "ign_ok": ign_ok,
        "botacc_ok": botacc_ok,
        "two_green_break": two_green_and_break,
        "early_ok": early_ok,
        "entry_mode": entry_mode,
        "detect_type": "normal",  # ← 1단계: 일반 감지
        "trigger_type": trigger_type,  # ← 2단계: 트리거 목록
    }
    if mega:
        pre["mega_ok"] = True
        pre["trigger_type"].append("메가")

    return pre

def final_check_leader(m, pre, tight_mode=False):
    # ★★★ 완화 노브 적용
    r = relax_knob()
    t = pre["tape"]
    ob = pre["ob"]
    ticks = pre["ticks"]

    # === 최소 조건 (이건 AND로 유지) ===
    if t["n"] < MIN_TICKS_COUNT:
        cut("TICKS_LOW", f"{m} {t['n']}")
        return None

    # 스프레드 극단값 필터 (2% 이상은 무조건 제외)
    if ob["spread"] > 2.0:
        cut("SPREAD_EXTREME", f"{m} spread {ob['spread']:.2f}%")
        return None

    # === 리스크 스코어 계산 ===
    turn = t["krw"] / max(ob["depth_krw"], 1)
    imbalance = calc_orderbook_imbalance(ob)
    fresh_ok = last_two_ticks_fresh(ticks)
    volume_surge = pre.get("volume_surge", 1.0)

    if USE_RISK_SCORE:
        score = calc_risk_score(
            buy_ratio=t["buy_ratio"],
            spread=ob["spread"],
            turn=turn,
            imbalance=imbalance,
            fresh_ok=fresh_ok,
            volume_surge=volume_surge
        )

        # tight_mode면 임계값 상향
        threshold = RISK_SCORE_THRESHOLD + (5 if tight_mode else 0)
        # 야간엔 약간 완화
        if 0 <= now_kst().hour < 6:
            threshold -= 3
        # 장세 완화 노브 반영
        threshold -= int(2 * r)

        if score < threshold:
            cut("SCORE_LOW", f"{m} score={score:.1f} < {threshold}")
            return None

        # 스코어 통과 시 로그
        print(f"[SCORE_OK] {m} score={score:.1f} (buy={t['buy_ratio']:.2f}, spread={ob['spread']:.2f}, turn={turn:.3f}, imb={imbalance:.2f})")

    else:
        # === 기존 AND 로직 (USE_RISK_SCORE=False 시 폴백) ===
        MIN_TURNOVER_LOCAL = max(0.020, _turn_needed(ob.get("depth_krw", 0)))
        if tight_mode:
            MIN_TURNOVER_LOCAL += 0.003
        if 0 <= now_kst().hour < 6:
            MIN_TURNOVER_LOCAL = max(0.018, MIN_TURNOVER_LOCAL - 0.004)
        MIN_TURNOVER_LOCAL = max(0.020, MIN_TURNOVER_LOCAL - 0.002 * r)

        TICKS_BUY_RATIO_LOCAL = max(0.56, TICKS_BUY_RATIO + (0.02 if tight_mode else 0.0))
        TICKS_BUY_RATIO_LOCAL = max(0.54, TICKS_BUY_RATIO_LOCAL - 0.015 * r)

        if turn < MIN_TURNOVER_LOCAL:
            cut("TURN_LOW", f"{m} turn {turn:.3f}")
            return None
        if t["buy_ratio"] < TICKS_BUY_RATIO_LOCAL:
            cut("BUY_WEAK", f"{m} buy {t['buy_ratio']:.2f}")
            return None
        if t["n"] >= 10 and t["buy_ratio"] < 0.63:
            cut("BUY_WEAK_MANYT", f"{m} weak many")
            return None
        if not fresh_ok:
            cut("FRESH_FAIL", f"{m} stale")
            return None
        th = get_dynamic_thresholds()
        raw_ob = ob["raw"]["orderbook_units"][:3]
        bid_sum = sum(u["bid_size"] * u["bid_price"] for u in raw_ob)
        ask_sum = sum(u["ask_size"] * u["ask_price"] for u in raw_ob)
        if bid_sum / max(ask_sum, 1) < th["bidask_min"]:
            cut("BIDASK_WEAK", f"{m} bidask weak")
            return None
        max_spread = MAX_SPREAD_FAST if t.get("rate", 0) >= 0.7 else MAX_SPREAD_BASE
        if ob["spread"] > max_spread:
            cut("SPREAD_HIGH", f"{m} spread {ob['spread']:.2f}%")
            return None

    price_change = pre.get("change", 0.0)
    turn_pct = turn * 100  # 회전율 %

    # ========================================
    # ★★★ 신규 필터: 성공/실패 패턴 기반 필터링 ★★★
    # ========================================
    buy_ratio = t["buy_ratio"]

    # --- 프리시전 포켓 체크 (예외 허용 조건) ---
    # 조건: 임밸 >= 0.80 AND 매수비 >= 63.5%
    # (정밀도 ~82%, 실제 알람 데이터 분석 기반)
    # 🔧 틱버스트는 프리시전 비활성화 (데이터상 0% 승률)
    allow_precision = pre.get("allow_precision", True)
    if pre.get("detect_type") == "tick_burst":
        allow_precision = False

    is_precision_pocket = (
        allow_precision
        and imbalance >= 0.80
        and buy_ratio >= 0.635
    )

    # --- 하드컷 조건 ---
    # 1) 매수비 == 100% → 컷 (성공률 30%, 가장 흔한 실패 패턴)
    if abs(buy_ratio - 1.0) < 1e-6:
        if not is_precision_pocket:
            cut("BUYRATIO_100PCT", f"{m} buy=100% (high fail pattern)")
            return None

    # 2) 임밸 < 0.25 → 컷 (성공률 36%, 호가 균형 취약)
    if imbalance < 0.25:
        cut("IMBAL_LOW", f"{m} imbal {imbalance:.2f} < 0.25")
        return None

    # 3) 회전 >= 48% → 컷 (펌핑/휩쏘 위험), 포켓이면 예외
    if turn_pct >= 48.0:
        if not is_precision_pocket:
            cut("TURN_OVERHEAT", f"{m} turn {turn_pct:.1f}% >= 48%")
            return None
    # ========================================

    # 3단계: 필터 타입 결정
    filter_type = "프리시전" if is_precision_pocket else "기본통과"

    return {
        "price": pre["price"],
        "chg": round(price_change * 100, 2),
        "current_volume": int(pre.get("current_volume", 0)),
        "volume_surge": round(pre.get("volume_surge", 0.0), 2),
        "buy": round(t["buy_ratio"] * 100, 1),
        "n": t["n"],
        "spread": round(ob["spread"], 2),
        "turn": round(turn_pct, 2),
        "imbalance": round(imbalance, 3),
        "score": score if USE_RISK_SCORE else 0,
        "is_precision_pocket": is_precision_pocket,
        "filter_type": filter_type,  # ← 3단계: 기본통과/프리시전
    }


