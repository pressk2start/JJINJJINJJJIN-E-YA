def sell_market(market, volume, max_attempts=3):
    """
    시장가 매도 with 재시도 로직
    - market: 종목 코드
    - volume: 매도 수량
    - max_attempts: 최대 시도 횟수 (기본 3회)

    업비트 최소 거래금액(5,000원) 체크 포함
    """
    # AUTO_TRADE 최후 가드 (혹시 모를 호출 실수 방지)
    if not AUTO_TRADE:
        print(f"[SELL_SKIP] AUTO_TRADE=0 → 주문 스킵 ({market}, vol={volume:.6f})")
        return False

    # 🔍 최소 거래금액 체크 (업비트: 5,000원 미만 거래 불가)
    try:
        ticker_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": market})
        if ticker_js and len(ticker_js) > 0:
            current_price = ticker_js[0].get("trade_price", 0)
            order_value = volume * current_price

            if order_value < MIN_ORDER_KRW:
                # 소액 잔고: 매도 시도하지 않고 포지션만 정리
                print(f"[SELL_SKIP] {market} 소액 잔고 무시: {volume:.6f}코인 (≈{order_value:.0f}원 < {MIN_ORDER_KRW}원)")
                with _POSITION_LOCK:
                    pos = OPEN_POSITIONS.get(market)
                    if pos:
                        current_vol = pos.get("volume", 0)
                        new_vol = max(0, current_vol - volume)
                        if new_vol > 0:
                            pos["volume"] = new_vol
                            OPEN_POSITIONS[market] = pos
                        else:
                            OPEN_POSITIONS.pop(market, None)
                return True  # 정리 완료로 간주
    except Exception as e:
        print(f"[SELL_WARN] {market} 가격 조회 실패, 매도 계속 진행: {e}")

    # 실제 매도 시도
    for attempt in range(1, max_attempts + 1):
        try:
            res = place_market_sell(market, volume)
            order_uuid = res.get("uuid") if isinstance(res, dict) else None

            # 체결 확인 (실제 executed_volume 기준으로 포지션 차감)
            od = get_order_result(order_uuid, timeout_sec=6.0) if order_uuid else None

            executed = 0.0
            if od:
                try:
                    executed = float(od.get("executed_volume") or "0")
                except Exception:
                    executed = 0.0

            if executed > 0:
                # 실제 체결 수량만큼 차감 (부분 체결 대응)
                with _POSITION_LOCK:
                    pos = OPEN_POSITIONS.get(market)
                    if pos:
                        current_vol = pos.get("volume", 0)
                        new_vol = max(0.0, current_vol - executed)
                        if new_vol > 0:
                            pos["volume"] = new_vol
                            OPEN_POSITIONS[market] = pos
                        else:
                            # 전량 매도 → 포지션 제거
                            OPEN_POSITIONS.pop(market, None)
                print(f"[SELL_OK] {market} 매도 체결: {executed:.6f} (요청 {volume:.6f}, 시도 {attempt}/{max_attempts})")
                return True
            else:
                print(f"[SELL_WARN] {market} 체결 수량 0 (시도 {attempt}/{max_attempts})")
        except Exception as e:
            print(f"[SELL_ERR] {market} 매도 실패 (시도 {attempt}/{max_attempts}): {e}")
            if attempt < max_attempts:
                time.sleep(0.5 * attempt)  # 재시도 전 대기 (0.5초, 1초, 1.5초...)

    # 모든 시도 실패
    tg_send(f"⚠️ <b>매도 실패</b> {market}\n수량: {volume:.6f}\n사유: sell failed after {max_attempts} attempts")
    return False


def final_price_guard(m, initial_price, max_drift=None):
    """
    주문 직전 가격 재확인
    - initial_price: 신호 발생 시 기준 가격 (pre['price'])
    - max_drift: 신호가 대비 허용 상승률 (기본: MAX_ENTRY_DRIFT 사용)
    - AGGRESSIVE_MODE=True 인 경우, max_drift~max_drift+1.5% 구간은
      '추격 진입'으로 소액/피라미딩 기반 진입 허용
    """
    if max_drift is None:
        max_drift = MAX_ENTRY_DRIFT  # 통일된 슬리피지 캡 사용
    try:
        js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
        if not js:
            print(f"[GUARD] {m} 티커 조회 실패 → 가드 스킵")
            return True, initial_price

        current_price = js[0].get("trade_price", initial_price)
        drift = (current_price / initial_price - 1.0)

        if drift > max_drift:
            # 평소라면 고점 추격으로 컷
            # 하지만 공격 모드면 일정 구간까지는 허용
            if AGGRESSIVE_MODE and drift <= (max_drift + 0.015):
                print(
                    f"[GUARD][AGGR] {m} 가격 급등 {drift*100:.2f}% "
                    f"→ 공격 모드: 추격 진입 허용 (소액/피라미딩 전제)"
                )
                return True, current_price

            # 이 이상은 진짜 너무 튄 거라 컷
            print(f"[GUARD] {m} 가격 급등 {drift*100:.2f}% → 진입 취소")
            return False, current_price

        return True, current_price

    except Exception as e:
        print(f"[GUARD_ERR] {m}: {e}")
        return True, initial_price


def sniper_gate(m, pre):
    """
    돌파 직후 첫 눌림-재상승에서만 진입 허용 (초입 보장)
    - 늦은 추격 차단
    - 짧은 눌림 후 재상승 포착
    """
    if not SNIPER_MODE:
        return True, pre["price"], "OFF"

    base = pre["price"]
    start = time.time()
    peak = base
    low_after_peak = base

    while time.time() - start <= SNIPER_WAIT_SEC:  # 3초만 대기
        ticks = get_recent_ticks(m, 80)
        if not ticks:
            time.sleep(0.15)
            continue

        p = ticks[0].get("trade_price", base)
        peak = max(peak, p)
        if p < peak:
            low_after_peak = min(low_after_peak, p)

        # 1) 신호가 대비 과도 진행이면 추격 금지
        if (p / base - 1.0) > SNIPER_MAX_ADV_FROM_SIGNAL:
            return False, p, "LATE_ADV"

        # 2) 눌림 범위 체크
        dd = (low_after_peak / max(peak, 1) - 1.0)  # 음수
        if -SNIPER_PULLBACK_MAX <= dd <= -SNIPER_PULLBACK_MIN:
            # 3) 재상승 확인: 2 upticks + 5초 매수비
            t5 = micro_tape_stats_from_ticks(ticks, 5)
            if uptick_streak_from_ticks(ticks, need=SNIPER_MIN_UPTICKS) and t5["buy_ratio"] >= 0.58:
                return True, p, "OK"

        time.sleep(0.12)

    return False, base, "TIMEOUT"


def top_stall_exit_signal(ticks, best_price, entry_price):
    """
    고점 부근 스톨/둔화 감지 → 익절 트리거
    - 최소 +1.2% 수익 구간에서만 작동
    - 5초 테이프 둔화 + 매수비 약화 감지
    """
    if not ticks:
        return False

    nowp = ticks[0]["trade_price"]
    gain = nowp / max(entry_price, 1) - 1.0
    if gain < 0.012:  # 최소 +1.2% 수익 구간에서만 작동
        return False

    t5 = micro_tape_stats_from_ticks(ticks, 5)
    t15 = micro_tape_stats_from_ticks(ticks, 15)
    drop_from_high = nowp / max(best_price, 1) - 1.0  # 음수면 고점대비 하락

    stall = (t5["rate"] < max(0.3, t15["rate"] * 0.55)) and (t5["buy_ratio"] < 0.48)
    no_uptick = not uptick_streak_from_ticks(ticks, need=2)
    hard_fade = (drop_from_high <= -0.007 and t5["buy_ratio"] < 0.52)

    return stall or hard_fade or (no_uptick and t5["buy_ratio"] < 0.50)


