def final_price_guard(m, initial_price, max_drift=None, ticks=None):
    """
    주문 직전 가격 재확인 (동적 임계치)
    - initial_price: 신호 발생 시 기준 가격 (pre['price'])
    - max_drift: 신호가 대비 허용 상승률 (None이면 동적 계산)
    - ticks: 변동성 계산용 틱 데이터
    - AGGRESSIVE_MODE=True 인 경우, max_drift~max_drift+1.2% 구간은
      '추격 진입'으로 소액/피라미딩 기반 진입 허용
    """
    try:
        js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
        if not js:
            print(f"[GUARD] {m} 티커 조회 실패 → 가드 스킵")
            return True, initial_price

        current_price = js[0].get("trade_price", initial_price)
        drift = (current_price / initial_price - 1.0)

        # 🔧 동적 임계치: 변동성 + 장세 반영 (신호→주문 짧은 구간)
        if max_drift is None:
            pstd = price_band_std(ticks or [], sec=10) if ticks else 0.0
            r = relax_knob()  # 0~1.5
            # 🔧 0.5% 기준 (짧은 순간 0.5% 움직임이면 충분)
            base = 0.005 if not AGGRESSIVE_MODE else 0.006
            # 🔧 야간(0~6시) 추격 허용폭 +0.1% 완화
            hour = now_kst().hour
            if 0 <= hour < 6:
                base += 0.001
            dyn = base + min(0.004, pstd * 0.5) + r * 0.002
            thr = dyn
        else:
            thr = max_drift

        if drift > thr:
            # 평소라면 고점 추격으로 컷
            # 하지만 공격 모드면 일정 구간까지는 허용
            # 🔧 0.5% 기준이니 +0.5% 추가 = 총 1% 까지 허용
            if AGGRESSIVE_MODE and drift <= (thr + 0.005):
                print(
                    f"[GUARD][AGGR] {m} 가격 급등 {drift*100:.2f}% <= dyn+1.2% "
                    f"→ 공격 모드: 추격 진입 허용"
                )
                return True, current_price

            # 이 이상은 진짜 너무 튄 거라 컷 (signal_skip에서 로그 처리)
            return False, current_price

        # 🔧 FIX: 하방 급락 컷 (페이크 브레이크 방지)
        down_thr = max(0.005, thr * 0.8)  # 🔧 0.5% 또는 상단의 80%
        if drift < -down_thr:
            # 급락 컷 (signal_skip에서 로그 처리)
            return False, current_price

        return True, current_price

    except Exception as e:
        print(f"[GUARD_ERR] {m}: {e}")
        # 🔧 FIX: 보수적 모드에서는 API 실패 시 진입 취소
        return (True if AGGRESSIVE_MODE else False), initial_price

