def upbit_private_delete(path, params=None, timeout=7):
    """DELETE 요청 (주문 취소용)"""
    url = f"https://api.upbit.com{path}"
    items = list(params.items()) if isinstance(params, dict) else (params or [])
    for attempt in range(3):
        headers = _make_auth_headers(items)
        try:
            _throttle()
            with _session_lock:
                r = SESSION.delete(url, headers=headers, params=items, timeout=timeout)
            if r.status_code in (429, 500, 502, 503, 504):
                time.sleep(0.25 * (2 ** attempt))
                continue
            r.raise_for_status()
            return r.json()
        except requests.HTTPError as e:
            status = getattr(e.response, "status_code", None)
            body_txt = getattr(e.response, "text", "")
            print(f"[UPBIT_DELETE_HTTPERROR] {path} {e} body={body_txt}")
            if status == 401:
                tg_send(f"❌ Upbit 401(DELETE) {path}\n{body_txt[:800]}")
            if attempt == 2:
                return None  # 취소 실패해도 매도는 진행
            time.sleep(0.25 * (2 ** attempt))
        except requests.RequestException as e:
            print(f"[UPBIT_DELETE_REQERR] {path} {e}")
            if attempt == 2:
                return None
            time.sleep(0.25 * (2 ** attempt))

def cancel_open_orders(market: str):
    """해당 마켓의 대기 중인 주문 모두 취소 (매도 전 잔금 잠김 방지)"""
    try:
        orders = upbit_private_get("/v1/orders", {"market": market, "state": "wait"})
        if not orders:
            return 0
        cancelled = 0
        for order in orders:
            uuid = order.get("uuid")
            if uuid:
                result = upbit_private_delete("/v1/order", {"uuid": uuid})
                if result:
                    cancelled += 1
                    print(f"[CANCEL_ORDER] {market} 대기주문 취소: {uuid}")
        return cancelled
    except Exception as e:
        print(f"[CANCEL_ORDER_ERR] {market} {e}")
        return 0

def fmt_volume_for_api(x: float, dp: int = 8) -> str:
    """
    API 전송용 volume 포맷 (지수표기/반올림 방지)
    - 8자리 고정, 내림(ROUND_DOWN)으로 안전
    - 지수표기(1e-07) 완전 방지
    """
    q = Decimal('1').scaleb(-dp)  # 10^-dp
    d = Decimal(str(x)).quantize(q, rounding=ROUND_DOWN)
    s = format(d, 'f')
    # 후행 0 제거 (0.00001000 → 0.00001)
    return s.rstrip('0').rstrip('.') if '.' in s else s

def upbit_private_post(path, body=None, timeout=7):
    url = f"https://api.upbit.com{path}"
    body = body or {}
    # 순서 보존: dict면 items로, list면 그대로
    if isinstance(body, dict):
        items = list(body.items())
    elif isinstance(body, list):
        items = body[:]
    else:
        raise TypeError("body must be dict or list[tuple]")

    for attempt in range(3):
        headers = _make_auth_headers(items)  # ❗ 매시도마다 새 nonce/JWT
        try:
            _throttle()
            with _session_lock:
                # Upbit는 POST에서 query string 기준 query_hash 검증 (body 아님)
                # data=items로 전송 (호환성 강화)
                r = SESSION.post(url, headers=headers, data=items, timeout=timeout)
            if r.status_code in (429, 500, 502, 503, 504):
                time.sleep(0.25 * (2 ** attempt))
                continue
            r.raise_for_status()
            return r.json()

        except requests.HTTPError as e:
            status = getattr(e.response, "status_code", None)
            body_txt = getattr(e.response, "text", "")
            print(f"[UPBIT_POST_HTTPERROR] {path} {e} body={body_txt}")
            if status == 401:
                tg_send(f"❌ Upbit 401(POST) {path}\n{body_txt[:800]}")
            if attempt == 2:
                raise
            time.sleep(0.25 * (2 ** attempt))

        except requests.RequestException as e:
            print(f"[UPBIT_POST_REQERR] {path} {e}")
            if attempt == 2:
                raise
            time.sleep(0.25 * (2 ** attempt))


def get_order_result(uuid_str, timeout_sec=10.0):
    """
    주문 uuid 로 최종 체결 결과 조회 (지연 내성 강화)
    - done / cancel 상태가 되거나 timeout 될 때까지 polling
    - 타임아웃 임박 시 1회 추가 지연 후 재조회
    """
    if not uuid_str:
        return None
    deadline = time.time() + timeout_sec
    last = None
    while time.time() < deadline:
        try:
            od = upbit_private_get("/v1/order", {"uuid": uuid_str})
            last = od
            state = od.get("state")
            if state in ("done", "cancel"):
                break
        except requests.HTTPError as e:
            if getattr(e, "response", None) and e.response.status_code == 404:
                break
        except Exception:
            last = None
        time.sleep(0.3)

    # 상태 반영 지연 대비: 마지막으로 한 번 더
    if last and last.get("state") not in ("done", "cancel"):
        time.sleep(0.8)
        try:
            last = upbit_private_get("/v1/order", {"uuid": uuid_str})
        except Exception:
            pass
    return last

