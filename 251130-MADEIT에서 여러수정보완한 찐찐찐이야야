def fmt6(x):
    """
    숫자를 보기 좋게 표시:
    - 정수는 소수점 없이
    - 소수점이 있는 경우 최대 6자리까지 표시
    """
    if isinstance(x, (int, float)):
        if abs(x - int(x)) < 1e-6:
            return f"{int(x):,}"
        else:
            s = f"{x:,.6f}".rstrip('0').rstrip('.')
            return s
    return str(x)


def fmt_price(x):
    """
    가격을 최대한 정밀하게 표시 (소수점 최대 8자리, trailing zero 제거)
    - 업비트 체결가/호가 등 모든 가격에 사용
    - 의미있는 소수점까지만 표시
    """
    if isinstance(x, (int, float)):
        s = f"{x:,.8f}".rstrip('0')
        if s.endswith('.'):
            s += '0'  # 최소 소수점 1자리는 표시
        return s
    return str(x)

