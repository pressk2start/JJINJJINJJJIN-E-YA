def close_auto_position(m, reason=""):
    """
    손절/청산 시 자동 매도
    - 실제 체결된 경우에만 포지션 제거
    - 부분체결이면 잔량 유지(volume 업데이트)
    """
    if not AUTO_TRADE:
        print(f"[AUTO] AUTO_TRADE=0 → 청산 스킵 ({m}, reason={reason})")
        return

    now = time.time()

    # ★★★ 크리티컬: 중복 청산 방지 + 쿨다운 스탬프 선반영 (원자적) ★★★
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if not pos:
            print(f"[AUTO] OPEN_POSITIONS에 {m} 포지션 없음 → 청산 스킵 (reason={reason})")
            tg_send_mid(f"⚠️ {m} 청산 시도했는데 OPEN_POSITIONS에 포지션 없음")
            return
        # ✅ 이미 청산중이면 즉시 스킵 (동시 스레드 차단)
        if pos.get("closing"):
            print(f"[AUTO] {m} 이미 closing 중 → 스킵")
            return
        # ✅ 쿨다운 체크 (원자적으로 같은 락 안에서)
        last_attempt = LAST_EXIT_ATTEMPT.get(m, 0)
        if now - last_attempt < 10:  # 10초 쿨다운
            print(f"[AUTO] {m} 청산 재시도 쿨다운 중 (마지막 시도 {now-last_attempt:.1f}초 전)")
            return
        # ✅ 청산 플래그 + 쿨다운 스탬프 즉시 세팅 (다른 스레드 차단)
        pos["closing"] = True
        OPEN_POSITIONS[m] = pos
        LAST_EXIT_ATTEMPT[m] = now

    # ★ 찌꺼기 방지: 실제 계좌 보유량 + 평균매수가 재조회 (업비트 API 기준)
    actual_vol = 0.0
    real_avg_buy_price = 0.0  # ★ 업비트 실제 평단
    try:
        accounts = get_account_info()
        if accounts:
            currency = m.split("-")[1] if "-" in m else ""
            for acc in accounts:
                if acc.get("currency") == currency:
                    actual_vol = float(acc.get("balance", "0"))
                    real_avg_buy_price = float(acc.get("avg_buy_price", "0"))  # ★ 실제 평단
                    break
    except Exception as e:
        print(f"[AUTO] {m} 계좌 조회 실패: {e}")

    # ★ 과청산 방지: 실제 보유량 vs 포지션 기록 중 작은 값 사용 (금융사고 방지)
    pos_vol = pos.get("volume", 0.0)
    vol = min(actual_vol, pos_vol) if actual_vol > 0 else pos_vol
    vol = float(Decimal(fmt_volume_for_api(vol)))  # 정밀도 내림 + 지수표기 방지

    print(f"[AUTO] {m} 청산 수량: pos={pos_vol:.8f}, actual={actual_vol:.8f}, use={vol:.8f}")

    if vol <= 0:
        print(f"[AUTO] {m} volume<=0 ({vol}) → 포지션 제거만 수행")
        with _POSITION_LOCK:
            OPEN_POSITIONS.pop(m, None)
        return

    # ★ 평단: 업비트 실제 평단 우선, 없으면 포지션 기록 사용
    pos_entry_price = float(pos.get("entry_price", 0.0)) or 0.0
    entry_price = real_avg_buy_price if real_avg_buy_price > 0 else pos_entry_price
    if real_avg_buy_price > 0 and abs(real_avg_buy_price - pos_entry_price) / max(pos_entry_price, 1) > 0.001:
        print(f"[AUTO] {m} 평단 보정: 기록={pos_entry_price:.2f} → 실제={real_avg_buy_price:.2f}")

    # 현재가(청산 전 기준) 조회 - 공용 엔드포인트 사용 (서명 오버헤드 제거)
    try:
        cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
        cur_price = float(cur_js[0].get("trade_price", entry_price)) if cur_js else entry_price
    except Exception:
        cur_price = entry_price

    # 선 계산(대략)
    ret_pct = ((cur_price / entry_price - 1.0) * 100.0) if entry_price > 0 else 0.0
    est_entry_value = entry_price * vol
    est_exit_value = cur_price * vol
    pl_value = est_exit_value - est_entry_value

    print(f"[AUTO] {m} 청산 시도: volume={vol}, reason={reason}, PnL(선계산)={ret_pct:+.2f}%")

    # ★ 최소 주문금액 체크 (5,000원 미만 시 거절 방지)
    estimated_order_krw = cur_price * vol
    if estimated_order_krw < 5000:
        # ★★★ 실제 API 잔량 확인 후 유령 포지션 정리 ★★★
        coin = m.replace("KRW-", "")
        actual_vol = 0.0
        try:
            balances = upbit_private_get("/v1/accounts") or []
            for b in balances:
                if b.get("currency") == coin:
                    actual_vol = float(b.get("balance", 0))
                    break
        except Exception as e:
            print(f"[CLOSE] {m} 잔량 조회 실패: {e}")

        actual_krw = actual_vol * cur_price
        if actual_krw < 500:
            # 실제 잔량이 500원 미만 → 유령 포지션 정리
            print(f"[CLOSE_DUST] {m} 실제잔량 {actual_krw:.0f}원 < 500원 → 유령포지션 정리")
            with _POSITION_LOCK:
                OPEN_POSITIONS.pop(m, None)
                LAST_EXIT_AT[m] = time.time()
            tg_send_mid(f"🧹 {m} 유령포지션 정리 (잔량 {actual_krw:.0f}원)")
            return
        else:
            # 진짜 잔량은 있지만 5000원 미만 → 스킵
            print(f"[AUTO] {m} 청산 예상금액 {estimated_order_krw:,.0f}원 < 5,000원 → 주문 스킵")
            tg_send_mid(f"⚠️ {m} 청산 불가: 예상금액 {estimated_order_krw:,.0f}원 < 5,000원 (최소주문금액)")
            # closing 플래그 해제
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m)
                if pos:
                    pos["closing"] = False
            return

    exit_price_used = cur_price  # 실제 체결가 성공 시 교체
    executed_vol = 0.0           # 실제 체결 수량
    sell_ok = False

    # ★★★ 매도 전 대기주문 취소 (잔금 잠김 400에러 방지) ★★★
    cancelled = cancel_open_orders(m)
    if cancelled > 0:
        print(f"[CLOSE] {m} 대기주문 {cancelled}건 취소 완료")

    try:
        res = place_market_sell(m, vol)
        order_uuid = res.get("uuid") if isinstance(res, dict) else None
        od = get_order_result(order_uuid, timeout_sec=6.0) if order_uuid else None

        # 실제 체결가/체결수량 계산
        if od:
            trades = od.get("trades") or []
            total_krw = 0.0
            total_vol = 0.0
            for tr in trades:
                try:
                    p = float(tr.get("price", "0") or 0)
                    v = float(tr.get("volume", "0") or 0)
                except Exception:
                    continue
                total_krw += p * v
                total_vol += v
            if total_vol > 0:
                exit_price_used = total_krw / total_vol
                executed_vol = total_vol
            else:
                # 백업: 상위 필드에 executed_volume 제공될 수 있음
                try:
                    executed_vol = float(od.get("executed_volume") or 0.0)
                except Exception:
                    executed_vol = 0.0

        sell_ok = executed_vol > 0.0

        # 실제 체결 기준으로 재계산(부분체결 포함)
        if sell_ok:
            est_exit_value = exit_price_used * executed_vol
            est_entry_value = entry_price * executed_vol
            pl_value = est_exit_value - est_entry_value
            ret_pct = ((exit_price_used / entry_price - 1.0) * 100.0) if entry_price > 0 else 0.0
            ret_pct_after_fee = ret_pct - (FEE_RATE * 100.0)  # ★ 왕복 수수료 반영 (일관성)

            # ❌ 여기서 record_trade() 호출은 제거 (완전종료에서만 기록)


        if sell_ok:
            # 🔥 순손익 계산 (수수료 반영) - ★ FEE_SIDE 사용 (버그 수정: 이중차감 방지)
            total_fees = (est_entry_value + est_exit_value) * FEE_SIDE  # 매수0.05% + 매도0.05%
            net_profit = pl_value - total_fees

            # 🔥 더 눈에 띄는 자동청산 알람 (순손익 강조)
            profit_emoji = "🟢" if net_profit >= 0 else "🔴"
            alarm_ok = tg_send(
                f"{'='*30}\n"
                f"{profit_emoji} <b>자동청산 완료</b> {m}\n"
                f"{'='*30}\n"
                f"💰 <b>순손익: {net_profit:+,.0f}원 ({ret_pct_after_fee:+.2f}%)</b>\n"
                f"\n"
                f"• 사유: {reason}\n"
                f"• 매수평단: {fmt_price(entry_price)}원\n"
                f"• 실매도가: {fmt_price(exit_price_used)}원\n"
                f"• 체결수량: {executed_vol:.6f}\n"
                f"• 매수금액: {est_entry_value:,.0f}원\n"
                f"• 청산금액: {est_exit_value:,.0f}원\n"
                f"• 수수료: {total_fees:,.0f}원\n"
                f"{link_for(m)}"
            )
            # 🔔 알람 전송 상태 로깅 (디버깅용)
            if alarm_ok:
                print(f"[AUTO_ALARM_OK] {m} 자동청산 완료 알람 전송 성공 (사유: {reason})")
            else:
                print(f"[AUTO_ALARM_FAIL] ⚠️ {m} 자동청산 완료 알람 전송 실패 (사유: {reason}) - Telegram API 오류 가능성")
        else:
            tg_send_mid(
                f"⚠️ <b>자동청산 주문 미체결/실패</b> {m}\n"
                f"• 요청 수량: {vol:.6f}\n"
                f"• 체결 수량: 0\n"
                f"→ 최소 주문금액 부족 / 유동성 부족 / 주문 거절 가능성 점검"
            )

    except Exception as e:
        print("[AUTO SELL ERR]", e)
        tg_send(f"⚠️ <b>자동청산 실패</b> {m}\n사유: {e}")

        # ★★★ 크리티컬: 400 에러 시 실제 잔량 확인 후 포지션 정리 ★★★
        # "잔량 없는데 매도 시도" → 400 Bad Request → 무한 반복 방지
        try:
            accounts_err = get_account_info()
            if accounts_err:
                currency = m.split("-")[1] if "-" in m else ""
                actual_vol_err = 0.0
                for acc in accounts_err:
                    if acc.get("currency") == currency:
                        actual_vol_err = float(acc.get("balance", "0"))
                        break

                # 실제 잔량이 최소주문금액(5000원) 미만이면 포지션 완전 정리
                cur_price_err = cur_price if cur_price > 0 else 1.0
                dust_krw_err = actual_vol_err * cur_price_err

                if dust_krw_err < 5000:
                    print(f"[AUTO_ERR_CLEANUP] {m} 실제 잔량 {actual_vol_err:.8f} ({dust_krw_err:.0f}원) < 5000원 → 포지션 강제 정리")
                    with _POSITION_LOCK:
                        OPEN_POSITIONS.pop(m, None)
                        LAST_EXIT_AT[m] = time.time()
                    tg_send_mid(f"🧹 {m} 잔량 부족으로 포지션 강제 정리 (실잔량: {dust_krw_err:.0f}원)")
                    return  # 더 이상 재시도 안 함
        except Exception as e2:
            print(f"[AUTO_ERR_CLEANUP_FAIL] {m}: {e2}")

        # 🔒 실패 시 closing 해제 (재시도 가능하게)
        with _POSITION_LOCK:
            pos = OPEN_POSITIONS.get(m)
            if pos:
                pos["closing"] = False

    finally:
        # 🔒 포지션 업데이트 및 통계 기록은 '완전 종료'에서만
        if sell_ok:
            # ★ 찌꺼기 방지: 청산 후 실제 잔량 재조회
            actual_remaining_final = 0.0
            try:
                accounts = get_account_info()
                if accounts:
                    currency = m.split("-")[1] if "-" in m else ""
                    for acc in accounts:
                        if acc.get("currency") == currency:
                            actual_remaining_final = float(acc.get("balance", "0"))
                            break
            except Exception as e:
                print(f"[AUTO] {m} 청산 후 잔량 재조회 실패: {e}")

            calc_remaining = max(vol - executed_vol, 0.0)
            remaining = actual_remaining_final if actual_remaining_final > 0 else calc_remaining
            print(f"[AUTO] {m} 청산 후 잔량: calc={calc_remaining:.8f}, actual={actual_remaining_final:.8f}, use={remaining:.8f}")

            # ★ 찌꺼기 무시: 최소 주문금액(5000원) 미만은 완전 청산으로 간주
            if remaining > 0:
                try:
                    cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
                    cur_price = float(cur_js[0].get("trade_price", 0)) if cur_js else 0
                    dust_krw = remaining * cur_price
                    if dust_krw < 5000:
                        print(f"[AUTO] {m} 찌꺼기 무시: {remaining:.8f} ({dust_krw:.0f}원 < 5000원)")
                        remaining = 0.0  # 완전 청산으로 간주
                except Exception:
                    pass

            if remaining <= 1e-12:
                # ✅ 완전 종료: 통계/쿨다운 기록 + 트레이드 기록
                ret_pct_after_fee = ret_pct - (FEE_RATE * 100.0)

                # 📊 MFE/MAE 추출
                with _POSITION_LOCK:
                    pos_final = OPEN_POSITIONS.get(m, {})
                    mfe_final = pos_final.get("mfe_pct", 0.0)
                    mae_final = pos_final.get("mae_pct", 0.0)

                try:
                    record_trade(m, ret_pct_after_fee, mfe_final, mae_final)
                except Exception as _e:
                    print("[TRADE_RECORD_ERR]", _e)

                profit_keywords = ["PROFIT", "TRAIL", "DROP_FROM_HIGH", "LOCK", "익절", "수익"]
                is_profit = any(kw in (reason or "").upper() for kw in profit_keywords)

                with _POSITION_LOCK:
                    LAST_EXIT_AT[m] = time.time()
                    LAST_EXIT_CAUSE[m] = "profit" if is_profit else "loss"
                    OPEN_POSITIONS.pop(m, None)
                    # ★ 완전청산 성공 시 쿨다운 초기화
                    LAST_EXIT_ATTEMPT.pop(m, None)
            else:
                # ✅ 부분청산: 잔량 유지, closing 해제, 쿨다운 초기화
                with _POSITION_LOCK:
                    pos = OPEN_POSITIONS.get(m, {})
                    if pos:
                        pos["volume"] = remaining
                        pos["closing"] = False
                        OPEN_POSITIONS[m] = pos
                    # ★ 부분청산 성공 시 쿨다운 초기화 (이전 실패 기록 제거)
                    LAST_EXIT_ATTEMPT.pop(m, None)
                partial_krw = exit_price_used * executed_vol
                tg_send(
                    f"ℹ️ <b>부분 청산</b> {m}\n"
                    f"• 사유: {reason}\n"
                    f"• 체결가: {fmt_price(exit_price_used)}원\n"
                    f"• 잔여 수량: {remaining:.6f}\n"
                    f"\n"
                    f"• 체결 수량: {executed_vol:.6f}\n"
                    f"• 체결 금액: {partial_krw:,.0f}원\n"
                )
        else:
            # ✅ 실패/미체결: 시도만 기록 + closing 해제
            with _POSITION_LOCK:
                LAST_EXIT_ATTEMPT[m] = time.time()
                pos = OPEN_POSITIONS.get(m)
                if pos:
                    pos["closing"] = False

        # ★ 최종 안전망: 모든 경로에서 closing 플래그 확실히 해제 (완전종료 제외)
        with _POSITION_LOCK:
            if m in OPEN_POSITIONS:  # 포지션이 아직 남아있으면
                pos = OPEN_POSITIONS.get(m)
                if pos and pos.get("closing") is not False:
                    pos["closing"] = False
                    print(f"[CLOSING_GUARD] {m} closing 플래그 강제 해제 (안전망)")

def safe_partial_sell(m, sell_ratio=0.5, reason=""):
    """
    부분 청산 공용 함수
    - sell_ratio: 0.5 → 50%, 0.3 → 30% 등
    - partial_count로 최대 2회까지 부분청산/부분익절 허용 (TP1/TP2)
    반환: (성공여부:bool, 메시지:str, 체결량:float)
    """
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if not pos or pos.get("volume", 0) <= 0:
            msg = f"[REMONITOR] {m} 부분청산 실패: 포지션 없음/수량 0"
            print(msg)
            return False, msg, 0.0
        # 🔁 TP는 한도 미적용 (TP1/TP2 보장)
        is_tp = str(reason).upper().startswith("TP")
        partial_count = int(pos.get("partial_count", 0))
        if (not is_tp) and partial_count >= 2:
            msg = f"[REMONITOR] {m} 부분청산 한도(2회) 초과 → 스킵 (TP는 제외)"
            print(msg)
            return False, msg, 0.0
        current_volume = pos["volume"]

    sell_volume = current_volume * sell_ratio

    # ★ 부분청산 가드: 실제 잔량 + 평균매수가 재조회 (업비트 API 기준)
    actual_available = 0.0
    real_avg_buy_price = 0.0  # ★ 업비트 실제 평단
    try:
        accounts = get_account_info()
        if accounts:
            currency = m.split("-")[1] if "-" in m else ""
            for acc in accounts:
                if acc.get("currency") == currency:
                    actual_available = float(acc.get("balance", "0"))
                    real_avg_buy_price = float(acc.get("avg_buy_price", "0"))  # ★ 실제 평단
                    break
    except Exception as e:
        print(f"[PARTIAL_SELL] {m} 실제 잔량 조회 실패: {e}")
        actual_available = current_volume  # fallback

    # 과매도 방지: 실제 보유량 vs 계산값 중 작은 값 사용
    sell_volume = min(sell_volume, actual_available)
    # 정밀도 내림 + 지수표기 방지
    sell_volume = float(Decimal(fmt_volume_for_api(sell_volume)))
