def open_auto_position(m, pre, dyn_stop, eff_sl_pct):
    """
    초입·공격모드 대응 자동 매수 진입
    """
    if not AUTO_TRADE:
        return

    if not UPBIT_ACCESS_KEY or not UPBIT_SECRET_KEY:
        print("[AUTO] API 키 미설정 → 자동매수 스킵")
        return

    # 🔧 FIX: 중복 진입 방지 (pending 상태로 원자화)
    with _POSITION_LOCK:
        if m in OPEN_POSITIONS:
            print(f"[AUTO] 이미 {m} 포지션 보유중 → 신규 진입 스킵")
            return
        # 🔧 FIX: 총 노출 한도 체크
        active_count = sum(1 for p in OPEN_POSITIONS.values() if p.get("state") == "open")
        if active_count >= MAX_POSITIONS:
            print(f"[AUTO] 최대 포지션 수 {MAX_POSITIONS}개 도달 → 신규 진입 스킵")
            tg_send_mid(f"⚠️ {m} 신규 진입 대기 (최대 {MAX_POSITIONS}개 포지션 보유 중)")
            return
        # ✅ 예약 플래그로 다른 스레드 진입 차단
        OPEN_POSITIONS[m] = {"state": "pending"}

    signal_price = pre.get("price")
    if not signal_price:
        print(f"[AUTO] {m} pre['price'] 없음 → 진입 스킵")
        with _POSITION_LOCK:
            OPEN_POSITIONS.pop(m, None)  # pending 취소
        return

    # === 하이브리드 진입모드 반영 ===
    entry_mode = pre.get("entry_mode", "confirm")

    if entry_mode == "probe":
        entry_fraction = 0.10   # 🔧 10%로 축소 (소액 탐색)
        mode_emoji = "🧭"
    elif entry_mode == "half":
        entry_fraction = 0.50   # 🔧 50% 사이즈 (중간 회전율)
        mode_emoji = "⚡"
    elif entry_mode == "confirm":
        entry_fraction = 1.0    # 전체 금액 (확정 진입)
        mode_emoji = "🔥"
    else:
        entry_fraction = 1.0
        mode_emoji = "🤖"

    # ★ 공격모드일 경우 가격 가드 완화
    max_drift = 0.012 if not AGGRESSIVE_MODE else 0.025

    ok_guard, current_price = final_price_guard(m, signal_price, max_drift=max_drift)
    if not ok_guard:
        tg_send(
            f"⚠️ <b>진입 취소</b> {m}\n"
            f"• 신호가: {fmt6(signal_price)}원\n"
            f"• 현재가: {fmt6(current_price)}원\n"
            f"• 상승률: {((current_price / signal_price - 1) * 100):.2f}%\n"
            f"• 사유: 가격 급등 (초입 추격 위험)"
        )
