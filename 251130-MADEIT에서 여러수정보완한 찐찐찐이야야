def format_sell_alert(market, reason, volume, entry_price, sell_price, extra_info=""):
    """
    매도 알람을 매수 청산처럼 상세하게 포맷
    - market: 종목 코드
    - reason: 매도 사유
    - volume: 매도 수량
    - entry_price: 진입가 (평단)
    - sell_price: 매도가 (현재가)
    - extra_info: 추가 정보 (선택)
    """
    buy_amount = entry_price * volume
    sell_amount = sell_price * volume
    profit = sell_amount - buy_amount
    profit_rate = (sell_price / entry_price - 1.0) * 100

    # 부호 통일 (손익/수익률 모두 +/- 명시)
    profit_sign = "+" if profit >= 0 else "-"
    rate_sign = "+" if profit_rate >= 0 else "-"
    emoji = "💰" if profit >= 0 else "🩸"

    msg = f"{emoji} <b>자동청산 {market}</b>\n"
    msg += f"• 사유: {reason}\n"
    msg += f"• 수량: {volume:.6f}\n"
    msg += f"• 매수평단: {fmt6(entry_price)}원\n"
    msg += f"• 실매도가: {fmt6(sell_price)}원\n"
    msg += f"• 매수금액: {fmt6(buy_amount)}원\n"
    msg += f"• 청산금액: {fmt6(sell_amount)}원\n"
    msg += f"• 실현손익: {profit_sign}{fmt6(abs(profit))}원\n"
    msg += f"• 수익률: {rate_sign}{abs(profit_rate):.2f}%\n"
    if extra_info:
        msg += f"• 상세: {extra_info}\n"
    msg += f"https://upbit.com/exchange?code=CRIX.UPBIT.{market}"
    return msg

def tg_send(t, retry=1):
    # 디버깅: tg_send 호출 확인
    print(f"[TG_SEND_CALLED] {t}")

    # TG_TOKEN 없거나 CHAT_IDS가 비어 있으면 콘솔에만 출력
    if not TG_TOKEN or not CHAT_IDS:
        print(f"[TG_WARN] 텔레그램 미설정 (TOKEN={bool(TG_TOKEN)}, CHAT_IDS={CHAT_IDS})")
        print(t)
        return True

    ok_any = False
    for cid in CHAT_IDS:
        payload = {
            "chat_id": cid,
            "text": _esc_html(t),  # HTML 특수문자 이스케이프
            "parse_mode": "HTML",
            "disable_web_page_preview": True,
        }
        for _ in range(retry + 1):
            try:
                r = SESSION_TG.post(  # 텔레그램 전용 세션 사용
                    f"https://api.telegram.org/bot{TG_TOKEN}/sendMessage",
                    json=payload,
                    timeout=4,
                )
                if r.status_code == 200:
                    js = r.json()
                    if js.get("ok") is True:
                        ok_any = True
                        break
                elif r.status_code == 429:
                    # Rate limit: 더 긴 대기 시간
                    print(f"[TG][{cid}] 429 Too Many Requests - 긴 대기")
                    time.sleep(1.5 + rnd())
                    continue
                elif 500 <= r.status_code < 600:
                    # 서버 에러: 짧은 재시도
                    print(f"[TG][{cid}] {r.status_code} Server Error - 재시도")
                    time.sleep(0.5 + rnd() * 0.5)
                    continue
                else:
                    # 기타 에러 (4xx 등)
                    print(f"[TG][{cid}] status={r.status_code} body={r.text}")
            except Exception as e:
                print(f"[TG][{cid}] exception: {e}")
            time.sleep(0.25 + rnd() * 0.25)
    return ok_any


