def _get_coin_balance(symbol: str) -> float:
    """특정 코인의 실제 잔고 조회 (balance + locked)"""
    try:
        ac = get_account_info()
        currency = symbol.split("-")[1]
        for a in ac:
            if a.get("currency") == currency:
                balance = float(a.get("balance", "0") or "0")
                locked = float(a.get("locked", "0") or "0")
                return balance + locked
    except Exception as e:
        print(f"[BALANCE] {symbol} 잔고 조회 실패: {e}")
        pass
    return 0.0


def calc_position_size(entry_price, stop_price, total_equity, risk_pct):
    """
    손절가 기준으로 포지션 크기 계산
    - total_equity * risk_pct 만큼만 최대 손실 허용
    - MIN_LOSS_FLOOR: 최소 손실폭 (체결 스프레드 + 수수료 + 여유, 기본 0.35%)
    """
    # 입력 검증 (None/0 방어)
    if not entry_price or not stop_price or entry_price <= 0 or total_equity <= 0:
        return 0.0

    risk_krw = total_equity * risk_pct
    per_unit_loss = max(entry_price - stop_price,
                        entry_price * MIN_LOSS_FLOOR)  # 환경변수로 조정 가능
    qty = risk_krw / per_unit_loss
    return max(qty, 0)


def compute_net_be_price(entry_price, total_vol, sold_vol, sold_avg,
                         fee_side=None, buffer=None):
    """
    부분익절 후 남은 잔량이 이 가격에 팔리면 '전체 손익'이 0이 되는 가격 (Net BE)

    - entry_price: 매수 평단
    - total_vol: 전체 수량
    - sold_vol: 이미 판 수량
    - sold_avg: 부분익절 평균 체결가
    - fee_side: 편도 수수료 (기본: FEE_RATE/2)
    - buffer: 안전 여유폭 (기본: NET_BE_BUFFER)

    수식: realized_cash + s * remain * (1-fee) >= buy_cash
         → s = (buy_cash - realized_cash) / (remain * (1-fee))
    """
    if fee_side is None:
        fee_side = FEE_RATE / 2
    if buffer is None:
        buffer = NET_BE_BUFFER

    remain = max(total_vol - sold_vol, 1e-12)
    buy_cash      = entry_price * total_vol * (1 + fee_side)  # 매수 시 지출 (수수료 포함)
    realized_cash = sold_avg * sold_vol * (1 - fee_side)      # 이미 회수한 현금 (수수료 차감)

    net_be = (buy_cash - realized_cash) / (remain * (1 - fee_side))
    return net_be * (1 + buffer)  # 여유폭 추가


