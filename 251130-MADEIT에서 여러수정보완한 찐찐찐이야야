def fmt6(x):
    """
    숫자를 보기 좋게 표시:
    - 정수는 소수점 없이
    - 소수점이 있는 경우 최대 6자리까지 표시
    """
    if isinstance(x, (int, float)):
        if abs(x - int(x)) < 1e-6:
            return f"{int(x):,}"
        else:
            s = f"{x:,.6f}".rstrip('0').rstrip('.')
            return s
    return str(x)

