# === PATCH: grind detector ===
def grind_break_ok(c1, ticks):
    """계단식(그라인드) 상승 예외:
       - 최근 8봉 중 6봉 이상이 EMA5 위 (7→6 완화)
       - 매수비(15s) >= 0.56
       - 체결간 간격 변동계수(CV, 30s) <= 1.05 (0.95→1.05 완화)
    """
    if len(c1) < 10 or not ticks:
        return False
    closes = [x["trade_price"] for x in c1]
    e5 = ema_series(closes, 5)
    last8 = list(zip(c1[-8:], e5[-8:]))
    above = sum(1 for c, e in last8 if c["trade_price"] >= e)
    ema_slope = (e5[-1] - e5[-4]) if len(e5) >= 4 else 0
    # ★ v2: 금액가중 buy ratio 사용
    t15 = micro_tape_stats_from_ticks_v2(ticks, 15, use_now_anchor=True, winsor_p=0.95)
    ia = inter_arrival_stats(ticks, 30)
    return (above >= 6 and ema_slope > 0 and t15.get("buy_value_ratio", 0) >= 0.56
            and ia.get("cv", 9.9) <= 1.05)


