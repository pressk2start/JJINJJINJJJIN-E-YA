# =========================
def monitor_position(m,
                     entry_price,
                     pre,
                     tight_mode=False,
                     horizon=None,
                     reentry=False):
    c1 = get_minutes_candles(1, m, 20)
    base_stop, eff_sl_pct, atr_info = dynamic_stop_loss(entry_price, c1)

    # horizon이 안 들어오면 자동 결정, 들어오면 그 값 사용
    if horizon is None:
        horizon = decide_monitor_secs(pre, tight_mode=tight_mode)
    start_ts = time.time()
    MAX_RUNTIME = horizon * 1.5  # 최대 허용 실행시간 (정상시간의 1.5배)


    # 디바운스/트레일 상태
    # 손절 디바운스용
    stop_first_seen_ts = 0.0
    stop_hits = 0
    # 컨텍스트 청산 디바운스용
    ctx_first_seen_ts = 0.0
    ctx_hits = 0

    trail_armed = False
    trail_stop = 0.0

    # 스파이크/그레이스 기존 로직 재활용
    consecutive_failures = 0
    MAX_CONSECUTIVE_FAILURES = 10
    grace_used = False
    spike_recovery_used = False

    ob = pre.get("ob")
    ob_depth_default = ob.get("depth_krw", 10_000_000) if ob else 10_000_000

    last_price = entry_price
    best = entry_price
    worst = entry_price

    # 실제 보유 수량 확보 (익절 시 매도용)
    with _POSITION_LOCK:
        entry_volume = OPEN_POSITIONS.get(m, {}).get("volume", 0.0)

    verdict = None
    outcome_extra = ""

    # === 🎯 얇은 수익 체크포인트 상태 ===
    checkpoint_reached = False   # 얇은 수익(0.3%) 도달 여부
    strong_mode = False          # 강세 확인 후 트레일링 모드
    strong_peak = entry_price    # 강세 모드 진입 후 고점 추적

    # === 포지션 모드 (probe / confirm) ===
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m, {})
    entry_mode = pos.get("entry_mode", "confirm")

    try:
        while time.time() - start_ts <= horizon:
            time.sleep(RECHECK_SEC)

            ticks = get_recent_ticks(m, 100)
            if not ticks or len(ticks) < 3:
                consecutive_failures += 1
                if consecutive_failures >= MAX_CONSECUTIVE_FAILURES:
                    time.sleep(3)
                    ticks = get_recent_ticks(m, 100)
                    if not ticks:
                        verdict = "데이터 수신 실패"
                        break
                    consecutive_failures = 0
                continue
            consecutive_failures = 0

            # 현재가
            cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
            if not cur_js or len(cur_js) == 0:
                continue
            curp = cur_js[0].get("trade_price", last_price)
            last_price = curp
            # ✅ 트레일링 래칫 버그 수정: 신고점 판정 먼저
            new_high = curp > best
            best = max(best, curp)
            worst = min(worst, curp)

            # === 1) ATR 기반 동적 손절 (웜업 제거, 체결 직후부터 적용) ===
            alive_sec = time.time() - start_ts
            dd_now = (curp / best - 1.0)
            cur_gain = (curp / entry_price - 1.0)

            # 🔧 웜업 제거: 체결 직후부터 ATR 손절 적용
            if cur_gain <= -eff_sl_pct:
                atr_detail = f", {atr_info}" if atr_info else ""
                close_auto_position(m, f"ATR손절 -{abs(cur_gain)*100:.2f}% (기준 -{eff_sl_pct*100:.2f}%{atr_detail})")
                verdict = "ATR손절"
                outcome_extra = f"({cur_gain*100:.2f}%, SL-{eff_sl_pct*100:.2f}%)"
                break

            # === 2) 트레일링 손절: 이익이 나야만 무장
            gain_from_entry = (curp / entry_price - 1.0)
            
            # === PROBE → CONFIRM 전환 로직 ===
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m, {})

            if pos.get("entry_mode") == "probe":
                # 전환 조건: 일정 수익 이상 + 거래속도 정상 + 매수세 유지
                t15_now = micro_tape_stats_from_ticks(ticks, 15)
                # 🔧 FIX: Decimal 제거 (float와 비교 시 TypeError 발생)
                gain_now = (curp / entry_price - 1.0)

                strong_flow = (
                    t15_now["buy_ratio"] >= 0.58
                    and t15_now["krw_per_sec"] >= 18000
                    and uptick_streak_from_ticks(ticks, need=2)
                )

                if gain_now >= 0.012 and strong_flow:
                    add_reason = f"상승확정 (수익+{gain_now*100:.1f}% 매수비{t15_now['buy_ratio']:.0%} 초당{t15_now['krw_per_sec']/1000:.0f}K)"
                    ok_add, new_entry = add_auto_position(m, curp, add_reason)
                    if ok_add and new_entry:
                        # 진입모드 승격
                        with _POSITION_LOCK:
                            pos["entry_mode"] = "confirm"
                            pos["entry_price"] = new_entry
                            pos["added"] = True
                            pos["last_add_ts"] = time.time()
                            OPEN_POSITIONS[m] = pos

                        tg_send_mid(
                            f"🔥 {m} 상승 확정 → probe ➜ confirm 전환\n"
                            f"추매 후 평단: {fmt6(new_entry)}원"
                        )

                        # 동적 손절 재계산
                        c1_for_sl = get_minutes_candles(1, m, 20)
                        base_stop, eff_sl_pct, atr_info = dynamic_stop_loss(new_entry, c1_for_sl)
                        trail_armed = False  # 새 기준으로 트레일링 리셋

            if (not trail_armed) and gain_from_entry >= TRAIL_ARM_GAIN:
                trail_armed = True
                # 초기 트레일: ATR 기준 혹은 최소거리
                atr = atr14_from_candles(get_minutes_candles(1, m, 20), 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = curp * (1.0 - trail_dist)

            # === 2-1) 피라미딩(추매): 완화형 로직 (부분청산 후 재상승 대응) ===
            if USE_PYRAMIDING and AUTO_TRADE:
                t15_now = micro_tape_stats_from_ticks(ticks, 15)

                # 💡 조건 완화 — 약상승에서도 반응하도록
                add_cond_price = gain_from_entry >= max(0.005, PYRAMID_ADD_MIN_GAIN * 0.8)
                add_cond_flow = (
                    t15_now["buy_ratio"] >= 0.55 and
                    t15_now["krw_per_sec"] >= PYRAMID_ADD_FLOW_MIN_KRWPSEC * 0.8 and
                    last_two_ticks_fresh(ticks)
                )

                # 📊 단기 EMA 기준으로 단기 상승 전환 감지 (1분봉)
                c1m = get_minutes_candles(1, m, 20)
                ema3 = ema_last([c["trade_price"] for c in c1m], 3)
                ema8 = ema_last([c["trade_price"] for c in c1m], 8)
                short_term_up = ema3 > ema8

                if add_cond_price and add_cond_flow and short_term_up:
                    with _POSITION_LOCK:
                        pos = OPEN_POSITIONS.get(m)
                        already_added = pos.get("added") if pos else True
                        last_add_ts = pos.get("last_add_ts", 0.0) if pos else 0.0

                    # 쿨다운을 40% 단축해 재진입성 향상
                    cooldown_ok = (time.time() - last_add_ts) >= (PYRAMID_ADD_COOLDOWN_SEC * 0.6)

                    if pos and (not already_added) and cooldown_ok:
                        add_reason = f"재상승EMA (수익+{gain_from_entry*100:.1f}% 매수비{t15_now['buy_ratio']:.0%} EMA3>EMA8)"
                        ok_add, new_entry = add_auto_position(m, curp, add_reason)
                        if ok_add and new_entry:
                            entry_price = new_entry
                            c1_for_sl = get_minutes_candles(1, m, 20)
                            base_stop, eff_sl_pct, atr_info = dynamic_stop_loss(entry_price, c1_for_sl)

            # 🔧 FIX: 트레일 업데이트 - new_high 사용 (curp > best는 best 갱신 후라 항상 False)
            if trail_armed and new_high:
                atr = atr14_from_candles(get_minutes_candles(1, m, 20), 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = max(trail_stop, curp * (1.0 - trail_dist))

            # 💎 브레이크이븐 스텝: +0.4% 도달 시 손절가 정보 갱신 (참고용)
            # 🔧 NOTE: effective_stop은 현재 청산 트리거에 미사용
            # 실제 청산은 ATR손절/체크포인트/트레일링에서 처리
            BREAKEVEN_TRIGGER = 0.004  # +0.4%
            in_breakeven_box = abs(gain_from_entry) <= BREAKEVEN_BOX  # ±0.15% 박스 내

            if gain_from_entry >= BREAKEVEN_TRIGGER:
                breakeven_price = entry_price * (1 + FEE_RATE)
                base_stop = max(base_stop, breakeven_price)

            # 유효 스탑 = max(기본 동적 SL, 트레일링)
            effective_stop = max(base_stop, trail_stop if trail_armed else 0.0)

            # === 🔥 심플 체크포인트 매도 로직 ===
            cur_gain = (curp / entry_price - 1.0)
            ob_now = pre.get("ob", {})

            # === 🎯 ATR 기반 동적 손절 (틱스탑 제거됨) ===
            # 이미 line 4876에서 웜업 없이 즉시 ATR 손절 적용 중
            # 여기는 트레일링 손절 이후 추가 손절 판정용

            # ② 얇은 수익 체크포인트 (+0.2%) 도달 시 강세 판단
            # 🔧 FIX: 체크포인트 재평가 - 가격이 0.1% 아래로 떨어지면 리셋
            if checkpoint_reached and not strong_mode and cur_gain < (THIN_PROFIT_CHECKPOINT * 0.3):
                checkpoint_reached = False  # 체크포인트 아래로 떨어짐 → 재평가 허용

            # 🔧 소프트 가드: 초기 30초간 청산 조건 강화
            in_soft_guard = alive_sec < SOFT_GUARD_SEC

            if not checkpoint_reached and cur_gain >= THIN_PROFIT_CHECKPOINT:
                checkpoint_reached = True
                # 강세 여부 체크
                if is_strong_momentum(ticks, ob_now):
                    # 강세 → 트레일링 모드 진입
                    strong_mode = True
                    strong_peak = curp
                    tg_send_mid(f"💪 {m} 진입 후 +{cur_gain*100:.2f}% 강세확인 → 홀딩")
                else:
                    # 약세 판정이지만 소프트 가드 + 박스 내면 홀딩
                    if in_soft_guard and in_breakeven_box:
                        # 초기 30초 + ±0.15% 박스 → 홀딩 (휩쏘 방지)
                        tg_send_mid(f"⏳ {m} 약세 판정이나 소프트가드 구간 → 관찰 유지")
                    else:
                        # 약세 → 즉시 매도
                        close_auto_position(m, f"체크포인트 익절 진입 후 +{cur_gain*100:.2f}% 수익에서 약세판정")
                        verdict = "THIN_PROFIT"
                        break

            # ③ 강세 모드: 고점 추적 + 동적 트레일링 (수익률에 따라 폭 확대)
            if strong_mode:
                # 고점 갱신
                if curp > strong_peak:
                    strong_peak = curp

                # 🚀 동적 트레일링 폭: 수익률에 따라 확대
                # +5% 이상 → -3% 허용, +3% 이상 → -2%, +1% 이상 → -1%, 기본 -0.2%
                peak_gain = (strong_peak / entry_price - 1.0)
                if peak_gain >= 0.05:
                    dynamic_trail_drop = 0.03  # 3%
                elif peak_gain >= 0.03:
                    dynamic_trail_drop = 0.02  # 2%
                elif peak_gain >= 0.01:
                    dynamic_trail_drop = 0.01  # 1%
                else:
                    dynamic_trail_drop = STRONG_TRAIL_DROP  # 0.2%

                # 고점 대비 하락률 계산
                drop_from_strong_peak = (strong_peak - curp) / strong_peak

                if drop_from_strong_peak >= dynamic_trail_drop:
                    final_gain = (curp / entry_price - 1.0)
                    peak_gain = (strong_peak / entry_price - 1.0)
                    close_auto_position(m, f"트레일링 익절 진입 후 +{final_gain*100:.2f}% 수익 (최고+{peak_gain*100:.2f}%에서 -{drop_from_strong_peak*100:.1f}% 하락)")
                    verdict = "STRONG_TRAIL_EXIT"
                    break

            # ⑤ Giveback Cap: MFE 대비 35% 이상 되돌리면 청산
            max_gain = (best / entry_price - 1.0)  # MFE 수익률
            cur_gain_now = (curp / entry_price - 1.0)  # 현재 수익률
            GIVEBACK_CAP = 0.35  # 35% 되돌림 한도
            MIN_GAIN_FOR_GIVEBACK = 0.003  # 최소 +0.3% 수익 시에만 적용

            if max_gain >= MIN_GAIN_FOR_GIVEBACK and cur_gain_now > 0:
                giveback_ratio = (max_gain - cur_gain_now) / max_gain
                if giveback_ratio >= GIVEBACK_CAP:
                    close_auto_position(m, f"Giveback청산 +{cur_gain_now*100:.2f}% (최고+{max_gain*100:.2f}%의 {(1-giveback_ratio)*100:.0f}%만 확보)")
                    verdict = "GIVEBACK_CAP"
                    break

            # ④ 눌림 후 재상승 감지 → 트레일 강화 (재진입 대신)
            drop_from_high = (best - curp) / best if best > 0 else 0
            if drop_from_high >= 0.005 and uptick_streak_from_ticks(ticks, need=3):
                if trail_armed:
                    # 재진입 대신 트레일 간격 타이트하게 강화
                    trail_stop = max(trail_stop, curp * (1.0 - max(TRAIL_DISTANCE_MIN * 0.8, 0.0025)))
                    tg_send_mid(f"🔧 {m} 재상승 감지 → 트레일 강화")
        
        if verdict is None:
            verdict = "시간 만료(모니터링 종료)"

    finally:
        # ================================
        # 1) 최신 상태 / 수익률 계산
        # ================================
        ticks = get_recent_ticks(m, 100)
        t15 = micro_tape_stats_from_ticks(ticks, 15) if ticks else {
            "buy_ratio": 0,
            "krw": 0,
            "n": 0,
            "krw_per_sec": 0
        }

        ob = pre.get("ob") or {}
        ob_depth_krw = ob.get("depth_krw", 10_000_000)

        try:
            ret_pct = ((last_price / entry_price - 1.0) - FEE_RATE) * 100.0
        except:
            ret_pct = 0.0

        maxrun = (best / entry_price - 1.0) * 100.0
        maxdd = (worst / entry_price - 1.0) * 100.0

        # ================================
        # 2) 끝알람 문구 생성
        # ================================
        action, rationale = _end_reco(entry_price,
                                      last_price,
                                      c1,
                                      ticks,
                                      ob_depth_krw,
                                      ctx_thr=CTX_EXIT_THRESHOLD)

        # ===========================================
        # 끝알람 / 재모니터링 알림 비활성화
        #  (실제 로직은 유지하지만 텔레그램 메시지 과다 방지)
        # ===========================================
        if not reentry:
            pass  # 끝알람 비활성화
        else:
            pass  # 재모니터링 요약 비활성화

        # ===========================================
        # 재모니터링 루프 시작
        #  - 최초 모니터링에서만 호출
        #  - remonitor_until_close()에서 재호출된 경우(reentry=True)는 다시 안 들어감
        # ===========================================
        # ✅ 재모니터링 알림 비활성화 (불필요한 반복 메시지 방지)
        # (실제 로직은 유지하지만, 알림 발송만 차단)
        if AUTO_TRADE and m in OPEN_POSITIONS and not reentry:
            remonitor_until_close(m, entry_price, pre, tight_mode)

        # ===========================================
        # 3) probe 손절 후 빠른 재진입 허용 로직
        # ===========================================
        if AUTO_TRADE and verdict and "손절" in verdict:
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m)
                if pos and pos.get("entry_mode") == "probe":
                    # probe 손절 시 재진입 쿨다운 최소화
                    REMONITOR_QUICK_COOLDOWN_SEC = 120  # 2분 쿨다운
                    REMONITOR_WINDOW_MINUTES = 10       # 10분 내 동일 종목 재기회 허용

                    # 최근 종료 시각 기록
                    pos["last_exit_ts"] = time.time()
                    OPEN_POSITIONS[m] = pos

                    # 🌀 probe 손절 감지 → 재진입 모드 (알림 비활성화)

                    # 빠른 재모니터링 예약
                    time.sleep(REMONITOR_QUICK_COOLDOWN_SEC)
                    remonitor_until_close(m, entry_price, pre, tight_mode)

        # 👇 이 return 은 if 바깥에서 항상 실행되게
        return (
            verdict,
            action,
            rationale,
            ret_pct,
            last_price,
            maxrun,
            maxdd,
        )


