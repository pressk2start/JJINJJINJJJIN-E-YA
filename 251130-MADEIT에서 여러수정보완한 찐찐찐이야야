def stage1_gate(*, spread, accel, volume_surge, turn_pct, buy_ratio, imbalance, fresh_ok,
                 current_volume=0, price_change=0, mega=False,
                 ema20_breakout=False, high_breakout=False, vol_vs_ma=0.0,
                 ignition_score=0):
    """
    1단계 진입 게이트: 단일 통합 필터 (점화 통합)

    [🔥 점화 점수 = 가점/완화 요소]
    - ignition_score가 높으면 임계치가 동적으로 완화됨
    - 별도 분기 없이 단일 흐름으로 처리
    - 학습/튜닝 포인트: GATE_* 변수 하나

    [전역 변수 임계치 사용 - 자동학습 대상]
    - GATE_TURN_MIN: 회전율 하한
    - GATE_SPREAD_MAX: 스프레드 상한
    - GATE_ACCEL_MIN: 가속도 하한
    - GATE_BUY_RATIO_MIN: 매수비 하한
    - GATE_IMBALANCE_MIN: 호가 임밸런스 하한
    - GATE_VOL_MIN: 거래대금 하한
    - GATE_SURGE_MIN: 거래량급등 하한
    - GATE_PRICE_MIN: 가격변동 하한

    Returns: (allow, reason)
    """
    # ============================================================
    # 🔥 점화 점수에 따른 동적 임계치 완화 (별도 분기 X, 가점 방식)
    # ignition_score: 0~4, 점수당 완화 비율 적용
    # ============================================================
    relax = ignition_score * 0.08  # 점수당 8% 완화 (3점이면 24% 완화)

    # 동적 임계치 계산 (점화 점수 높으면 조건 완화)
    eff_surge_min = max(0.1, GATE_SURGE_MIN * (1 - relax))       # 0.4 → 0.1 (3점)
    eff_vol_vs_ma = max(0.2, 0.5 * (1 - relax))                  # 0.5 → 0.2 (3점)
    eff_price_min = max(0, GATE_PRICE_MIN * (1 - relax * 2))     # 거의 0
    eff_turn_min = max(0.5, GATE_TURN_MIN * (1 - relax))         # 2.0 → 0.5 (3점)
    eff_buy_min = max(0.45, GATE_BUY_RATIO_MIN * (1 - relax * 0.5))  # 0.55 → 0.48 (3점)
    eff_imb_min = max(0.15, GATE_IMBALANCE_MIN * (1 - relax))    # 0.35 → 0.15 (3점)
    eff_spread_max = GATE_SPREAD_MAX * (1 + relax)               # 0.4 → 0.5 (3점)
    eff_accel_min = max(0.1, GATE_ACCEL_MIN * (1 - relax))       # 0.3 → 0.1 (3점)

    # 점화 여부 (로그용)
    is_ignition = (ignition_score >= 3)

    # 📊 주요 지표 한줄 요약 (튜닝용 - 모든 컷/통과에 표시)
    metrics = (f"점화={ignition_score} surge={volume_surge:.2f}x MA대비={vol_vs_ma:.1f}x "
               f"변동={price_change*100:.2f}% 회전={turn_pct:.1f}% 매수비={buy_ratio:.0%} "
               f"스프레드={spread:.2f}% 임밸={imbalance:.2f} 가속={accel:.1f}x")

    # ============================================================
    # 단일 흐름: 모든 조건 체크 (동적 임계치 사용)
    # ============================================================

    # === 신선도 체크 (필수 - 완화 없음) ===
    if not fresh_ok:
        return False, "틱신선도부족"

    # === 거래대금 컷 ===
    if current_volume < GATE_VOL_MIN and not mega:
        return False, f"거래대금부족 {current_volume/1e6:.0f}M<{GATE_VOL_MIN/1e6:.0f}M"

    # === 거래량 급등 조건 (동적) ===
    vol_ok = (volume_surge >= eff_surge_min) or (vol_vs_ma >= eff_vol_vs_ma)
    if not vol_ok and not mega:
        return False, f"거래량부족 surge{volume_surge:.1f}x<{eff_surge_min:.1f}x MA{vol_vs_ma:.1f}x<{eff_vol_vs_ma:.1f}x"

    # === 가격변동 하한 컷 (동적) ===
    if price_change < eff_price_min and not mega:
        return False, f"변동부족 {price_change*100:.1f}%<{eff_price_min*100:.1f}%"

    # === 회전율 컷 (동적) ===
    if turn_pct < eff_turn_min:
        return False, f"회전율부족 {turn_pct:.1f}%<{eff_turn_min:.1f}%"
    # 🔧 CRITICAL: 과회전 + 스프레드 넓음 = 슬리피지 위험 (120→50 현실화)
    if turn_pct > 50 and spread > 0.25:
        return False, f"과회전+스프레드 회전{turn_pct:.0f}%>50% 스프{spread:.2f}%>0.25%"

    # === 스프레드 컷 (동적) ===
    if spread > eff_spread_max:
        return False, f"스프레드과다 {spread:.2f}%>{eff_spread_max:.2f}%"

    # === 과열 필터 (완화 없음 - 안전장치) ===
    overheated = accel * volume_surge
    if overheated > GATE_OVERHEAT_MAX:
        return False, f"과열 {overheated:.1f}>{GATE_OVERHEAT_MAX}"

    # === 가속도 컷 (동적) ===
    if accel < eff_accel_min:
        return False, f"감속중 가속{accel:.1f}x<{eff_accel_min:.1f}x"
    if accel > GATE_ACCEL_MAX:
        return False, f"가속과다 {accel:.1f}x>{GATE_ACCEL_MAX}x"

    # === 매수비 컷 (동적) ===
    if buy_ratio < eff_buy_min:
        return False, f"매수비부족 {buy_ratio:.0%}<{eff_buy_min:.0%}"

    # === 매수비 100% 컷 (스푸핑 의심 - 완화 없음) ===
    if abs(buy_ratio - 1.0) < 1e-6:
        return False, "매수비100%(스푸핑)"

    # === 급등 컷 (완화 없음 - 안전장치) ===
    if volume_surge > GATE_SURGE_MAX:
        return False, f"급등과다 {volume_surge:.1f}x>{GATE_SURGE_MAX}x"

    # === 호가 임밸런스 컷 (동적) ===
    if imbalance < eff_imb_min:
        return False, f"호가균형취약 임밸{imbalance:.2f}<{eff_imb_min:.2f}"

    # === 진입 신호 체크 (동적) ===
    # 돌파 점수: EMA20 돌파 + 고점 돌파
    breakout_score = int(ema20_breakout) + int(high_breakout)

    # 진입 조건: 돌파 1개 OR vol_vs_ma OR 점화 3점 이상
    entry_signal = (breakout_score >= 1) or (vol_vs_ma >= eff_vol_vs_ma) or (ignition_score >= 3)

    if not entry_signal:
        return False, f"진입조건미달 EMA돌파={ema20_breakout} 고점돌파={high_breakout} MA{vol_vs_ma:.1f}x"

    # === 통과 ===
    # 신호 타입 표시 (점화 / 강돌파 / EMA↑ / 고점↑ / 거래량↑)
    if is_ignition:
        signal_tag = "🔥점화"
    elif breakout_score == 2:
        signal_tag = "강돌파 (EMA↑+고점↑)"
    elif ema20_breakout:
        signal_tag = "EMA↑"
    elif high_breakout:
        signal_tag = "고점↑"
    else:
        signal_tag = "거래량↑"

    # 통과 시 주요 지표만 간략 표시
    pass_summary = f"매수{buy_ratio:.0%} 회전{turn_pct:.1f}% 임밸{imbalance:.2f}"
    return True, f"{signal_tag} PASS | {pass_summary}"


# === 🔧 틱버스트 허용 판단 (비활성화됨) ===
def allow_tick_burst(buy_ratio, turn_pct, tick_count, spread, symbol_median_spread=None):
    """
    🔧 비활성화: tick_burst 경로 제거로 더 이상 사용 안함
    """
    # --- 공통 하드컷 ---
    # 🔥 강화: 3 → 4틱
    if tick_count < 4:
        return False, None, "틱수 부족(<4)"

    if buy_ratio <= 0.05:
        return False, None, "매수비 0% 편향"

    # 🔥 강화: 매수비 >= 65% (리포트: 패배 케이스에 낮은 매수비 다수)
    if buy_ratio < 0.65:
        return False, None, f"매수비 부족({buy_ratio:.0%}<65%)"

    # 🔥 강화: 회전율 >= 5% (리포트: 패배에 turn 0.1% 케이스)
    if turn_pct < 5.0:
        return False, None, f"회전율 부족({turn_pct:.1f}%<5%)"

    # 🔥 강화: 스프레드 <= 0.25% (리포트: 패배에 0.4% 케이스)
    thr_spread = 0.25
    if spread > thr_spread:
        return False, None, f"스프레드 초과({spread:.2f}%>{thr_spread:.2f}%)"

    # --- 유동성 레짐 분기 (하드컷 대신 사이징) ---
    # 🔥 강화: 사이징 기준 상향
    if turn_pct >= 10.0 and buy_ratio >= 0.75:
        # 고유동+고매수비: confirm
        size = "normal"
    elif turn_pct >= 8.0:
        # 고유동: half
        size = "half"
    else:
        # 그 외: probe
        size = "probe"

    return True, size, f"통과(회전{turn_pct:.1f}%,매수{buy_ratio:.0%},사이즈={size})"


def detect_leader_stock(m, obc, c1, tight_mode=False):
    """
    하이브리드 진입 탐지 엔진:
      - Probe(소액): 완화된 early 흐름 감지 → 초기 염탐 진입
      - Confirm(추세): 강한 점화/매집/돌파 → 확정 진입
    """
    if len(c1) < 3:
        return None

    # === 🔧 스테이블코인 차단 (USDT, USDC 등 가격변동 없는 코인) ===
    if any(stable in m.upper() for stable in ["USDT", "USDC", "DAI", "TUSD", "BUSD"]):
        cut("STABLECOIN", f"{m} 스테이블코인 제외")
        return None

    # === 동일 종목 중복 진입 방지 (포지션 보유 시 스킵) ===
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if pos:
            # 🔧 FIX: 락 내부에서 체크해야 race condition 방지
            return None

    # === 틱 기반 초봉(10초) 선행 진입 시그널 ===
    # 🔧 비활성화: tick_burst 경로 제거 (normal 경로로 통합)
    # - probe 진입 후 본진입 전략이 실제로 효과 없음
    # - tick_burst vs normal 임계치가 거의 동일해서 분리 의미 없음
    # ticks_now = get_recent_ticks(m, 80)
    # if ticks_now: ... (전체 tick_burst 로직 비활성화)

    # (이하 기존 detect_leader_stock 코드 계속)

    ob = obc.get(m)
    if not ob or not isinstance(ob.get("raw"), dict):
        return None
    if not ob.get("raw", {}).get("orderbook_units"):
        return None
    if ob.get("depth_krw", 0) <= 0:
        return None

    mega = is_mega_breakout(c1)
    th = get_dynamic_thresholds()
    cur, prev = c1[-1], c1[-2]
    price_change = (cur["trade_price"] / max(prev["trade_price"], 1) - 1)

    # 🔧 SPREAD_HIGH, VOL_LOW, SURGE_LOW, PRICE_LOW → stage1_gate로 이동
    # 거래량 데이터 (stage1_gate에서 사용)
    current_volume = cur.get("candle_acc_trade_price", 0)
    past_volumes = [c["candle_acc_trade_price"] for c in c1[-7:-2] if c["candle_acc_trade_price"] > 0]

    # 틱 확보
    ticks = get_recent_ticks(m, 100)
    if not ticks:
        cut("TICKS_LOW", f"{m} no ticks")
        return None

    # 🔥 평시 TPS 업데이트 (점화 감지용)
    update_baseline_tps(m, ticks)

    # === 테이프 지표 (stage1_gate용) ===
    t15 = micro_tape_stats_from_ticks(ticks, 15)
    t45 = micro_tape_stats_from_ticks(ticks, 45)
    twin = t15 if t15["krw_per_sec"] >= t45["krw_per_sec"] else t45
    turn = twin["krw"] / max(ob["depth_krw"], 1)

    # 🔥 1단계 게이트 적용 (단일 통합 필터)
    # 점화 감지도 stage1_gate 내에서 처리
    vol_surge = current_volume / max(statistics.mean(past_volumes) if past_volumes else current_volume / 8, 1)
    accel = calc_flow_acceleration(ticks)
    turn_pct = turn * 100  # decimal → %
    imbalance = calc_orderbook_imbalance(ob)
    fresh_ok = last_two_ticks_fresh(ticks)

    # 🔥 섀도우 모드용 지표 미리 계산
    ia = inter_arrival_stats(ticks, 30)
    cv = ia["cv"]
    pstd10 = price_band_std(ticks, 10)
    cons_buys = calc_consecutive_buys(ticks, 15)
    overheat = accel * vol_surge
    spread = ob.get("spread", 9.9)

    # 🛑 하드 컷: 극단 스푸핑 패턴 (확신 구간만 차단)
    # buy_ratio >= 0.98 AND pstd <= 0.001 AND CV >= 2.5
    if twin["buy_ratio"] >= 0.98 and pstd10 <= 0.001 and cv >= 2.5:
        cut("FAKE_FLOW_HARD", f"{m} buy{twin['buy_ratio']:.2f} pstd{pstd10:.4f} cv{cv:.2f}")
        return None

    # 🔍 섀도우 태깅 (실거래는 그대로, 태그만 기록)
    shadow_flags = []
    if cv > 2.2:
        shadow_flags.append("CV22")
    if turn_pct >= 12 and (cons_buys > 18 or overheat > 3):
        shadow_flags.append("TURNxCONS/HEAT")
    if accel >= 3.0 and not (imbalance >= 0.40 and spread <= 0.12):
        shadow_flags.append("ACCEL_WEAK_CTX")
    would_cut = len(shadow_flags) > 0

    # 🚀 신규 조건 계산: EMA20 돌파, 고점 돌파, 거래량 MA 대비
    cur_price = cur["trade_price"]
    closes = [x["trade_price"] for x in c1]
    ema20 = ema_last(closes, 20) if len(closes) >= 20 else None
    ema20_breakout = (ema20 is not None and cur_price > ema20)

    prev_high = prev_high_from_candles(c1, lookback=12, skip_recent=1)
    high_breakout = (prev_high > 0 and cur_price > prev_high)

    vol_ma20 = vol_ma_from_candles(c1, period=20)
    vol_vs_ma = current_volume / max(vol_ma20, 1) if vol_ma20 > 0 else 0.0

    # 🔥 점화 감지 점수 계산 (stage1_gate에 전달)
    _, ignition_reason, ignition_score = ignition_detected(
        market=m,
        ticks=ticks,
        avg_candle_volume=vol_ma20,
        ob=ob,
        cooldown_ms=15000
    )

    gate_ok, gate_reason = stage1_gate(
        spread=ob["spread"],
        accel=accel,
        volume_surge=vol_surge,
        turn_pct=turn_pct,
        buy_ratio=twin["buy_ratio"],
        imbalance=imbalance,
        fresh_ok=fresh_ok,
        current_volume=current_volume,
        price_change=price_change,
        mega=mega,
        # 🚀 신규 파라미터
        ema20_breakout=ema20_breakout,
        high_breakout=high_breakout,
        vol_vs_ma=vol_vs_ma,
        ignition_score=ignition_score
    )
    if not gate_ok:
        # STAGE1_GATE는 텔레그램 알람 전에 컷되므로 near_miss=False
        cut("STAGE1_GATE", f"{m} {gate_reason}", near_miss=False)
        return None

    # === 결과 패키징 ===
    # 🔥 signal_tag 추출 (gate_reason: "{signal_tag} PASS | {metrics}")
    signal_tag = gate_reason.split(" PASS")[0] if " PASS" in gate_reason else "기본"

    pre = {
        "price": cur["trade_price"],
        "change": price_change,
        "current_volume": current_volume,
        "volume_surge": vol_surge,
        "ob": ob,
        "tape": twin,
        "ticks": ticks,
        "flow_accel": accel,
        "imbalance": imbalance,
        "turn_pct": turn_pct,
        "spread": ob["spread"],
        "buy_ratio": twin["buy_ratio"],
        "fresh_ok": fresh_ok,  # 🔧 CRITICAL: fresh_ok 전달 (스코어 계산용)
        "mega": mega,
        "filter_type": "stage1_gate",
        "ignition_score": ignition_score,
        "gate_reason": gate_reason,
        # 🔥 경로 표시: signal_tag 하나로 통일 (점화3, EMA↑, 고점↑, 거래량↑ 등)
        "signal_tag": signal_tag,
        # 🔍 섀도우 모드용 (거래는 그대로, 나중에 분석용)
        "shadow_flags": ",".join(shadow_flags) if shadow_flags else "",
        "would_cut": would_cut,
        "cv": cv,
        "pstd": pstd10,
        "consecutive_buys": cons_buys,
        "overheat": overheat,
    }

    return pre

def final_check_leader(m, pre, tight_mode=False):
    """
    🔧 단순 패스쓰루: stage1_gate/prebreak에서 모든 필터링 완료
    호환성을 위해 함수는 유지하되, 바로 payload 반환
    """
    t = pre["tape"]
    ob = pre["ob"]

    # Pre-break는 틱수 체크 스킵 (이미 조건 충족)
    filter_type = pre.get("filter_type", "stage1_gate")
    if filter_type != "prebreak":
        # 최소 틱수만 체크 (이건 stage1_gate 전에 필요)
        if t["n"] < MIN_TICKS_COUNT:
            cut("TICKS_LOW", f"{m} {t['n']}")
            return None

    # 필터 타입에 따른 표시: signal_tag 사용
    if filter_type == "prebreak":
        display_filter = "🚀선행진입"
    elif "점화" in pre.get("signal_tag", ""):
        display_filter = "빠른진입"
    else:
        display_filter = "통합게이트"

    # 🔧 FIX: score 계산 복원 (calc_risk_score 호출)
    buy_ratio = pre.get("buy_ratio", 0.5)
    spread = pre.get("spread", 0.5)
    # 🔧 CRITICAL: turn 단위 보정 (퍼센트 → 소수)
    turn = (pre.get("turn_pct", 1.0) or 1.0) / 100.0
    imbalance = pre.get("imbalance", 0.0)
    volume_surge = pre.get("volume_surge", 1.0)
    fresh_ok = pre.get("fresh_ok", True)

    score = calc_risk_score(buy_ratio, spread, turn, imbalance, fresh_ok, volume_surge)

    # 프리시전 포켓: 임밸 >= 0.6 AND 매수비 >= 63.5%
    is_precision = (imbalance >= 0.6 and buy_ratio >= 0.635)

    # 이미 stage1_gate/prebreak에서 모든 필터링 완료
    # 기존 호출 코드 호환을 위해 payload 형식으로 반환
    return {
        "price": pre["price"],
        "chg": round(pre.get("change", 0) * 100, 2),
        "current_volume": int(pre.get("current_volume", 0)),
        "volume_surge": round(pre.get("volume_surge", 0.0), 2),
        "buy": round(pre.get("buy_ratio", 0) * 100, 1),
        "n": t["n"],
        "spread": round(pre.get("spread", 0), 2),
        "turn": round(pre.get("turn_pct", 0), 2),
        "imbalance": round(imbalance, 3),
        "score": score,
        "is_precision_pocket": is_precision,
        "filter_type": display_filter,
        "is_prebreak": filter_type == "prebreak",
    }


