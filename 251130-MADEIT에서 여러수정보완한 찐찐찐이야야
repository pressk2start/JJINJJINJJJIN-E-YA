def log_trade_features(entry_data: dict, exit_data: dict = None):
    """
    거래 피처 로깅 (진입 시 호출, 청산 시 업데이트)
    """
    with _trade_log_lock:
        new_file = not os.path.exists(TRADE_LOG_PATH)
        with open(TRADE_LOG_PATH, "a", newline="", encoding="utf-8") as f:
            w = csv.DictWriter(f, fieldnames=FEATURE_FIELDS)
            if new_file:
                w.writeheader()
            row = {k: entry_data.get(k, "") for k in FEATURE_FIELDS}
            if exit_data:
                row.update(exit_data)
            w.writerow(row)

_last_report_ts = {}  # 🔧 중복 카운트 방지: 마지막 리포트 시각 (market -> ts)

def update_trade_result(market: str, exit_price: float, pnl_pct: float, hold_sec: float):
    """
    청산 시 결과 업데이트 + 건수 기반 학습 트리거 + 경로 리포트
    """
    global _trade_count_since_learn, _lose_streak, _win_streak, _path_report_count

    # 🔧 방어: last_trade_was_loss가 아직 없으면 초기화
    globals().setdefault("last_trade_was_loss", {})

    # 🔧 중복 카운트 방지: 같은 마켓이 30초 내 중복 호출되면 스킵
    now_ts = time.time()
    last_ts = _last_report_ts.get(market, 0)
    if now_ts - last_ts < 30:
        print(f"[UPDATE_TRADE] {market} 중복 호출 스킵 ({now_ts - last_ts:.1f}초 내)")
        return
    _last_report_ts[market] = now_ts

    print(f"[UPDATE_TRADE] {market} 청산 기록 시작 (pnl: {pnl_pct:.2%})")

    is_win = pnl_pct > 0
    csv_exists = os.path.exists(TRADE_LOG_PATH)

    # 🔧 손실 후 동일 종목 쿨다운 2배 적용용 플래그 설정
    last_trade_was_loss[market] = not is_win

    if not csv_exists:
        print(f"[UPDATE_TRADE] {TRADE_LOG_PATH} 파일 없음 (CSV 업데이트 스킵, 리포트는 계속)")
    else:
        with _trade_log_lock:
            try:
                rows = []
                with open(TRADE_LOG_PATH, "r", encoding="utf-8") as f:
                    reader = csv.DictReader(f)
                    rows = list(reader)

                # 마지막 해당 마켓 찾아서 업데이트
                for i in range(len(rows) - 1, -1, -1):
                    if rows[i]["market"] == market and not rows[i].get("exit_price"):
                        rows[i]["exit_price"] = str(exit_price)
                        rows[i]["pnl_pct"] = f"{pnl_pct:.4f}"
                        rows[i]["result"] = "win" if is_win else "lose"
                        rows[i]["hold_sec"] = str(int(hold_sec))
                        break

                # 다시 쓰기
                with open(TRADE_LOG_PATH, "w", newline="", encoding="utf-8") as f:
                    w = csv.DictWriter(f, fieldnames=FEATURE_FIELDS)
                    w.writeheader()
                    w.writerows(rows)
            except Exception as e:
                print(f"[TRADE_LOG_UPDATE_ERR] {e}")

    # 🔧 건수 기반 학습 트리거 (매수만 학습)
    if AUTO_LEARN_ENABLED:
        _trade_count_since_learn += 1

        if is_win:
            _lose_streak = 0   # 승리 시 연패 리셋
            _win_streak += 1   # 🔧 연승 증가
        else:
            _lose_streak += 1  # 패배 시 연패 증가
            _win_streak = 0    # 🔧 연승 리셋

        # 🔧 연패 3회 시 Pre-break 10분간 중지
        global _PREBREAK_SUSPEND_UNTIL
        if _lose_streak >= 3:
            _PREBREAK_SUSPEND_UNTIL = time.time() + 600  # 10분
            print(f"[LOSE_STREAK] 연속 {_lose_streak}패 → Pre-break 10분 중지")

        # 학습 조건: 10건마다 OR 연속 3패
        should_learn = (
            _trade_count_since_learn >= AUTO_LEARN_INTERVAL or
            _lose_streak >= AUTO_LEARN_STREAK_TRIGGER
        )

        if should_learn:
            trigger_reason = f"연속 {_lose_streak}패" if _lose_streak >= AUTO_LEARN_STREAK_TRIGGER else f"{_trade_count_since_learn}건 도달"
            print(f"[AUTO_LEARN] 학습 트리거: {trigger_reason}")
            _trade_count_since_learn = 0  # 리셋

            try:
                learn_result = analyze_and_update_weights()
                if learn_result:
                    thr = learn_result.get("thresholds", {})
                    chg = learn_result.get("changes", {})

                    # analyze_and_update_weights() 안에서 이미 GATE_* 전역을 갱신함
                    change_detail = " | ".join(
                        f"{k}:{v:+g}" for k, v in chg.items() if v != 0
                    ) or "변화없음"

                    tg_send(
                        f"🧠 <b>자동학습 완료</b> ({trigger_reason})\n"
                        f"📊 승률: {learn_result['win_rate']}% ({learn_result['wins']}승/{learn_result['loses']}패)\n"
                        f"📈 샘플: {learn_result.get('sample_size', 0)}건\n"
                        f"🧱 게이트 변화: {change_detail}\n"
                        f"🎯 현재 임계치: "
                        f"매수비≥{thr.get('GATE_BUY_RATIO_MIN', GATE_BUY_RATIO_MIN):.0%} "
                        f"스프레드≤{thr.get('GATE_SPREAD_MAX', GATE_SPREAD_MAX):.2f}% "
                        f"회전≥{thr.get('GATE_TURN_MIN', GATE_TURN_MIN):.1f}% "
                        f"임밸≥{thr.get('GATE_IMBALANCE_MIN', GATE_IMBALANCE_MIN):.2f} "
                        f"급등≤{thr.get('GATE_SURGE_MAX', GATE_SURGE_MAX):.1f}x "
                        f"가속≥{thr.get('GATE_ACCEL_MIN', GATE_ACCEL_MIN):.2f}x"
                    )
                else:
                    tg_send_mid(f"🧠 자동학습 시도 ({trigger_reason}) - 데이터 부족으로 스킵")
            except Exception as e:
                print(f"[AUTO_LEARN_ERR] {e}")

    # 🔍 경로 리포트 (20건마다 자동 발송)
    _path_report_count += 1
    print(f"[PATH_REPORT] 카운트: {_path_report_count}/{PATH_REPORT_INTERVAL}")
    if _path_report_count >= PATH_REPORT_INTERVAL:
        _path_report_count = 0
        try:
            # 경로 통계 + 상세 거래 목록 합쳐서 발송
            path_report = get_path_statistics(50)  # 최근 50건 경로 분석
            detail_report = get_recent_trades_detail(10)  # 최근 10건 상세
            combined = path_report + detail_report
            print(f"[PATH_REPORT] 리포트 발송 시도")
            tg_send(combined)
        except Exception as e:
            print(f"[PATH_REPORT_ERR] {e}")

def get_path_statistics(last_n: int = 100) -> str:
    """
    🔍 경로별 승률 통계 생성 (텔레그램 리포트용)
    """
    if not os.path.exists(TRADE_LOG_PATH):
        return "📊 거래 기록 없음"

    try:
        import pandas as pd
        df = pd.read_csv(TRADE_LOG_PATH)

        # result 컬럼이 있고 값이 있는 행만 (청산 완료된 거래)
        if "result" not in df.columns:
            return "📊 청산 기록 없음"

        df = df[df["result"].isin(["win", "lose"])].tail(last_n)

        if len(df) < 5:
            return f"📊 데이터 부족 ({len(df)}건, 최소 5건 필요)"

        total = len(df)
        wins = len(df[df["result"] == "win"])
        overall_wr = wins / total * 100 if total > 0 else 0

        lines = [
            f"📊 <b>경로별 승률 리포트</b> (최근 {total}건)",
            f"📈 전체 승률: {overall_wr:.1f}% ({wins}승/{total-wins}패)",
            "─" * 20,
        ]

        # 1단계: 감지 타입
        if "detect_type" in df.columns:
            lines.append("<b>1단계 감지:</b>")
            for dtype in df["detect_type"].dropna().unique():
                sub = df[df["detect_type"] == dtype]
                cnt = len(sub)
                w = len(sub[sub["result"] == "win"])
                wr = w / cnt * 100 if cnt > 0 else 0
                icon = "⚡" if dtype == "tick_burst" else "📊"
                star = " ✅" if wr >= overall_wr + 10 else (" ⚠️" if wr <= overall_wr - 10 else "")
                lines.append(f"  {icon}{dtype}: {cnt}건 ({wr:.0f}%){star}")

        # 2단계: 트리거 타입
        if "trigger_type" in df.columns:
            lines.append("<b>2단계 트리거:</b>")
            # 트리거는 복합(점화+Early)일 수 있으므로 개별 분석
            trigger_stats = {}
            for _, row in df.iterrows():
                triggers = str(row.get("trigger_type", "")).split("+")
                for t in triggers:
                    t = t.strip()
                    if not t or t == "없음":
                        continue
                    if t not in trigger_stats:
                        trigger_stats[t] = {"win": 0, "total": 0}
                    trigger_stats[t]["total"] += 1
                    if row["result"] == "win":
                        trigger_stats[t]["win"] += 1

            # 승률 순으로 정렬
            sorted_triggers = sorted(trigger_stats.items(),
                                     key=lambda x: x[1]["win"]/max(x[1]["total"],1),
                                     reverse=True)
            for t, stats in sorted_triggers:
                cnt = stats["total"]
                w = stats["win"]
                wr = w / cnt * 100 if cnt > 0 else 0
                star = " ✅" if wr >= overall_wr + 10 else (" ⚠️" if wr <= overall_wr - 10 else "")
                lines.append(f"  {t}: {cnt}건 ({wr:.0f}%){star}")

        # 3단계: 필터 타입
        if "filter_type" in df.columns:
            lines.append("<b>3단계 필터:</b>")
            for ftype in df["filter_type"].dropna().unique():
                sub = df[df["filter_type"] == ftype]
                cnt = len(sub)
                w = len(sub[sub["result"] == "win"])
                wr = w / cnt * 100 if cnt > 0 else 0
                icon = "🎯" if ftype == "프리시전" else "✓"
                star = " ✅" if wr >= overall_wr + 10 else (" ⚠️" if wr <= overall_wr - 10 else "")
                lines.append(f"  {icon}{ftype}: {cnt}건 ({wr:.0f}%){star}")

        # 🔥 경로 조합별 승률
        if all(col in df.columns for col in ["detect_type", "trigger_type", "filter_type"]):
            lines.append("<b>📍 경로 조합:</b>")

            # 조합 생성
            combo_stats = {}
            for _, row in df.iterrows():
                detect = "⚡" if row.get("detect_type") == "tick_burst" else "📊"
                trigger = str(row.get("trigger_type", "-"))[:6]  # 길면 자르기
                ftype = "🎯" if row.get("filter_type") == "프리시전" else "✓"
                combo = f"{detect}→{trigger}→{ftype}"

                if combo not in combo_stats:
                    combo_stats[combo] = {"win": 0, "total": 0}
                combo_stats[combo]["total"] += 1
                if row["result"] == "win":
                    combo_stats[combo]["win"] += 1

            # 승률 순 정렬, 상위 5개만
            sorted_combos = sorted(combo_stats.items(),
                                   key=lambda x: (x[1]["win"]/max(x[1]["total"],1), x[1]["total"]),
                                   reverse=True)

            for combo, stats in sorted_combos[:7]:  # 최대 7개
                cnt = stats["total"]
                w = stats["win"]
                wr = w / cnt * 100 if cnt > 0 else 0
                star = " ✅" if wr >= overall_wr + 10 else (" ⚠️" if wr <= overall_wr - 10 else "")
                lines.append(f"  {combo}: {cnt}건 ({wr:.0f}%){star}")

        # 추천
        lines.append("─" * 20)

        # 가장 나쁜 경로 찾기
        worst = None
        worst_wr = 100
        if "detect_type" in df.columns:
            for dtype in df["detect_type"].dropna().unique():
                sub = df[df["detect_type"] == dtype]
                cnt = len(sub)
                if cnt >= 3:
                    wr = len(sub[sub["result"] == "win"]) / cnt * 100
                    if wr < worst_wr:
                        worst_wr = wr
                        worst = f"감지:{dtype}"

        if worst and worst_wr < overall_wr - 5:
            lines.append(f"💡 검토 필요: {worst} ({worst_wr:.0f}%)")
        else:
            lines.append("💡 특별히 나쁜 경로 없음")

        return "\n".join(lines)

    except Exception as e:
        return f"📊 통계 오류: {e}"

def get_recent_trades_detail(last_n: int = 10) -> str:
