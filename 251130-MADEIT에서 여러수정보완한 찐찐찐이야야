def close_auto_position(m, reason=""):
    """
    손절/청산 시 자동 매도 (찌꺼기 방지 포함)
    """
    if not AUTO_TRADE:
        print(f"[AUTO] AUTO_TRADE=0 → 청산 스킵 ({m}, reason={reason})")
        return

    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)

    if not pos:
        print(f"[AUTO] OPEN_POSITIONS에 {m} 포지션 없음 → 청산 스킵 (reason={reason})")
        tg_send_mid(f"⚠️ {m} 청산 시도했는데 OPEN_POSITIONS에 포지션 없음")
        return

    # 실제 보유량 조회 (찌꺼기 방지)
    actual_vol = get_actual_balance(m)
    vol = actual_vol if actual_vol > 0 else pos.get("volume", 0)

    tg_send_mid(f"💣 {m} 자동청산 시도 (reason={reason}, vol={vol:.6f})")

    if vol <= 0:
        print(f"[AUTO] {m} volume<=0 ({vol}) → 포지션 제거만 수행")
        with _POSITION_LOCK:
            OPEN_POSITIONS.pop(m, None)
        # 🔧 FIX: volume 0이어도 리포트 카운트 증가
        if AUTO_LEARN_ENABLED:
            try:
                update_trade_result(m, 0, 0, 0)  # 더미 값으로 카운트만
            except:
                pass
        return

    entry_price = pos.get("entry_price", 0)

    # 현재가(청산 전 기준) 조회 - ✅ 퍼블릭 API 사용
    try:
        cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
        cur_price = cur_js[0].get("trade_price",
                                  entry_price) if cur_js else entry_price
    except Exception:
        cur_price = entry_price

    # 선 계산(대략)
    ret_pct = (cur_price / entry_price -
               1.0) * 100.0 if entry_price > 0 else 0.0
    est_entry_value = entry_price * vol
    est_exit_value = cur_price * vol
    pl_value = est_exit_value - est_entry_value

    print(
        f"[AUTO] {m} 청산 시도: volume={vol}, reason={reason}, PnL(선계산)={ret_pct:+.2f}%"
    )

    exit_price_used = cur_price  # 실제 체결가 성공 시 교체

    try:
        res = place_market_sell(m, vol, price_hint=cur_price)  # 🔧 가격 힌트 전달
        order_uuid = res.get("uuid") if isinstance(res, dict) else None
        if order_uuid:
            od = get_order_result(order_uuid, timeout_sec=6.0)
        else:
            od = None

        # 실제 체결량/체결가 계산
        executed = 0.0
        if od:
            trades = od.get("trades") or []
            total_krw = 0.0
            total_vol = 0.0
            for tr in trades:
                try:
                    p = float(tr.get("price", "0"))
                    v = float(tr.get("volume", "0"))
                except Exception:
                    continue
                total_krw += p * v
                total_vol += v
            executed = total_vol
            if total_vol > 0:
                exit_price_used = total_krw / total_vol

        # 🔧 FIX #1: 미체결 시 포지션 유지
        if executed <= 0:
            print(f"[AUTO] {m} 청산 미체결 → 포지션 유지")
            tg_send(f"⚠️ <b>자동청산 미체결</b> {m}\n사유: 체결량 0 / 포지션 유지")
            return

        # 🔧 FIX #1: 부분체결 시 잔여량으로 업데이트
        if executed < vol - 1e-10:
            remaining = max(vol - executed, 0.0)
            # ✅ 잔여가 최소주문금액(5000원) 미만이면 메모리에서 제거 (좀비 방지)
            if exit_price_used * remaining < 5000:
                remaining = 0.0
            with _POSITION_LOCK:
                pos2 = OPEN_POSITIONS.get(m)
                if pos2:
                    if remaining <= 0:
                        OPEN_POSITIONS.pop(m, None)
                    else:
                        pos2["volume"] = remaining
                        pos2["last_exit_ts"] = time.time()
                        OPEN_POSITIONS[m] = pos2
            print(f"[AUTO] {m} 부분체결: {executed:.6f}/{vol:.6f} → 잔여 {remaining:.6f}")
            if remaining > 0:
                tg_send(f"⚠️ <b>부분체결</b> {m}\n체결: {executed:.6f} / 잔여: {remaining:.6f}")
            else:
                tg_send(f"⚠️ <b>부분체결</b> {m}\n체결: {executed:.6f} / 잔여 미달 → 정리완료")
            # 부분체결도 손익 계산은 함 (executed 기준)
            vol = executed  # 아래 손익 계산용

        # 🔧 FIX #1: 전량체결 시에만 포지션 제거
        else:
            with _POSITION_LOCK:
                OPEN_POSITIONS.pop(m, None)

        # 🔧 FIX: 실제 체결량(vol=executed) 기준으로 재계산
        est_entry_value = entry_price * vol  # ✅ executed 기준으로 재계산
        est_exit_value = exit_price_used * vol
        pl_value = est_exit_value - est_entry_value
        ret_pct = (exit_price_used / entry_price -
                   1.0) * 100.0 if entry_price > 0 else 0.0

        # ✅ 거래 결과 기록 (승률 기반 리스크 튜닝에 사용)
        try:
            record_trade(m, ret_pct)
        except Exception as _e:
            print("[TRADE_RECORD_ERR]", _e)

        # 🧠 자동 학습용 결과 업데이트
        if AUTO_LEARN_ENABLED:
            try:
                hold_sec = time.time() - pos.get("entry_ts", time.time())
                update_trade_result(m, exit_price_used, ret_pct / 100.0, hold_sec)
            except Exception as _e:
                print(f"[FEATURE_UPDATE_ERR] {_e}")

        result_emoji = "🟢" if ret_pct > 0 else "🔴"
        fee_total = (est_entry_value + est_exit_value) * 0.0005  # 수수료 추정 (0.05%)

        tg_send(
            f"====================================\n"
            f"{result_emoji} <b>자동청산 완료</b> {m}\n"
            f"====================================\n"
            f"💰 순손익: {pl_value:+,.0f}원 ({ret_pct:+.2f}%)\n\n"
            f"• 사유: {reason}\n"
            f"• 매수평단: {fmt6(entry_price)}원\n"
            f"• 실매도가: {fmt6(exit_price_used)}원\n"
            f"• 체결수량: {vol:.6f}\n"
            f"• 매수금액: {est_entry_value:,.0f}원\n"
            f"• 청산금액: {est_exit_value:,.0f}원\n"
            f"• 수수료: {fee_total:,.0f}원\n"
            f"====================================\n"
            f"{link_for(m)}"
        )

    except Exception as e:
        print("[AUTO SELL ERR]", e)
        tg_send(f"⚠️ <b>자동청산 실패</b> {m}\n사유: {e}")

        # 🔧 FIX: 최소주문금액 미만 → 매도 불가 찌꺼기, 메모리 포지션만 정리
        if "최소주문금액" in str(e) or "5000" in str(e):
            with _POSITION_LOCK:
                OPEN_POSITIONS.pop(m, None)
            tg_send_mid(f"🧹 {m} 최소주문금액 미만 → 포지션 제거 (소량 잔여는 보유)")
            # 🔧 FIX: 리포트 카운트 증가
            if AUTO_LEARN_ENABLED:
                try:
                    update_trade_result(m, 0, 0, 0)
                except:
                    pass
            return

        # 🔧 FIX: 400 에러 시 실제 잔고 확인 → 0이면 좀비 포지션 제거
        if "400" in str(e) or "Bad Request" in str(e):
            actual_check = get_actual_balance(m)
            if actual_check <= 0:
                print(f"[AUTO] {m} 잔고 0 확인 → 좀비 포지션 제거")
                tg_send_mid(f"🗑️ {m} 좀비 포지션 제거 (실제 잔고 0)")
                with _POSITION_LOCK:
                    OPEN_POSITIONS.pop(m, None)
                # 🔧 FIX: 리포트 카운트 증가
                if AUTO_LEARN_ENABLED:
                    try:
                        update_trade_result(m, 0, 0, 0)
                    except:
                        pass
        return


def safe_partial_sell(m, sell_ratio=0.5, reason=""):
    """
    부분 청산 공용 함수
    - sell_ratio: 0.5 → 50%, 0.3 → 30% 등
    - partial_done 플래그로 1회만 부분청산/부분익절 허용
    반환: (성공여부:bool, 메시지:str, 체결량:float)
    """
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if not pos or pos.get("volume", 0) <= 0:
            msg = f"[REMONITOR] {m} 부분청산 실패: 포지션 없음/수량 0"
            print(msg)
            return False, msg, 0.0
        if pos.get("partial_done"):
            msg = f"[REMONITOR] {m} 부분청산 이미 수행됨 → 스킵"
            print(msg)
            return False, msg, 0.0
        current_volume = pos["volume"]
        entry_price = pos.get("entry_price", 0)

    sell_volume = current_volume * sell_ratio
    if sell_volume <= 0:
        msg = f"[REMONITOR] {m} 부분청산 실패: sell_volume<=0"
        print(msg)
        return False, msg, 0.0

    # 🔧 현재가 조회 (최소주문금액 체크용)
    try:
        cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
        cur_price = cur_js[0].get("trade_price", entry_price) if cur_js else entry_price
    except Exception:
        cur_price = entry_price

    # 🔧 FIX: 최소주문금액(5000원) 사전검증
    MIN_ORDER_KRW = 5000
    sell_krw = sell_volume * cur_price
    remaining_volume = current_volume - sell_volume
    remaining_krw = remaining_volume * cur_price

    # 매도금액 또는 잔여금액이 5000원 미만이면 → 전량청산으로 전환
    if sell_krw < MIN_ORDER_KRW or remaining_krw < MIN_ORDER_KRW:
        print(f"[PARTIAL→FULL] {m} 최소금액 미달 (매도:{sell_krw:.0f}원, 잔여:{remaining_krw:.0f}원) → 전량청산")
        sell_volume = current_volume  # 전량으로 변경
        # partial_done은 설정하지 않음 (전량청산이므로 포지션 종료됨)

    try:
        res = place_market_sell(m, sell_volume, price_hint=cur_price)
        order_uuid = res.get("uuid") if isinstance(res, dict) else None
        od = get_order_result(order_uuid,
                              timeout_sec=6.0) if order_uuid else None

        executed = 0.0
        if od:
            try:
                executed = float(od.get("executed_volume") or "0")
            except Exception:
                executed = 0.0

        if executed <= 0:
            msg = f"[PARTIAL_SELL_ERR] {m}: executed_volume=0 (요청 {sell_volume:.6f})"
            print(msg)
            tg_send_mid(f"⚠️ <b>부분청산 주문 실패</b> {m}\n"
                        f"• 요청 비율: {sell_ratio*100:.0f}%\n"
                        f"• 요청 수량: {sell_volume:.6f}\n"
                        f"• 체결 수량: 0 (실패)")
            return False, msg, 0.0

        remaining_volume = max(current_volume - executed, 0.0)

        # 실제 체결가 계산
        exit_price_used = 0.0
        if od:
            trades = od.get("trades") or []
            total_krw = 0.0
            total_vol = 0.0
            for tr in trades:
                try:
                    p = float(tr.get("price", "0"))
                    v = float(tr.get("volume", "0"))
                except Exception:
                    continue
                total_krw += p * v
                total_vol += v
            if total_vol > 0:
                exit_price_used = total_krw / total_vol

        # 손익 계산
        est_entry_value = entry_price * executed
        est_exit_value = exit_price_used * executed if exit_price_used > 0 else 0
        pl_value = est_exit_value - est_entry_value
        ret_pct = (exit_price_used / entry_price - 1.0) * 100.0 if entry_price > 0 and exit_price_used > 0 else 0.0
        fee_total = (est_entry_value + est_exit_value) * 0.0005

        # 💥 크리티컬 핫픽스: 잔여 0이면 포지션 제거 (좀비 방지)
        if remaining_volume <= 1e-10:
            with _POSITION_LOCK:
                OPEN_POSITIONS.pop(m, None)
            print(f"[PARTIAL→FULL_DONE] {m} 전량청산 완료 → 포지션 제거")
        else:
            with _POSITION_LOCK:
                pos2 = OPEN_POSITIONS.get(m)
                if pos2:
                    pos2["volume"] = remaining_volume
                    pos2["partial_done"] = True
                    pos2["partial_price"] = exit_price_used if exit_price_used > 0 else cur_price
                    pos2["partial_type"] = "profit" if ret_pct > 0 else "loss"

        msg = (f"[REMONITOR] {m} 부분 청산 실행 {sell_ratio*100:.0f}% "
               f"(체결 {executed:.6f}) 잔여 {remaining_volume:.6f}")
        print(msg)

        result_emoji = "🟢" if ret_pct > 0 else "🔴"
        tg_send(
            f"====================================\n"
            f"{result_emoji} <b>부분 청산</b> {m}\n"
            f"====================================\n"
            f"💰 순손익: {pl_value:+,.0f}원 ({ret_pct:+.2f}%)\n\n"
            f"• 사유: {reason or '부분청산'}\n"
            f"• 매수평단: {fmt6(entry_price)}원\n"
            f"• 실매도가: {fmt6(exit_price_used)}원\n"
            f"• 체결수량: {executed:.6f}\n"
            f"• 매수금액: {est_entry_value:,.0f}원\n"
            f"• 청산금액: {est_exit_value:,.0f}원\n"
            f"• 수수료: {fee_total:,.0f}원\n"
            f"• 잔여수량: {remaining_volume:.6f}\n"
            f"===================================="
        )

        # 🔧 부분청산도 거래 기록에 추가 (경로 리포트 카운트용)
        if AUTO_LEARN_ENABLED and remaining_volume <= 1e-10:
            # 전량청산된 경우만 기록 (부분청산 후 전량청산 시)
            try:
                with _POSITION_LOCK:
                    pos_for_ts = OPEN_POSITIONS.get(m, {})
                hold_sec = time.time() - pos_for_ts.get("entry_ts", time.time())
                update_trade_result(m, exit_price_used, ret_pct / 100.0, hold_sec)
            except Exception as _e:
                print(f"[PARTIAL_TRADE_LOG_ERR] {_e}")

        return True, msg, executed

    except Exception as e:
        msg = f"[PARTIAL_SELL_ERR] {m}: {e}"
        print(msg)
        # 🔧 FIX: 최소주문금액 미만 → 매도 불가 찌꺼기, 메모리 포지션만 정리
        if "최소주문금액" in str(e) or "5000" in str(e):
            with _POSITION_LOCK:
                OPEN_POSITIONS.pop(m, None)
            tg_send_mid(f"🧹 {m} 부분청산 실패(최소주문금액) → 포지션 제거 처리")
            # 🔧 FIX: 리포트 카운트 증가
            if AUTO_LEARN_ENABLED:
                try:
                    update_trade_result(m, 0, 0, 0)
                except:
                    pass
        return False, msg, 0.0


def remonitor_until_close(m, entry_price, pre, tight_mode=False):
    """
    끝알람 이후 자동청산 신호가 나올 때까지 반복 모니터링
    🔧 FIX: 장기 보유 타임아웃 추가 (부분청산 후 정체 방지)
    """
    CYCLE_SEC = 300
    cycle = 0

    # 🔧 시간 기반 타임아웃 제거 - 가격 조건으로만 매도

    while True:
        cycle += 1
        print(f"[REMONITOR] {m} {cycle}회차 재모니터링 시작")

        # 🔧 부분청산 후 추가 하락 체크
        with _POSITION_LOCK:
            pos = OPEN_POSITIONS.get(m)
        if pos and pos.get("partial_done"):
            partial_price = pos.get("partial_price", 0)
            partial_type = pos.get("partial_type", "loss")

            # 현재가 조회
            try:
                cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
                cur_price = cur_js[0].get("trade_price", 0) if cur_js else 0
            except:
                cur_price = 0

            if cur_price > 0 and partial_price > 0:
                if partial_type == "profit":
                    # 익절 부분청산 후: -0.2% 추가 하락 OR 진입가 이하 → 청산
                    drop_from_partial = (partial_price - cur_price) / partial_price
                    if cur_price <= entry_price or drop_from_partial >= PARTIAL_EXIT_PROFIT_DROP:
                        reason = f"부분익절 후 추가하락 -{drop_from_partial*100:.2f}% 잔량청산"
                        print(f"[REMONITOR] {m} {reason} → 나머지 청산")
                        close_auto_position(m, reason)
                        return True
                else:
                    # 손절 부분청산 후: -0.1% 추가 하락 → 청산
                    drop_from_partial = (partial_price - cur_price) / partial_price
                    if drop_from_partial >= PARTIAL_EXIT_LOSS_DROP:
                        reason = f"부분손절 후 추가하락 -{drop_from_partial*100:.2f}% 잔량청산"
                        print(f"[REMONITOR] {m} {reason} → 나머지 청산")
                        close_auto_position(m, reason)
                        return True

        verdict, action, rationale, ret_pct, last_price, maxrun, maxdd = \
            monitor_position(
                m, entry_price, pre,
                tight_mode=tight_mode,
                horizon=CYCLE_SEC,
                reentry=True
            )

        should_close = False
        reason = verdict or action or "모니터링 종료"

        # 1) 급락 / 손절 권고
        if verdict and ("급락" in verdict or "손절" in verdict):
            should_close = True

        # 2) 전량 청산 권고
        elif action and "전량 청산 권고" in action:
            should_close = True

        # 3) 수익 실현:
        #    - 2.5% 이상: 전량 청산
        #    - 1.5% ~ 2.5%: 30% 부분익절(포지션당 1회)
        elif ret_pct is not None and ret_pct >= 2.5:
            should_close = True
            reason = f"수익실현 진입 후 +{ret_pct:.2f}% 달성 전량청산"

        elif ret_pct is not None and ret_pct >= 1.5:
            # 중간 구간: 30% 부분 수익실현 후 계속 보유
            ok, msg, executed = safe_partial_sell(
                m, sell_ratio=0.3, reason=f"진입 후 +{ret_pct:.2f}% 수익 달성 30% 부분익절")
            if ok and executed > 0:
                print(msg)
            # 부분익절 후에는 계속 재모니터링
            continue

        # 4) 컨텍스트 청산 권고는 → 청산 안 하고 계속 재모니터링
        elif verdict and verdict.startswith("청산 권고("):
            continue

        # 5) 부분 청산(50%) 권고 → 실제 50% 매도 후 계속 재모니터링
        elif action == "부분 청산(50%) 권고":
            ok, msg, executed = safe_partial_sell(m,
                                                  sell_ratio=0.5,
                                                  reason="모니터링 종료 시점 50% 부분청산")
            if ok and executed > 0:
                print(msg)
            continue

        # 6) 유지 권고 → 계속 재모니터링
        elif action == "유지 권고":
            continue

        # 7) 그냥 시간 만료면 → 다시 한 번 사이클
        elif verdict == "시간 만료(모니터링 종료)":
            continue

        if should_close:
            print(f"[REMONITOR] {m} 자동청산 조건 충족 → 청산 ({reason})")
            close_auto_position(m, reason)
            return True


