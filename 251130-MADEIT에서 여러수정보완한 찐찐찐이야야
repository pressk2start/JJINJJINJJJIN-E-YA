def detect_leader_stock(m, obc, c1, tight_mode=False):
    """
    하이브리드 진입 탐지 엔진:
      - Probe(소액): 완화된 early 흐름 감지 → 초기 염탐 진입
      - Confirm(추세): 강한 점화/매집/돌파 → 확정 진입
    """
    if len(c1) < 3:
        return None

    # 📊 볼린저 밴드 횡보 필터 (변동성 낮은 장 회피)
    if len(c1) >= 20:
        bb = bollinger_bands(c1, period=20, std_mult=2.0)
        if bb:
            bb_width = bb["bandwidth"]
            if bb_width < 0.025:  # 폭 2.5% 미만 → 횡보장 (2%→2.5% 강화, 이평수렴 차단)
                return None  # 진입 스킵

    # ★★★ 하락 추세 진입 차단: 종가가 EMA5 아래면 스킵 ★★★
    # (친구 조언: MA5 위로 복귀 전에는 롱 진입 금지)
    if len(c1) >= 5:
        cur_close = c1[-1]["trade_price"]
        ema5_val = ema_last([c["trade_price"] for c in c1], 5)
        if ema5_val and cur_close < ema5_val * 0.998:  # EMA5보다 0.2% 이상 아래면 스킵
            return None

    # ★★★ 강한 하락추세 롱 금지 (GRS 같은 역추세 probe 차단) ★★★
    # 3가지 조건 중 2개 이상 충족해야 롱 진입 허용
    # 1) 종가 > MA20  2) RSI > 45  3) +DI > -DI
    if len(c1) >= 20:
        cur_close = c1[-1]["trade_price"]
        closes = [c["trade_price"] for c in c1]
        ema20_val = ema_last(closes, 20)

        # RSI 계산 (간단 버전)
        rsi_val = None
        if len(c1) >= 14:
            gains, losses = [], []
            for i in range(-14, 0):
                diff = c1[i]["trade_price"] - c1[i-1]["trade_price"]
                if diff > 0:
                    gains.append(diff)
                else:
                    losses.append(abs(diff))
            avg_gain = sum(gains) / 14 if gains else 0
            avg_loss = sum(losses) / 14 if losses else 0.0001
            rs = avg_gain / avg_loss if avg_loss > 0 else 100
            rsi_val = 100 - (100 / (1 + rs))

        # DI 계산
        adx_data = adx_di(c1, period=14) if len(c1) >= 14 else None
        plus_di = adx_data.get("plus_di", 0) if adx_data else 0
        minus_di = adx_data.get("minus_di", 0) if adx_data else 0
        adx_val = adx_data.get("adx", 0) if adx_data else 0

        # 조건 체크
        cond_above_ma20 = (ema20_val and cur_close > ema20_val)
        cond_rsi_ok = (rsi_val and rsi_val > 45)
        cond_di_ok = (plus_di > minus_di)

        bullish_count = sum([cond_above_ma20, cond_rsi_ok, cond_di_ok])

        # ★ ADX >= 25 AND -DI >= +DI + 5면 롱 완전 금지 (강한 하락추세)
        if adx_val >= 25 and (minus_di - plus_di) >= 5:
            return None

        # ★ 2개 미만이면 롱 금지 (역추세 probe 차단)
        if bullish_count < 2:
            return None

    # === 동일 종목 중복 진입 방지 (probe 모드는 25초로 단축, 일반은 90초) ===
    cooldown_after_exit = 25 if ALWAYS_PROBE_FIRST else 90
    now_ts = time.time()

    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)

    if pos:
        last_add_ts  = pos.get("last_add_ts", 0.0)
        last_exit_ts = pos.get("last_exit_ts", 0.0)  # 모니터링 쪽에서 기록될 수 있음
        if (now_ts - max(last_add_ts, last_exit_ts)) < cooldown_after_exit:
            return None
    else:
        # 포지션이 없어도 최근 '청산 완료' 또는 '청산 시도(미체결 포함)'가 가까우면 스킵
        with _POSITION_LOCK:
            last_exit_done    = LAST_EXIT_AT.get(m, 0.0)
            last_exit_attempt = LAST_EXIT_ATTEMPT.get(m, 0.0)
        last_block = max(last_exit_done, last_exit_attempt)
        if (now_ts - last_block) < cooldown_after_exit:
            return None

    # === ★ PROBE_V2: 부드러운 우상향 포착 (트렌드/돌파/모멘텀) ===
    if PROBE_V2_ENABLED:
        obx = obc.get(m)
        if obx and probe_v2_prefilter(c1, obx):
            trigger_type = None
            if probe_v2_trigger_trend(c1):
                trigger_type = "C_TREND"
            elif probe_v2_trigger_breakout(c1):
                trigger_type = "A_BREAKOUT"
            elif probe_v2_trigger_momentum(c1):
                trigger_type = "B_MOMENTUM"

            if trigger_type:
                # 프로브 2.0 상태 추가
                probe_v2_add_state(m, trigger_type)

                # 틱 데이터 준비
                ticks_v2 = get_recent_ticks(m, 80)
                tape_v2 = micro_tape_stats_from_ticks(ticks_v2, 15) if ticks_v2 else {"n":0, "buy_ratio":0, "krw":0, "krw_per_sec":0}

                # change 계산
                price_change = 0.0
                if len(c1) >= 2:
                    price_change = (c1[-1]["trade_price"] / max(c1[-2]["trade_price"], 1) - 1)

                # volume_surge 계산
                current_volume = c1[-1].get("candle_acc_trade_volume", 0)
                avg_past = avg_past_volume(c1, n=5, field="candle_acc_trade_volume")
                volume_surge = current_volume / max(avg_past, 1) if avg_past > 0 else 1.0

                cut("PROBE_V2", f"{m} 프로브2.0 포착 → {trigger_type}")

                return {
                    "price": c1[-1]["trade_price"],
                    "change": price_change,
                    "current_volume": current_volume,
                    "volume_surge": volume_surge,
                    "ob": obx,
                    "ticks": ticks_v2,
                    "tape": tape_v2,
                    "early_ok": True,  # 트렌드형 probe
                    "probe_v2": True,  # PROBE_V2 플래그
                    "entry_mode": "probe"
                }

    # === ★ 계단식(그라인드) 상승: 최우선 분기 (confirm 직행) ===
    ticks_now = get_recent_ticks(m, 80)
    if grind_break_ok(c1, ticks_now):
        ob_l = obc.get(m)
        if ob_l and ob_l.get("depth_krw", 0) >= 12_000_000:
            cur_price = ticks_now[0]["trade_price"] if ticks_now else c1[-1]["trade_price"]
            price_change = 0.0
            volume_surge = 1.0
            if c1 and len(c1) >= 2:
                price_change = (c1[-1]["trade_price"] / max(c1[-2]["trade_price"], 1) - 1)
            if c1:
                current_volume = c1[-1].get("candle_acc_trade_volume", 0)
                avg_past = avg_past_volume(c1, n=5, field="candle_acc_trade_volume")
                if avg_past > 0 and current_volume > 0:
                    volume_surge = current_volume / max(avg_past, current_volume / 8, 1)

            t15_grind = micro_tape_stats_from_ticks(ticks_now, 15) if ticks_now else {"n":0, "buy_ratio":0, "krw":0, "krw_per_sec":0}

            cut("GRIND_BREAK", f"{m} 계단식 상승 포착 → confirm 직행 (매수비 {t15_grind.get('buy_ratio',0):.2f})")

            return {
                "price": cur_price,
                "change": price_change,
                "current_volume": current_volume if c1 else 0,
                "volume_surge": volume_surge,
                "ob": ob_l,
                "ticks": ticks_now or [],
                "tape": t15_grind,
                "early_ok": False,
                "ign_ok": False,
                "botacc_ok": False,
                "grind_break": True,  # ★ anti-peak 바이패스용
                "entry_mode": "confirm"  # ★ 계단식은 곧장 confirm
            }

    # === Micro-Probe: 초경량 즉시 찌르기 (가장 먼저 평가) ===
    if ticks_now:
        # ★ v2: 금액가중 buy ratio 사용
        t6 = micro_tape_stats_from_ticks_v2(ticks_now, 6, use_now_anchor=True, winsor_p=0.95)
        buy_ratio_6 = t6.get("buy_value_ratio", 0)
        if (
            t6["n"] >= 2 and                    # 체결 2개 이상 (3 → 2, 초완화)
            buy_ratio_6 >= 0.48 and             # 매수비 48%+ (금액가중, 0.50 → 0.48, 초완화)
            t6["krw_per_sec"] >= 8000 and       # 속도 8k KRW/s+ (4000 → 8000, 타이트)
            last_two_ticks_fresh(ticks_now) and
            uptick_streak_from_ticks(ticks_now, need=1)
        ):
            ob_l = obc.get(m)
            if ob_l and ob_l.get("depth_krw", 0) >= 3_000_000 and ob_l.get("spread", 999) <= 2.0:  # 5M → 3M, 1.5 → 2.0, 초완화
                # VWAP 과열 추격만 피하기
                vgap_mp = 0.0
                if c1:
                    v20 = vwap_from_candles_1m(c1, 20)
                    if v20:
                        vgap_mp = (ticks_now[0]["trade_price"]/v20 - 1.0)
                if vgap_mp <= 0.022:  # 0.018 → 0.022, 초완화
                    cut("MICRO_PROBE", f"{m} 초경량 찌르기 (매수비 {buy_ratio_6:.2f}, 속도 {t6['krw_per_sec']:.0f})")

                    # change와 volume_surge 계산
                    cur_price = ticks_now[0]["trade_price"]
                    price_change = 0.0
                    volume_surge = 1.0
                    if c1 and len(c1) >= 2:
                        price_change = (cur_price / max(c1[-2]["trade_price"], 1) - 1)
                    if c1:
                        current_volume = c1[-1].get("candle_acc_trade_volume", 0)
                        avg_past = avg_past_volume(c1, n=5, field="candle_acc_trade_volume")
                        if avg_past > 0 and current_volume > 0:
                            volume_surge = current_volume / max(avg_past, current_volume / 8, 1)

                    return {
                        "price": cur_price,
                        "change": price_change,
                        "volume_surge": volume_surge,
                        "current_volume": c1[-1].get("candle_acc_trade_volume", 0) if c1 else 0,
                        "ob": ob_l,
                        "ticks": ticks_now,
                        "tape": t6,
                        "early_ok": True,
                        "entry_mode": "probe"
                    }

    # === 틱 기반 초봉(10초) 선행 진입 시그널 (강화된 필터링) ===
    if not ticks_now:
        ticks_now = get_recent_ticks(m, 80)
    if ticks_now:
        # ★ v2: 금액가중 buy ratio 사용
        t10s = micro_tape_stats_from_ticks_v2(ticks_now, 10, use_now_anchor=True, winsor_p=0.95)
        t30s = micro_tape_stats_from_ticks_v2(ticks_now, 30, use_now_anchor=True, winsor_p=0.95)
        buy_ratio_10s = t10s.get("buy_value_ratio", 0)

        # 초입 신호 완화: 수직 초동 빠른 포착 (5→4틱, 18K→16K)
        sudden_burst = (
            t10s["krw_per_sec"] >= 2.0 * t30s["krw_per_sec"]  # 1.8 → 2.0 (더 강한 가속)
            and buy_ratio_10s >= 0.60  # 0.58 → 0.60 (금액가중, 더 강한 매수세)
            and t10s["n"] >= 4  # 5 → 4 (수직 초동 빠른 포착)
            and t10s["krw_per_sec"] >= 16000  # 18000 → 16000 (초동 허용 폭 확대)
        )

        fresh = uptick_streak_from_ticks(ticks_now, need=2)  # need=1 → need=2 (연속 상승 강화)

        if sudden_burst and fresh:
            cut("PROBE_TICK", f"{m} 틱 초입 감지 → probe 신호 (매수비 {buy_ratio_10s:.2f})")

            # change와 volume_surge 계산
            cur_price = ticks_now[0]["trade_price"]
            price_change = 0.0
            volume_surge = 1.0
            if c1 and len(c1) >= 2:
                price_change = (cur_price / max(c1[-2]["trade_price"], 1) - 1)
            if c1:
                current_volume = c1[-1].get("candle_acc_trade_volume", 0)
                avg_past = avg_past_volume(c1, n=5, field="candle_acc_trade_volume")
                if avg_past > 0 and current_volume > 0:
                    volume_surge = current_volume / max(avg_past, current_volume / 8, 1)

            pre = {
                "price": cur_price,
                "change": price_change,
                "volume_surge": volume_surge,
                "current_volume": c1[-1].get("candle_acc_trade_volume", 0) if c1 else 0,
                "ob": obc.get(m),
                "ticks": ticks_now,
                "tape": t10s,  # ← tape 추가 (final_check_leader 크래시 방지)
                "entry_mode": "probe",
                "early_ok": True,
            }
            return pre

    # === Probe-Lite: 가벼운 조건으로 초입 빈도 증가 ===
    if PROBE_LITE_ON:
        ticks_lite = ticks_now if ticks_now else get_recent_ticks(m, 80)
        ob_lite = obc.get(m)
        if ticks_lite and ob_lite and c1:
            # ★ v2: 금액가중 buy ratio 사용
            t10 = micro_tape_stats_from_ticks_v2(ticks_lite, 10, use_now_anchor=True, winsor_p=0.95)
            buy_ratio_lite = t10.get("buy_value_ratio", 0)
            vwap20 = vwap_from_candles_1m(c1, 20)
            vgap = (c1[-1]["trade_price"] / max(vwap20, 1) - 1.0) if vwap20 else 0.0

            # 오더북 최소 깊이 가드 추가 (허수 배제)
            if (ob_lite.get("depth_krw", 0) >= 8_000_000 and
                buy_ratio_lite >= PROBE_LITE_MIN_BUY and
                t10["krw_per_sec"] >= PROBE_LITE_MIN_KRWPSEC and
                uptick_streak_from_ticks(ticks_lite, need=1) and
                ob_lite.get("spread", 999) <= PROBE_LITE_MAX_SPREAD and
                abs(vgap) <= PROBE_LITE_MAX_VWAP_GAP):

                cut("PROBE_LITE", f"{m} probe-lite 신호 (매수비 {buy_ratio_lite:.2f}, 속도 {t10['krw_per_sec']:.0f})")

                # change와 volume_surge 계산
                cur_price = ticks_lite[0]["trade_price"]
                price_change = 0.0
                volume_surge = 1.0
                if c1 and len(c1) >= 2:
                    price_change = (cur_price / max(c1[-2]["trade_price"], 1) - 1)
                if c1:
                    current_volume = c1[-1].get("candle_acc_trade_volume", 0)
                    avg_past = avg_past_volume(c1, n=5, field="candle_acc_trade_volume")
                    if avg_past > 0 and current_volume > 0:
                        volume_surge = current_volume / max(avg_past, current_volume / 8, 1)

                return {
                    "price": cur_price,
                    "change": price_change,
                    "volume_surge": volume_surge,
                    "current_volume": c1[-1].get("candle_acc_trade_volume", 0) if c1 else 0,
                    "ob": ob_lite,
                    "ticks": ticks_lite,
                    "tape": t10,
                    "early_ok": True,
                    "entry_mode": "probe"
                }

    # (이하 기존 detect_leader_stock 코드 계속)

    ob = obc.get(m)
    if not ob or not isinstance(ob.get("raw"), dict):
        return None
    raw_units = (ob.get("raw") or {}).get("orderbook_units") or []  # ✅
    if not raw_units:  # ✅ 희귀 케이스 방지
        cut("BIDASK_WEAK", f"{m} missing orderbook units")
        return None
    if ob.get("depth_krw", 0) <= 0:
        return None

    # 🔵 점화/브레이크 판정 전 허수 펌프 컷 (새벽 허수 감소)
    cur = c1[-1]
    ticks = get_recent_ticks(m, 100)
    t30 = micro_tape_stats_from_ticks(ticks, 30) if ticks else {"n": 0, "krw": 0}
    if is_fake_pump(m, cur.get("candle_acc_trade_price", 0), cur["trade_price"], ob, t30, ticks=ticks, c1=c1):
        cut("FAKE_PUMP", f"{m} fake/illiquid")
        return None

    mega = is_mega_breakout(c1)
    th = get_dynamic_thresholds()
    cur, prev = c1[-1], c1[-2]
    price_change = (cur["trade_price"] / max(prev["trade_price"], 1) - 1)

    # 스프레드 컷
    if ob["spread"] > (MAX_SPREAD_FAST if mega else MAX_SPREAD_BASE):
        cut("SPREAD_HIGH", f"{m} spread {ob['spread']:.2f}%")
        return None

    # 거래량 조건
    current_volume = cur.get("candle_acc_trade_price", 0)
    if current_volume < MIN_VOLUME_KRW and not mega:
        cut("VOL_LOW", f"{m} vol {int(current_volume)}")
        return None

    # 거래 증가율 체크
    past_volumes = [c["candle_acc_trade_price"] for c in c1[-7:-2] if c["candle_acc_trade_price"] > 0]
    if not meets_volume_surge(current_volume, past_volumes) and not mega:
        ticks_tmp = get_recent_ticks(m, 100)
        t15_tmp = micro_tape_stats_from_ticks(ticks_tmp, 15)
        t45_tmp = micro_tape_stats_from_ticks(ticks_tmp, 45)
        if not (t15_tmp["krw_per_sec"] >= max(55_000, 1.15 * t45_tmp["krw_per_sec"])):
            cut("SURGE_LOW", f"{m} vol_surge_fail")
            return None

    # 약상승 컷
    if price_change < th["min_change"] and not mega:
        cut("PRICE_LOW", f"{m} {price_change*100:.2f}%")
        return None

    # 틱 확보
    ticks = get_recent_ticks(m, 100)
    if not ticks:
        cut("TICKS_LOW", f"{m} no ticks")
        return None

    # === 테이프·EMA 공통 지표 ===
    tape_stats = {k: micro_tape_stats_from_ticks(ticks, k) for k in [10, 15, 30, 45]}
    closes_1m = [x["trade_price"] for x in c1]
    ema5 = ema_last(closes_1m, 5) if closes_1m else None
    dist_ema5 = (cur["trade_price"] / ema5 - 1.0) if ema5 else 0.0
    t10, t15, t30, t45 = tape_stats[10], tape_stats[15], tape_stats[30], tape_stats[45]
    last_upticks_ok = uptick_streak_from_ticks(ticks, need=2)

    # === 점화/브레이크아웃 계열 ===
    ign_ok, ign_reason = ignition_trigger_ok(m, c1, ticks, ob)
    tick_break = tick_breakout_ok(m, c1, ticks, ob)
    ign_ok = ign_ok or tick_break

    botacc_ok, botacc_reason = bot_accum_trigger_ok(m, ticks, ob, c1)
    two_green_and_break = (
        sum(1 for c in c1[-3:] if c["trade_price"] > c["opening_price"]) >= 2
        and c1[-1]["high_price"] > max(c["high_price"] for c in c1[-4:-1])
    )

    # === Early (Probe) 진입 판단 ===
    r = relax_knob()
    twin = t15 if t15["krw_per_sec"] >= t45["krw_per_sec"] else t45
    vgap = (cur["trade_price"] / max(vwap_from_candles_1m(c1, 20), 1) - 1)
    turn = twin["krw"] / max(ob["depth_krw"], 1)
    flow_floor = int(EARLY_FLOW_MIN_KRWPSEC * (0.80 if r >= 1.0 else 1.0))

    # Early 조건: 그라인드형 포착 위해 완화
    early_conds = [
        vgap >= max(th["vwap_gap"] - 0.0003, EARLY_MIN_VWAP_GAP),
        vgap <= EARLY_MAX_VWAP_GAP,
        price_change <= 0.020,
        (ema5 is None) or (dist_ema5 <= EARLY_MAX_EMA5_GAP),
        twin["buy_ratio"] >= max(EARLY_MIN_BUY, 0.53),  # 0.55 → 0.53 (그라인드 대응)
        twin["krw_per_sec"] >= max(flow_floor, 16000),  # 절대 하한 16000
        turn >= max(EARLY_MIN_TURN, 0.018),  # 회전율
        twin["n"] >= max(EARLY_MIN_TICKS, 6),  # 8 → 6 (최소 틱 수 완화)
        last_two_ticks_fresh(ticks),
        uptick_streak_from_ticks(ticks, need=2),  # 연속 상승 2틱
    ]

    early_ok = all(early_conds)

    # === Confirm (확정 진입 판단) ===
    confirm_ok = (
        ign_ok or botacc_ok or mega or two_green_and_break
        or (early_ok and twin["buy_ratio"] >= 0.60 and uptick_streak_from_ticks(ticks, need=3))  # 0.58 → 0.60
    )

    # === Probe/Confirm 결과 ===
    if not (early_ok or confirm_ok):
        cut("NO_SIGNAL", f"{m} no entry cond")
        return None

    entry_mode = "confirm" if confirm_ok else "probe"

    # === 결과 패키징 ===
    pre = {
        "price": cur["trade_price"],
        "change": price_change,
        "current_volume": current_volume,
        "volume_surge": (current_volume / max(statistics.mean(past_volumes) if past_volumes else current_volume / 8, 1)),
        "ob": ob,
        "tape": twin,
        "ticks": ticks,
        "ema5_gap": dist_ema5,
        "ign_ok": ign_ok,
        "botacc_ok": botacc_ok,
        "two_green_break": two_green_and_break,
        "early_ok": early_ok,
        "entry_mode": entry_mode,
    }
    if mega:
        pre["mega_ok"] = True

    return pre

def final_check_leader(m, pre, tight_mode=False):
    # 안전 가드: tape 없으면 ticks로 즉석 계산
    if "tape" not in pre:
        ticks = pre.get("ticks") or []
        pre["tape"] = micro_tape_stats_from_ticks(ticks, 15) if ticks else {"n":0,"buy_ratio":0,"krw":0,"krw_per_sec":0}

    # ★★★ 꼭지 추격 금지 하드 게이트 (probe/confirm 공통)
    # ★ 강력 신호 시 바이패스: 수직 초동 포착 허용
    ticks = pre.get("ticks") or []
    if ticks:
        c1_now = get_minutes_candles(1, m, 20)
        if c1_now and len(c1_now) >= 14:
            cur = c1_now[-1]
            cur_price = cur["trade_price"]
            open_price = cur["opening_price"]
            high_price = cur["high_price"]

            # ATR 계산
            atr = atr14_from_candles(c1_now, 14)
            if not atr or atr <= 0:
                atr = cur_price * 0.006  # fallback

            # 장대양봉 체크
            body = abs(cur_price - open_price)

            # 상단 꼬리 체크
            upper_wick = high_price - max(cur_price, open_price)

            # VWAP 과열 체크
            vwap20 = vwap_from_candles_1m(c1_now, 20)
            if vwap20 and vwap20 > 0:
                vgap = (cur_price / vwap20 - 1.0)
            else:
                vgap = 0.0

            # 감속 체크 (t5 vs t15)
            t5 = micro_tape_stats_from_ticks(ticks, 5)
            t15 = micro_tape_stats_from_ticks(ticks, 15)
            speed_decel = (t5["krw_per_sec"] < 0.80 * max(t15["krw_per_sec"], 1))
            buy_decel = (t5["buy_ratio"] < t15["buy_ratio"] - 0.06)
            is_decel = (speed_decel or buy_decel)

            # ★ 강력 신호 바이패스: ign_ok/mega_ok/two_green_break/grind_break 시 anti-peak 미적용
            strong = (pre.get("ign_ok") or pre.get("mega_ok") or
                     pre.get("two_green_break") or pre.get("grind_break"))

            if strong:
                # 수직 초동은 추격 허용 (anti-peak 통과)
                pass
            else:
                # 일반 신호: 진짜 과열만 컷 (기준 완화)
                entry_mode = pre.get("entry_mode", "probe")
                is_vwap_hot = vgap >= (0.026 if entry_mode == "probe" else 0.022)  # 비교식 수정 (버그픽스)
                is_long_body = (body >= 1.10 * atr)  # 0.80→1.10 (더 확실한 장대양봉만)
                is_upper_wick = (upper_wick >= 0.60 * max(body, 1e-8))  # 0.40→0.60 (꼬리 큰 것만)

                # 꼭지 신호 종합
                if (is_vwap_hot or is_long_body or is_upper_wick or is_decel):
                    cut("PEAK_CHASE", f"{m} anti-peak (vgap={vgap:.3f}, body/atr={body/atr:.2f}, wick={is_upper_wick}, decel={is_decel})")
                    return None

            # ★★★ 추격 차단 필터 (친구 조언) - 완화 버전 ★★★
            # (1) EMA5 괴리 과다 차단: |가격-EMA5| >= 1.5% (1.2→1.5 완화)
            ema5_val = ema_last([c["trade_price"] for c in c1_now], 5)
            if ema5_val and ema5_val > 0:
                ema5_gap = abs(cur_price / ema5_val - 1.0)
                if ema5_gap >= 0.015:  # 1.5% 이상 괴리
                    cut("LATE_CHASE_EMA5", f"{m} EMA5 괴리 {ema5_gap*100:.2f}% >= 1.5% → 추격 차단")
                    return None

            # (2) 연속 양봉 과열 차단: 5봉 이상 연속 양봉 + 모멘텀 둔화 시에만
            # (강추세에서 연속 양봉은 정상이므로, 둔화 없으면 허용)
            green_streak = 0
            for c in reversed(c1_now[-7:]):
                if c["trade_price"] > c["opening_price"]:
                    green_streak += 1
                else:
                    break
            if green_streak >= 5 and is_decel:  # 연속 양봉 + 감속 시에만 차단
                cut("LATE_CHASE_STREAK", f"{m} 연속 양봉 {green_streak}개 + 모멘텀 둔화 → 소진 구간")
                return None

            # (3) 거래량 피크 후 감소 차단 - 삭제 (다른 필터로 충분)
            # recent_vols = [c["candle_acc_trade_volume"] for c in c1_now[-5:]]
            # if len(recent_vols) >= 3:
            #     peak_vol = max(recent_vols[:-1]) if len(recent_vols) > 1 else recent_vols[0]
            #     cur_vol = recent_vols[-1]
            #     if peak_vol > 0 and cur_vol < peak_vol * 0.6:
            #         cut("LATE_CHASE_VOL", f"{m} 거래량 피크 후 감소 → 추격 차단")
            #         return None

            # (4) 거래량 급증 후 5분 이내만 진입 허용 (3분→5분 완화)
            recent_vols = [c["candle_acc_trade_volume"] for c in c1_now[-6:]]  # 6봉으로 확장
            if len(recent_vols) >= 5:
                peak_idx = recent_vols.index(max(recent_vols))
                bars_since_peak = len(recent_vols) - 1 - peak_idx
                if bars_since_peak >= 5:  # 피크가 5봉 이상 전이면 늦음
                    cut("LATE_CHASE_TIME", f"{m} 거래량 피크가 {bars_since_peak}봉 전 → 5분 초과 추격 차단")
                    return None

    # === ★★ CONFIRM 음봉/상단꼬리 추가 필터 (confirm 전용 안전장치) ===
    if pre.get("entry_mode") == "confirm":
        c1_check = get_minutes_candles(1, m, 3)
        if c1_check and len(c1_check) >= 1:
            latest = c1_check[-1]
            cp = latest["trade_price"]
            op = latest["opening_price"]
            hp = latest["high_price"]

            # 음봉 체크 (종가 < 시가)
            is_red = (cp < op)

            # 상단 꼬리 체크 (ATR 대비 25% 이상)
            b = abs(cp - op)
            uw = hp - max(cp, op)
            atr_ref = atr14_from_candles(c1_check, min(14, len(c1_check))) or (cp * 0.006)
            has_wick = (uw >= 0.25 * atr_ref)

            if is_red or has_wick:
                reason = "음봉" if is_red else "상단꼬리"
                cut("CONFIRM_FILTER", f"{m} confirm {reason} 금지 (close={cp:.1f}, open={op:.1f}, wick={uw:.1f})")
                return None

    # 프로브는 소액 테스트 진입: 양질의 초입 신호만 포착 (적절한 필터링)
    if pre.get("entry_mode") == "probe":
        # ★★★ 음봉 거래량 폭발 필터: 매도세 우위 상황에서 probe 금지 ★★★
        c1_probe_check = get_minutes_candles(1, m, 20)
        if c1_probe_check and len(c1_probe_check) >= 5:
            latest = c1_probe_check[-1]
            cp = latest["trade_price"]
            op = latest["opening_price"]
            hp = latest["high_price"]
            lp = latest["low_price"]
            cur_vol = latest.get("candle_acc_trade_volume", 0)

            # 캔들 위치: (Close-Low)/(High-Low), 0=최저점, 1=최고점
            candle_range = hp - lp
            candle_pos = (cp - lp) / candle_range if candle_range > 0 else 0.5

            # 거래량 Z-score 계산 (최근 20봉 기준)
            vols = [c.get("candle_acc_trade_volume", 0) for c in c1_probe_check[-20:]]
            avg_vol = sum(vols) / len(vols) if vols else 1
            std_vol = (sum((v - avg_vol)**2 for v in vols) / len(vols))**0.5 if vols else 1
            vol_zscore = (cur_vol - avg_vol) / std_vol if std_vol > 0 else 0

            # ★ 음봉 거래량 폭발 차단: 캔들위치 <= 0.35 + 거래량 Z >= 1.5 → 매도세 우위
            is_bearish_spike = (candle_pos <= 0.35 and vol_zscore >= 1.5)

            # ★ 음봉 + 위꼬리 차단 (confirm과 동일)
            is_red = (cp < op)
            uw = hp - max(cp, op)
            body = abs(cp - op)
            has_big_wick = (body > 0 and uw > body * 0.8)  # 위꼬리가 몸통의 80% 이상

            if is_bearish_spike:
                cut("PROBE_BEARISH_SPIKE", f"{m} 음봉 거래량 폭발 (pos={candle_pos:.2f}, vol_z={vol_zscore:.1f}) → probe 차단")
                return None

            if is_red and has_big_wick:
                cut("PROBE_RED_WICK", f"{m} 음봉+위꼬리 (wick/body={uw/body:.1f}) → probe 차단")
                return None

            # ★★★ 상단 볼린저 추격 차단: 연속 양봉 + BB 상단 근처면 probe 금지 ★★★
            # (친구 조언: 상단밴드 접촉 + 연속 3봉 양봉이면 대기)
            bb_probe = bollinger_bands(c1_probe_check, period=20, std_mult=2.0)
            if bb_probe and bb_probe.get("upper"):
                upper_bb = bb_probe["upper"]
                price_bb_ratio = cp / upper_bb if upper_bb > 0 else 0

                # 연속 양봉 카운트
                green_count = 0
                for c in reversed(c1_probe_check[-5:]):
                    if c["trade_price"] > c["opening_price"]:
                        green_count += 1
                    else:
                        break

                # 가격이 상단 BB의 99% 이상 + 연속 양봉 3개 이상 → 과열 추격 차단
                if price_bb_ratio >= 0.99 and green_count >= 3:
                    cut("PROBE_UPPER_BB_CHASE", f"{m} 상단BB 추격 (BB비율={price_bb_ratio:.3f}, 연속양봉={green_count}) → probe 차단")
                    return None

        t = pre.get("tape", {"n":0,"buy_ratio":0,"krw":0})
        ob = pre.get("ob", {"depth_krw":0,"spread":99})

        # 실제 값 계산 (조건 체크에 사용)
        price_change = pre.get("change", 0.0)
        volume_surge = pre.get("volume_surge", 0.0)
        turn = t.get("krw") / max(ob.get("depth_krw"), 1)

        # ★ 거래량 폭발 시 매수비 강화: surge > 1.5x면 매수비 55% 이상 요구 (친구 조언)
        buy_ratio = t.get("buy_ratio", 0)
        min_buy_ratio = 0.55 if volume_surge >= 1.5 else 0.53

        # ★ 진입 조건 완화: 초입 빠르게 포착 (고점 물림 방지)
        if (t.get("n",0) >= 3 and                          # 3개 이상 틱 (4→3 완화)
            buy_ratio >= min_buy_ratio and                # 매수비 조건 (거래량폭발 시 강화)
            t.get("krw_per_sec",0) >= 10_000 and          # 거래속도 10,000원/초 이상 (14K→10K 완화)
            ob.get("depth_krw",0) >= 3_000_000 and        # 깊이 300만원 (유동성 확보)
            ob.get("spread",99) <= 1.2 and                # 스프레드 1.2% (✅ 크리티컬: 2.2→1.2 슬리피지 방지)
            abs(price_change) >= 0.0015):                 # ★ 최소 0.15% 가격 변동 (0.3→0.15 완화)

            return {
                "price": pre["price"],
                "chg": round(price_change * 100, 2),
                "current_volume": int(pre.get("current_volume", 0)),
                "volume_surge": round(volume_surge, 2),
                "buy": round(t.get("buy_ratio",0)*100,1),
                "n": t.get("n",0),
                "spread": round(ob.get("spread",0),2),
                "turn": round(turn * 100, 2)
            }
        return None  # 조건 미충족 시 진입 안 함

    # ★★★ 완화 노브 적용 (컨펌 신호만)
    r = relax_knob()
    t = pre["tape"]
    ob = pre["ob"]
    ticks = pre["ticks"]
    MIN_TURNOVER_LOCAL = max(0.018, _turn_needed(ob.get("depth_krw", 0)))  # 0.020 → 0.018
    if tight_mode:
        MIN_TURNOVER_LOCAL += 0.002  # 0.003 → 0.002
    if 0 <= now_kst().hour < 6:
        MIN_TURNOVER_LOCAL = max(0.018, MIN_TURNOVER_LOCAL - 0.004)
    MIN_TURNOVER_LOCAL = max(0.020, MIN_TURNOVER_LOCAL - 0.002 * r)  # ★ 추가

    TICKS_BUY_RATIO_LOCAL = max(
        0.55, TICKS_BUY_RATIO + (0.02 if tight_mode else 0.0))  # 0.56 → 0.55
    TICKS_BUY_RATIO_LOCAL = max(0.53,
                                TICKS_BUY_RATIO_LOCAL - 0.015 * r)  # 0.54 → 0.53 (최저치 보장)

    if t["n"] < MIN_TICKS_COUNT:
        cut("TICKS_LOW", f"{m} {t['n']}")
        return None
    turn = t["krw"] / max(ob["depth_krw"], 1)
    if turn < MIN_TURNOVER_LOCAL:
        cut("TURN_LOW", f"{m} turn {turn:.3f}")
        return None
    if t["buy_ratio"] < TICKS_BUY_RATIO_LOCAL:
        cut("BUY_WEAK", f"{m} buy {t['buy_ratio']:.2f}")
        return None
    if t["n"] >= 10 and t["buy_ratio"] < 0.63:
        cut("BUY_WEAK_MANYT", f"{m} weak many")
        return None
    if not last_two_ticks_fresh(ticks):
        cut("FRESH_FAIL", f"{m} stale")
        return None

    th = get_dynamic_thresholds()
    raw_units = (ob.get("raw") or {}).get("orderbook_units") or []  # ✅
    if not raw_units:
        cut("BIDASK_WEAK", f"{m} missing orderbook units")
        return None
    raw_ob = raw_units[:3]
    bid_sum = sum(u["bid_size"] * u["bid_price"] for u in raw_ob)
    ask_sum = sum(u["ask_size"] * u["ask_price"] for u in raw_ob)
    if bid_sum / max(ask_sum, 1) < th["bidask_min"]:
        cut("BIDASK_WEAK", f"{m} bidask weak")
        return None

    max_spread = MAX_SPREAD_FAST if t.get("rate",
                                          0) >= 0.7 else MAX_SPREAD_BASE
    if ob["spread"] > max_spread:
        cut("SPREAD_HIGH", f"{m} spread {ob['spread']:.2f}%")
        return None

    price_change = pre.get("change", 0.0)

    return {
        "price": pre["price"],
        "chg": round(price_change * 100, 2),
        "current_volume": int(pre["current_volume"]),
        "volume_surge": round(pre.get("volume_surge", 0.0), 2),
        "buy": round(t["buy_ratio"] * 100, 1),
        "n": t["n"],
        "spread": round(ob["spread"], 2),
        "turn": round((t['krw'] / max(ob['depth_krw'], 1)) * 100, 2)
    }


