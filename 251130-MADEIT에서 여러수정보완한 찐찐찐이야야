def micro_tape_stats_from_ticks(ticks, sec):
    if not ticks:
        return {
            "krw": 0,
            "n": 0,
            "buy_ratio": 0,
            "age": 999,
            "rate": 0,
            "krw_per_sec": 0
        }
    try:
        newest_ts = ticks[0]["timestamp"]
        cutoff = newest_ts - sec * 1000
    except:
        return {
            "krw": 0,
            "n": 0,
            "buy_ratio": 0,
            "age": 999,
            "rate": 0,
            "krw_per_sec": 0
        }

    n = 0
    krw = 0.0
    buys = 0
    oldest_ts = newest_ts
    for x in ticks:
        ts = x.get("timestamp", 0)
        if ts < cutoff:
            break
        p = x.get("trade_price", 0.0)
        v = x.get("trade_volume", 0.0)
        krw += p * v
        n += 1
        if x.get("ask_bid") == "BID": buys += 1
        if ts < oldest_ts: oldest_ts = ts

    if n == 0:
        return {
            "krw": 0,
            "n": 0,
            "buy_ratio": 0,
            "age": 999,
            "rate": 0,
            "krw_per_sec": 0
        }

    now_ms = int(time.time() * 1000)
    age = (now_ms - newest_ts) / 1000.0 if newest_ts else 999
    duration = max((newest_ts - (oldest_ts or newest_ts)) / 1000.0, 1.0)
    rate = n / duration
    krw_per_sec = krw / duration
    return {
        "krw": krw,
        "n": n,
        "buy_ratio": buys / n,
        "age": age,
        "rate": rate,
        "krw_per_sec": krw_per_sec
    }


def micro_tape_stats_from_ticks_v2(ticks, sec,
                                   use_now_anchor=True,
                                   winsor_p=0.95,
                                   min_ticks=0):
    """
    현재 시각 기준 + 금액 가중 Buy Ratio (밤사이 손실 방지)

    핵심 개선:
    - 현재 시각 기준 윈도우 (마지막 체결 시각이 오래되면 자동 약 신호)
    - 금액 가중 buy_value_ratio (큰손 유입 정확 포착)
    - winsor_p로 대형 체결 편향 완화

    반환:
      {
        "n": 틱개수, "age": 신선도(초),
        "rate": 초당틱수, "krw": 총거래대금, "krw_per_sec": 초당거래대금,
        "buy_count_ratio": 건수기반,
        "buy_value_ratio": 금액가중 (핵심!),
        "buy_vol_ratio": 수량가중,
        "total_val": 총거래대금, "total_vol": 총수량
      }
    """
    if not ticks:
        return {"n":0,"age":999,"rate":0,"krw":0,"krw_per_sec":0,
                "buy_count_ratio":0,"buy_value_ratio":0,"buy_vol_ratio":0,
                "buy_ratio":0,"total_val":0,"total_vol":0}

    try:
        now_ms = int(time.time()*1000)
        newest_ts = ticks[0].get("timestamp", now_ms)
    except:
        return {"n":0,"age":999,"rate":0,"krw":0,"krw_per_sec":0,
                "buy_count_ratio":0,"buy_value_ratio":0,"buy_vol_ratio":0,
                "buy_ratio":0,"total_val":0,"total_vol":0}

    # ★ 현재 시각 기준 윈도우 (마지막 체결이 오래되면 자동 약화)
    cutoff = (now_ms - sec*1000) if use_now_anchor else (newest_ts - sec*1000)

    # 창 내 틱 (오름차순 정렬: duration 계산용)
    win = [x for x in ticks if x.get("timestamp", 0) >= cutoff]
    if not win:
        age = (now_ms - newest_ts)/1000.0
        return {"n":0,"age":age,"rate":0,"krw":0,"krw_per_sec":0,
                "buy_count_ratio":0,"buy_value_ratio":0,"buy_vol_ratio":0,
                "buy_ratio":0,"total_val":0,"total_vol":0}

    win = sorted(win, key=lambda t: t.get("timestamp", 0))
    n = len(win)
    if min_ticks and n < min_ticks:
        age = (now_ms - win[-1]["timestamp"])/1000.0
        return {"n":n,"age":age,"rate":0,"krw":0,"krw_per_sec":0,
                "buy_count_ratio":0,"buy_value_ratio":0,"buy_vol_ratio":0,
                "buy_ratio":0,"total_val":0,"total_vol":0}

    duration = max((win[-1]["timestamp"] - win[0]["timestamp"])/1000.0, 1.0)
    age = (now_ms - win[-1]["timestamp"])/1000.0

    # Winsorize를 위한 pv 수집
    pvs = []
    for x in win:
        p = float(x.get("trade_price", 0.0))
        v = float(x.get("trade_volume", 0.0))
        pvs.append(p * v)

    # 상위 분위수 캡 (대형체결 한 방 편향 완화)
    pv_cap = None
    if pvs and 0.0 < (winsor_p or 0) < 1.0:
        pvs_sorted = sorted(pvs)
        idx = max(0, min(len(pvs_sorted)-1, int(len(pvs_sorted)*winsor_p)-1))
        pv_cap = pvs_sorted[idx]

    # 재합산
    total_val = 0.0; total_vol = 0.0
    buy_val = 0.0; buy_vol = 0.0; buys = 0
    krw_raw = 0.0
    buy_val_w = 0.0; total_val_w = 0.0

    for x in win:
        p = float(x.get("trade_price", 0.0))
        v = float(x.get("trade_volume", 0.0))
        pv = p * v
        krw_raw += pv
        total_val += pv
        total_vol += v

        # winsorized pv
        pv_w = min(pv, pv_cap) if pv_cap is not None else pv

        if x.get("ask_bid") == "BID":
            buys += 1
            buy_val += pv
            buy_vol += v
            buy_val_w += pv_w
        total_val_w += pv_w

    rate = n / duration
    krw_per_sec = krw_raw / duration

    buy_count_ratio = (buys / n) if n else 0.0
    buy_value_ratio = (buy_val_w / total_val_w) if total_val_w > 0 else 0.0
    buy_vol_ratio = (buy_vol / total_vol) if total_vol > 0 else 0.0

    # ★ 큰손 매수 감지 (Big Buy Detection)
    # 1회 체결량이 평균의 3배 이상 = 기관/세력 매수 신호
    avg_trade_val = total_val / n if n > 0 else 0
    big_buy_count = 0
    big_buy_total = 0.0
    BIG_BUY_MULT = 3.0  # 평균 대비 3배 이상이면 큰손

    for x in win:
        if x.get("ask_bid") == "BID":
            p = float(x.get("trade_price", 0.0))
            v = float(x.get("trade_volume", 0.0))
            pv = p * v
            if avg_trade_val > 0 and pv >= avg_trade_val * BIG_BUY_MULT:
                big_buy_count += 1
                big_buy_total += pv

    big_buy_detected = big_buy_count >= 1 and big_buy_total >= (total_val * 0.15)  # 큰손 매수가 전체의 15%+

    return {
        "n": n, "age": age, "rate": rate,
        "krw": krw_raw, "krw_per_sec": krw_per_sec,
        "buy_count_ratio": buy_count_ratio,
        "buy_value_ratio": buy_value_ratio,  # ★ 금액 가중 (핵심!)
        "buy_vol_ratio": buy_vol_ratio,
        "buy_ratio": buy_count_ratio,  # 호환성
        "total_val": total_val, "total_vol": total_vol,
        "big_buy_count": big_buy_count,  # ★ 큰손 매수 건수
        "big_buy_total": big_buy_total,  # ★ 큰손 매수 총액
        "big_buy_detected": big_buy_detected  # ★ 큰손 신호 감지 여부
    }


# ===== Bot Heuristics =====
def _pct(a, b):
    try:
        return abs(a / b - 1.0)
    except:
        return 0.0


def inter_arrival_stats(ticks, sec=30):
    if not ticks: return {"cv": 9.9, "count": 0}
    try:
        newest_ts = ticks[0]["timestamp"]
    except:
        return {"cv": 9.9, "count": 0}
    cutoff = newest_ts - sec * 1000
    ts = [x["timestamp"] for x in ticks if x["timestamp"] >= cutoff]
    ts = sorted(ts)
    if len(ts) < 4: return {"cv": 9.9, "count": len(ts)}
    gaps = [(b - a) / 1000.0 for a, b in zip(ts, ts[1:])]
    mu = sum(gaps) / len(gaps)
    if mu <= 0: return {"cv": 9.9, "count": len(ts)}
    var = sum((g - mu)**2 for g in gaps) / len(gaps)
    cv = (var**0.5) / mu
    return {"cv": cv, "count": len(ts)}


def price_band_std(ticks, sec=30):
    if not ticks: return 9.9
    try:
        newest_ts = ticks[0]["timestamp"]
    except:
        return 9.9
    cutoff = newest_ts - sec * 1000
    ps = [x["trade_price"] for x in ticks if x["timestamp"] >= cutoff]
    if len(ps) < 3: return 9.9
    m = sum(ps) / len(ps)
    var = sum((p - m)**2 for p in ps) / len(ps)
    std = (var**0.5) / max(m, 1)
    return std


def bot_pingpong_score(ticks, sec=20, band=BOT_PINGPONG_MAX_BAND):
    if not ticks: return 0.0
    try:
        newest_ts = ticks[0]["timestamp"]
    except:
        return 0.0
    cutoff = newest_ts - sec * 1000
    win = [x for x in reversed(ticks) if x["timestamp"] >= cutoff]
    if len(win) < 6: return 0.0
    prices = [x["trade_price"] for x in win]
    pr_min, pr_max = min(prices), max(prices)
    if _pct(pr_max, pr_min) > band:
        return 0.0
    alt = sum(1 for a, b in zip(win, win[1:])
              if a["ask_bid"] != b["ask_bid"]) / max(len(win) - 1, 1)
    return alt


def wash_trade_pattern(ticks, sec=30, repeats=BOT_WASH_REPEAT_VOL_N):
    if not ticks: return False
    try:
        newest_ts = ticks[0]["timestamp"]
    except:
        return False
    cutoff = newest_ts - sec * 1000
    vols = {}
    for x in ticks:
        if x["timestamp"] < cutoff: break
        v = round(x["trade_volume"], 6)
        vols[v] = vols.get(v, 0) + 1
    if not vols: return False
    top = max(vols.values())
    return top >= repeats


def bot_accum_trigger_ok(m, ticks, ob, c1):
    if not ticks or not ob or not c1: return (False, "BOTACC_INIT_FAIL")
    # ★ v2: 금액가중 buy ratio 사용
    t30 = micro_tape_stats_from_ticks_v2(ticks, 30, use_now_anchor=True, winsor_p=0.95)
    buy_ratio = t30.get("buy_value_ratio", 0)
    if not (BOT_ACCUM_MIN_BUY <= buy_ratio <= BOT_ACCUM_MAX_BUY):
        return (False, "BOTACC_BUY_RANGE")
    ia = inter_arrival_stats(ticks, 30)
    if ia["cv"] > BOT_TWAP_MAX_CV or ia["count"] < 6:
        return (False, "BOTACC_CV_LOWCOUNT")
    if price_band_std(ticks, 30) > BOT_TWAP_MAX_PSTD:
        return (False, "BOTACC_PSTD")
    if not uptick_streak_from_ticks(ticks, need=2):
        return (False, "BOTACC_NO_UPTICK")
    raw_units = (ob.get("raw") or {}).get("orderbook_units") or []
    if not raw_units:
        return (False, "BOTACC_OB_EMPTY")  # 오더북 유닛 없음 → 즉시 컷

    raw = raw_units[:3]
    bid = sum(u.get("bid_price", 0) * u.get("bid_size", 0) for u in raw)
    ask = sum(u.get("ask_price", 0) * u.get("ask_size", 0) for u in raw)
    if bid / max(ask, 1) < 1.10:
        return (False, "BOTACC_BIDASK_WEAK")

    cur = c1[-1]
    if cur["trade_price"] <= cur["opening_price"]:
        return (False, "BOTACC_NOT_GREEN")
    return (True, "BOTACC_OK")


def _win_stats(ticks, start_s, end_s):
    if not ticks:
        return {"n": 0, "buy_ratio": 0.0, "rate": 0.0, "krw_per_sec": 0.0}
    try:
        newest_ts = ticks[0]["timestamp"]
    except:
        return {"n": 0, "buy_ratio": 0.0, "rate": 0.0, "krw_per_sec": 0.0}
    lo = newest_ts - end_s * 1000
    hi = newest_ts - start_s * 1000
    win = [x for x in ticks if lo <= x.get("timestamp", 0) <= hi]
    if len(win) < 2:
        return {
            "n": len(win),
            "buy_ratio": 0.0,
            "rate": 0.0,
            "krw_per_sec": 0.0
        }
    win = sorted(win, key=lambda t: t["timestamp"])
    dur = max((win[-1]["timestamp"] - win[0]["timestamp"]) / 1000.0, 1.0)
    buys = sum(1 for x in win if x.get("ask_bid") == "BID")
    krw = sum(x["trade_price"] * x["trade_volume"] for x in win)
    return {
        "n": len(win),
        "buy_ratio": buys / max(len(win), 1),
        "rate": len(win) / dur,
        "krw_per_sec": krw / dur
    }


def buy_decay_flag(ticks):
    early = _win_stats(ticks, start_s=10, end_s=20)
    now = _win_stats(ticks, start_s=0, end_s=5)
    if early["n"] < 4 or now["n"] < 2:
        return False, {"early": early, "now": now}
    drop_buy = early["buy_ratio"] - now["buy_ratio"]
    cond = (drop_buy >= 0.12 and now["rate"] <= early["rate"] * 0.80
            and now["krw_per_sec"] <= early["krw_per_sec"] * 0.70)
    return cond, {"early": early, "now": now, "drop_buy": drop_buy}


