# === PATCH: grind detector ===
def grind_break_ok(c1, ticks):
    """계단식(그라인드) 상승 예외:
       - 최근 8봉 중 7봉 이상이 EMA5 위
       - 매수비(15s) >= 0.56
       - 체결간 간격 변동계수(CV, 30s) <= 0.95 (너무 고른 TWAP/봇 제외)
    """
    if len(c1) < 10 or not ticks:
        return False
    closes = [x["trade_price"] for x in c1]
    e5 = ema_series(closes, 5)
    last8 = list(zip(c1[-8:], e5[-8:]))
    above = sum(1 for c, e in last8 if c["trade_price"] >= e)
    ema_slope = (e5[-1] - e5[-4]) if len(e5) >= 4 else 0
    t15 = micro_tape_stats_from_ticks(ticks, 15)
    ia = inter_arrival_stats(ticks, 30)
    return (above >= 7 and ema_slope > 0 and t15.get("buy_ratio", 0) >= 0.56
            and ia.get("cv", 9.9) <= 0.95)


def uptrend_lock_ok(c1, ticks):
    """
    EMA/VWAP/테이프 기반 상승추세 확인
    - EMA8 > EMA21, 현재가 > EMA8
    - 현재가 > VWAP
    - 15초 테이프가 30초 대비 유지 + 매수비 56% 이상
    """
    if not c1 or not ticks:
        return False
    closes = [x["trade_price"] for x in c1]
    if len(closes) < 21:
        return False

    ema8  = ema_last(closes, 8)
    ema21 = ema_last(closes, 21)
    vwap  = vwap_from_candles_1m(c1, 20)
    t15   = micro_tape_stats_from_ticks(ticks, 15)
    t30   = micro_tape_stats_from_ticks(ticks, 30)

    slope_ok = (ema8 is not None and ema21 is not None and ema8 > ema21 and (closes[-1] > ema8))
    vwap_ok  = (vwap and closes[-1] > vwap)
    tape_ok  = (t15["krw_per_sec"] >= max(15000, 0.75 * t30["krw_per_sec"]) and t15["buy_ratio"] >= 0.56)

    return slope_ok and vwap_ok and tape_ok


