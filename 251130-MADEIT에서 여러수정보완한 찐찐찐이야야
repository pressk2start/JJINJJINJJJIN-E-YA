def open_auto_position(m, pre, dyn_stop, eff_sl_pct, *, override_krw=None):
    """
    초입·공격모드 대응 자동 매수 진입
    Args:
        override_krw: 프로브 금액 오버라이드 (글로벌 변경 방지)
    """
    if not AUTO_TRADE:
        return

    if not UPBIT_ACCESS_KEY or not UPBIT_SECRET_KEY:
        print("[AUTO] API 키 미설정 → 자동매수 스킵")
        return

    # ★ 중복 진입 방지 (PENDING + POSITION 동시 체크)
    with _PENDING_LOCK:
        if m in PENDING_ENTRY:
            print(f"[AUTO] {m} 이미 진입 처리 중 → 스킵")
            return
        with _POSITION_LOCK:
            if m in OPEN_POSITIONS:
                print(f"[AUTO] 이미 {m} 포지션 보유중 → 신규 진입 스킵")
                return
        PENDING_ENTRY.add(m)  # 진입 시작 표시

    # 보유 종목 상한
    with _POSITION_LOCK:
        open_cnt = sum(1 for v in OPEN_POSITIONS.values() if v.get("volume", 0) > 0)
    if open_cnt >= MAX_OPEN_POSITIONS:
        msg = f"[AUTO] 보유 상한 {MAX_OPEN_POSITIONS}개 도달 → {m} 신규 진입 스킵"
        print(msg)
        tg_send_mid(msg)
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    signal_price = pre.get("price")
    # ★ 가격 0/None 방어 (비정상 신호 차단)
    if not signal_price or signal_price <= 0:
        print(f"[AUTO] {m} pre['price'] 비정상({signal_price}) → 진입 스킵")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    # === 하이브리드 진입모드 반영 ===
    entry_mode = pre.get("entry_mode", "confirm")

    # ✅ ALWAYS_PROBE_FIRST: 첫 진입은 무조건 probe (7000원)
    if ALWAYS_PROBE_FIRST:
        entry_mode = "probe"

    if entry_mode == "probe":
        entry_fraction = 0.1   # (참고) 계산은 하되, 실제 주문금액은 PROBE_KRW로 강제
        mode_emoji = "🧭"
    elif entry_mode == "confirm":
        entry_fraction = 1.0
        mode_emoji = "🔥"
    else:
        entry_fraction = 1.0
        mode_emoji = "🤖"

    # ★ 가격 가드: probe/confirm 분리 (수직 초동 추격 허용 폭 확대)
    if entry_mode == "probe":
        max_drift = 0.030 if AGGRESSIVE_MODE else 0.018  # 3.0% / 1.8% (초동 추격 허용)
    else:
        max_drift = 0.020 if AGGRESSIVE_MODE else 0.012  # 2.0% / 1.2% (confirm 추격 허용)

    ok_guard, current_price = final_price_guard(m, signal_price, max_drift=max_drift)
    if not ok_guard:
        tg_send(
            f"⚠️ <b>진입 취소</b> {m}\n"
            f"• 신호가: {fmt_price(signal_price)}원\n"
            f"• 현재가: {fmt_price(current_price)}원\n"
            f"• 상승률: {((current_price / signal_price - 1) * 100):.2f}%\n"
            f"• 사유: 가격 급등 (초입 추격 위험)"
        )
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    # === 과열 추격 방지: VWAP/EMA5/BB 과열이면 차단 또는 강등 ===
    try:
        c1m = get_minutes_candles(1, m, 20)
        vwap20 = vwap_from_candles_1m(c1m, 20)
        ema5_now = ema_last([c["trade_price"] for c in c1m], 5)
        vgap = (current_price / max(vwap20, 1) - 1.0) if vwap20 else 0.0
        egap = (current_price / max(ema5_now, 1) - 1.0) if ema5_now else 0.0

        # ★ 볼린저 밴드 상단 체크 (확장 끝 추격 차단)
        bb = bollinger_bands(c1m, period=20, std_mult=2.0)
        bb_upper = bb["upper"] if bb else current_price * 1.02
        bb_exceed = (current_price > bb_upper * 1.001)  # 상단 0.1% 초과

        # ★ 거래량 추세 체크 (둔화 시 진입 금지)
        if len(c1m) >= 4:
            vol_recent = sum(c["candle_acc_trade_volume"] for c in c1m[-2:]) / 2  # 최근 2봉 평균
            vol_prev = sum(c["candle_acc_trade_volume"] for c in c1m[-4:-2]) / 2  # 직전 2봉 평균
            vol_declining = (vol_recent < vol_prev * 0.7)  # 30% 이상 감소
        else:
            vol_declining = False

        # ★★★ 추세-가속 모드 (Trend Boost): ADX 강할 때 BB 필터 우회 ★★★
        adx_entry = adx_di(c1m, period=14)
        trend_boost = False
        if adx_entry:
            adx_val = adx_entry.get("adx", 0)
            plus_di = adx_entry.get("plus_di", 0)
            minus_di = adx_entry.get("minus_di", 0)
            # ADX > 25 & +DI 우위 >= 8 → 진짜 추세 돌파 (BB 상단 초과해도 진입 허용)
            trend_boost = (adx_val > 25 and (plus_di - minus_di) >= 8)
            if trend_boost:
                print(f"[TREND_BOOST] {m} ADX={adx_val:.1f}, +DI-DI={plus_di-minus_di:.1f} → BB필터 우회")

    except Exception:
        vgap = egap = 0.0
        bb_exceed = False
        vol_declining = False
        trend_boost = False
        adx_entry = None  # ★ 크리티컬: 예외 시 명시적 초기화 (NameError 방지)

    # ★ 초강추세 판정 (거래량둔화도 우회할 정도로 강한 추세)
    # ADX > 30 & +DI 우위 >= 12 → "거래량 잠깐 줄어도 괜찮은" 수준
    super_trend_boost = False
    if adx_entry:
        adx_val = adx_entry.get("adx", 0)
        plus_di = adx_entry.get("plus_di", 0)
        minus_di = adx_entry.get("minus_di", 0)
        super_trend_boost = (adx_val > 30 and (plus_di - minus_di) >= 12)
        if super_trend_boost and vol_declining:
            print(f"[SUPER_TREND] {m} ADX={adx_val:.1f}, +DI-DI={plus_di-minus_di:.1f} → 거래량둔화 우회")

    # ★ BB 상단 초과 or 거래량 둔화 → 완전 차단 (단, 초강추세에서는 거래량둔화도 우회)
    if vol_declining and not super_trend_boost:
        # 거래량 둔화 차단 (초강추세 아니면)
        print(f"[EXPANSION_END] {m} 거래량둔화 → 진입 완전 차단")
        tg_send_mid(f"⛔ {m} 거래량둔화 → 진입 차단")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return
    elif vol_declining and super_trend_boost:
        # 초강추세면 거래량둔화 무시하고 probe로 진입
        if entry_mode == "confirm":
            entry_mode = "probe"
            entry_fraction = 0.10
            mode_emoji = "💪"  # 초강추세 진입
        print(f"[SUPER_TREND_ENTRY] {m} 거래량둔화지만 초강추세 → probe로 진입 허용")
    elif bb_exceed and not trend_boost:
        # BB 초과는 추세-가속 모드가 아닐 때만 차단
        print(f"[EXPANSION_END] {m} BB상단초과 → 진입 완전 차단 (꼭지 추격 방지)")
        tg_send_mid(f"⛔ {m} BB상단초과 → 진입 차단")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return
    elif bb_exceed and trend_boost:
        # 추세-가속 모드 + BB 초과 → probe로 강등해서 진입 (손절 타이트하게)
        if entry_mode == "confirm":
            entry_mode = "probe"
            entry_fraction = 0.10
            mode_emoji = "🚀"  # 추세 부스트 진입
            print(f"[TREND_BOOST_ENTRY] {m} BB초과지만 강추세 → probe로 진입 허용")

    # VWAP/EMA5 과열 → confirm→probe 강등
    if entry_mode == "confirm" and (vgap >= 0.018 or egap >= 0.022):
        entry_mode = "probe"
        entry_fraction = 0.10
        mode_emoji = "🧭"
        print(f"[OVERHEAT] {m} 과열 추격 방지: confirm→probe 강등 (vgap={vgap:.3f}, egap={egap:.3f})")

    # ★★★ 거리 게이트 (Late Entry Gate): 끝자락 추격 방지 ★★★
    try:
        # MA10 대비 이격 체크
        ema10_now = ema_last([c["trade_price"] for c in c1m], 10)
        ma10_gap = (current_price / max(ema10_now, 1) - 1.0) if ema10_now else 0.0

        # BB %b 체크 (밴드 내 위치: 0=하단, 0.5=중간, 1=상단)
        bb_percent_b = 0.5
        if bb and bb.get("upper") and bb.get("lower"):
            bb_range = bb["upper"] - bb["lower"]
            if bb_range > 0:
                bb_percent_b = (current_price - bb["lower"]) / bb_range

        # ★★★ 극단 과매수: BB %b > 0.95 + 강추세 아니면 차단 ★★★
        # (강추세=trend_boost면 밴드워크 가능 → 허용)
        if bb_percent_b > 0.95 and not trend_boost:
            print(f"[EXTREME_OVERBOUGHT] {m} BB %b={bb_percent_b:.2f} > 0.95 (약추세) → 꼭대기 추격 차단")
            tg_send_mid(f"🔥 {m} 극단 과매수(BB%b={bb_percent_b:.2f}) → 진입 차단")
            with _PENDING_LOCK:
                PENDING_ENTRY.discard(m)
            return
        elif bb_percent_b > 0.95 and trend_boost:
            print(f"[BAND_WALK] {m} BB %b={bb_percent_b:.2f} but 강추세 → 밴드워크 허용")

        # ATR 대비 이격 체크
        atr_entry = atr14_from_candles(c1m, 14) if len(c1m) >= 14 else None
        atr_gap_ratio = (current_price - ema10_now) / atr_entry if (atr_entry and ema10_now and atr_entry > 0) else 0

        # 늦은 진입 판정: MA10 이격 > 0.8% AND BB %b > 0.85 AND ATR 이격 > 0.5
        late_entry = (ma10_gap > 0.008 and bb_percent_b > 0.85 and atr_gap_ratio > 0.5)

        if late_entry and not trend_boost:
            # 추세-가속 모드가 아니면 늦은 진입 차단
            print(f"[LATE_ENTRY] {m} 끝자락 추격 차단 (MA10이격={ma10_gap*100:.2f}%, BB%b={bb_percent_b:.2f}, ATR이격={atr_gap_ratio:.2f})")
            tg_send_mid(f"⏰ {m} 끝자락 추격 차단 → 눌림 대기")
            with _PENDING_LOCK:
                PENDING_ENTRY.discard(m)
            return
        elif late_entry and trend_boost:
            # 추세-가속 모드면 경고만 하고 probe로 진입
            if entry_mode == "confirm":
                entry_mode = "probe"
                entry_fraction = 0.10
                mode_emoji = "⏰"
            print(f"[LATE_ENTRY_WARN] {m} 늦은 진입이지만 강추세 → probe 허용 (MA10={ma10_gap*100:.2f}%, BB%b={bb_percent_b:.2f})")
    except Exception as e:
        print(f"[LATE_ENTRY_ERR] {m}: {e}")

    # === 계좌 & 주문금액 계산 ===
    accounts = get_account_info()
    if not accounts:
        print("[AUTO] 계좌 조회 실패 → 스킵")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    krw_bal = 0.0
    for a in accounts:
        if a.get("currency") == "KRW":
            krw_bal = float(a.get("balance", "0"))
            break

    if krw_bal < 6000:
        print(f"[AUTO] KRW 부족 ({krw_bal:,.0f}) → 스킵")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    entry_price = current_price
    stop_price = dyn_stop

    # 📊 리스크/리워드 사전검증 (구조적으로 불리한 진입 차단)
    try:
        c1_rr = get_minutes_candles(1, m, 20)
        atr_value = atr14_from_candles(c1_rr, 14) if c1_rr else None
        if atr_value and atr_value > 0 and stop_price > 0:
            expected_loss = entry_price - stop_price
            expected_profit = atr_value * 1.3  # ATR의 1.3배를 목표로 설정 (보수적)
            rr_ratio = expected_profit / expected_loss if expected_loss > 0 else 0

            # ✅ 개선: probe도 RR 검증 적용 (probe 1.2+, confirm 1.5+)
            rr_threshold = 1.2 if entry_mode == "probe" else 1.5
            if rr_ratio < rr_threshold:
                print(f"[RR_FILTER] {m} RR비율 {rr_ratio:.2f} < {rr_threshold} ({entry_mode}) → 진입 차단")
                tg_send_mid(f"⚠️ {m} RR비율 {rr_ratio:.2f} 불리 → 진입 스킵 ({entry_mode})")
                with _PENDING_LOCK:
                    PENDING_ENTRY.discard(m)
                return
    except Exception as e:
        # RR 계산 실패 시 무시하고 진행
        print(f"[RR_CALC_ERR] {m}: {e}")

    # ✅ 최근 승률 기반 동적 리스크
    adaptive_risk = get_adaptive_risk()

    # === 하이브리드 진입 구조 ===
    risk_to_use = adaptive_risk * SEED_RISK_FRACTION if USE_PYRAMIDING else adaptive_risk
    risk_to_use *= entry_fraction  # probe는 리스크 축소 반영

    base_qty = calc_position_size(
        entry_price,
        stop_price,
        krw_bal,
        risk_to_use,
    )

    # ★ 안전가드: 포지션 사이즈 0이면 진입 스킵 (비정상 손절가 등)
    if base_qty <= 0 and entry_mode != "probe":
        print(f"[AUTO] {m} 포지션 사이즈 0 (손절폭 부족) → 진입 스킵")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    if entry_mode == "probe":
        # ✅ 염탐은 항상 고정 최소금액으로만
        # override_krw가 있으면 우선 사용 (글로벌 변경 방지)
        probe_krw = override_krw if override_krw is not None else PROBE_KRW
        krw_to_use = min(krw_bal, max(5000, probe_krw))
    else:
        # ★ 찌꺼기 방지: 0.2% headroom 추가 (수수료 0.05% + 슬리피지)
        raw_krw = base_qty * entry_price
        usable_krw = krw_bal * 0.998  # 99.8% 사용
        krw_to_use = min(usable_krw, raw_krw)

    krw_to_use = int(krw_to_use)  # 정수 변환

    if krw_to_use < 5000:
        print(f"[AUTO] 주문금액 {krw_to_use:,.0f}원 < 5,000원 → 스킵")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)
        return

    # === 매수 ===
    try:
        res = place_market_buy(m, krw_to_use)
        print("[AUTO_BUY_RES]", json.dumps(res, ensure_ascii=False))  # ★추가
        oid = res.get("uuid") if isinstance(res, dict) else None
        od = get_order_result(oid, timeout_sec=6) if oid else None
        print("[AUTO_BUY_ORDER]", json.dumps(od, ensure_ascii=False))  # ★추가

        if od:
            volume_filled = float(od.get("executed_volume") or "0")
        else:
            volume_filled = 0.0

        if volume_filled <= 0:
            msg = f"[AUTO] {m} 자동매수 체결 0 → 포지션 생성 안 함"
            print(msg)
            tg_send(f"⚠️ {msg}")
            with _PENDING_LOCK:
                PENDING_ENTRY.discard(m)
            return

        # 평균가 계산
        trades = od.get("trades") or []
        if trades:
            total_krw = sum(float(tr["price"]) * float(tr["volume"]) for tr in trades)
            total_vol = sum(float(tr["volume"]) for tr in trades)
            avg_price = total_krw / total_vol if total_vol > 0 else entry_price
        else:
            avg_price = float(entry_price)  # 명시적 float

    except requests.HTTPError as e:
        body = getattr(e.response, "text", "")
        print("[AUTO BUY ERR]", e, body)
        tg_send(f"⚠️ 매수 실패 {m}\n{e}\n{body}")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)  # ★ 실패 시 pending 해제
        return
    except Exception as e:
        print("[AUTO BUY ERR]", e)
        tg_send(f"⚠️ 매수 실패 {m}\n{e}")
        with _PENDING_LOCK:
            PENDING_ENTRY.discard(m)  # ★ 실패 시 pending 해제
        return

    # === 포지션 저장 ===
    with _POSITION_LOCK:
        OPEN_POSITIONS[m] = {
            "entry_price": avg_price,
            "volume": volume_filled,
            "stop": stop_price,
            "sl_pct": eff_sl_pct,
            "state": "open",
            "last_add_ts": 0.0,
            "entry_mode": entry_mode,
            "adds": 0,                 # ✅ 추매 횟수 카운터
        }

    # ★ 진입 완료 → pending 해제
    with _PENDING_LOCK:
        PENDING_ENTRY.discard(m)

    # ★ 찌꺼기 KRW 체크 (100원 미만은 정상 범위)
    try:
        accounts_after = get_account_info()
        if accounts_after:
            for a in accounts_after:
                if a.get("currency") == "KRW":
                    remaining_krw = float(a.get("balance", "0"))
                    if 0 < remaining_krw < 100:
                        print(f"[AUTO] {m} 매수 후 KRW 찌꺼기: {remaining_krw:.0f}원 (정상 범위, 무시)")
                    break
    except Exception:
        pass

    slip_pct = (avg_price / signal_price - 1.0) if signal_price else 0.0

    tg_send(
        f"{mode_emoji} <b>자동매수 체결 ({entry_mode})</b> {m}\n"
        f"• 신호가: {fmt_price(signal_price)}원\n"
        f"• 체결가: {fmt_price(avg_price)}원\n"
        f"• 슬리피지: {slip_pct*100:+.3f}%\n"
        f"• 주문금액: {krw_to_use:,.0f}원\n"
        f"• 수량: {volume_filled:.6f}\n"
        f"• 손절가: {fmt_price(stop_price)}원\n"
        f"{link_for(m)}"
    )

def add_auto_position(m, cur_price, override_krw=None):
    """
    이미 seed 포지션이 있을 때, 강한 추세에서 1회 추매(add) 수행
    - ADD_RISK_FRACTION 비율만큼 RISK_PER_TRADE를 다시 사용
    - 평균단가 재계산

    Args:
        override_krw: 추매 금액 강제 지정 (프로브 2.0 등에서 사용)
    """
    if not AUTO_TRADE:
        return False, None

    if not UPBIT_ACCESS_KEY or not UPBIT_SECRET_KEY:
        return False, None

    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if not pos or pos.get("volume", 0) <= 0:
            return False, None
        if pos.get("adds", 0) >= MAX_ADDS:
            # 추매 최대 횟수 도달
            return False, None
        # ★★★ 크리티컬: 동시 추매 차단 (adding 플래그) ★★★
        if pos.get("adding"):
            print(f"[AUTO_ADD] {m} 이미 adding 중 → 스킵")
            return False, None
        last_add_ts = pos.get("last_add_ts", 0.0)
        adds_count = pos.get("adds", 0)  # ★ 추매 횟수 (차등 비율용)
        # ✅ adding 플래그 즉시 세팅
        pos["adding"] = True
        OPEN_POSITIONS[m] = pos

    now = time.time()
    if (now - last_add_ts) < PYRAMID_ADD_COOLDOWN_SEC:
        # 쿨다운 실패 시 adding 해제
        with _POSITION_LOCK:
            pos2 = OPEN_POSITIONS.get(m)
            if pos2:
                pos2["adding"] = False
        return False, None

    # ★ 잔고 사용 전역 락 (동시성 경합 방지)
    with _FUNDS_LOCK:
        accounts = get_account_info()
        if not accounts:
            print("[AUTO_ADD] 계좌 조회 실패")
            return False, None

        krw_bal = 0.0
        actual_coin_vol = 0.0
        currency = m.split("-")[1] if "-" in m else ""
        for a in accounts:
            if a.get("currency") == "KRW":
                krw_bal = float(a.get("balance", "0"))
            elif a.get("currency") == currency:
                actual_coin_vol = float(a.get("balance", "0"))

        # ★★★ 유령 포지션 방지: 실제 코인 잔량 체크 (추매 전 필수)
        actual_coin_krw = actual_coin_vol * cur_price
        if actual_coin_krw < 5000:
            print(f"[AUTO_ADD_GHOST] {m} 실제 잔량 {actual_coin_vol:.8f} ({actual_coin_krw:.0f}원) < 5000원 → 유령포지션 정리")
            with _POSITION_LOCK:
                OPEN_POSITIONS.pop(m, None)
                LAST_EXIT_AT[m] = time.time()
            return False, None

        # ★ 헤드룸 적용: 수수료+여유 0.2% 차감 (0.7→0.2 찌꺼기 최소화)
        SAFE_HEADROOM = 0.002
        usable_krw = max(0, int(krw_bal * (1 - SAFE_HEADROOM)))

        if usable_krw < 6000:
            print(f"[AUTO_ADD] 가용 KRW 부족({usable_krw:,.0f}) → 추매 스킵")
            return False, None

        entry_price_old = pos["entry_price"]
        stop_price = pos["stop"]

        # ★ override_krw가 지정되면 그 금액 사용, 아니면 리스크 기반 계산
        if override_krw is not None:
            want_krw = int(override_krw)
            qty_theoretical = None  # override 모드에서는 이론수량 계산 안 함
        else:
            # ★★★ 추매 차등 비율: 리스크 축소 (1차 0.5%, 2차 이상 사용 안 함)
            if adds_count == 0:  # 1차 추매 (probe→confirm 전환)
                add_risk_pct = 0.005  # 0.5% (0.8→0.5 리스크 축소)
            elif adds_count == 1:  # 2차 추매 (MAX_ADDS=1이므로 사용 안 됨)
                add_risk_pct = 0.004  # 0.4% (사용 안 함)
            else:  # 3차 이상 (사용 안 됨)
                add_risk_pct = 0.003  # 0.3% (사용 안 함)

            qty_theoretical = calc_position_size(cur_price, stop_price, krw_bal, add_risk_pct)
            want_krw = int(qty_theoretical * cur_price) if qty_theoretical else 0

        krw_to_use = min(usable_krw, want_krw)

        # ★ 최소 금액 5100원 (수수료 헤드룸 포함)
        if krw_to_use < 5100:
            print(f"[AUTO_ADD] 주문 금액 {krw_to_use:,.0f}원 < 5,100원 → 스킵")
            return False, None

        krw_to_use = int(krw_to_use)

        # ★ NameError 방지: override 모드에서는 이론수량 출력 생략
        if qty_theoretical is not None:
            print(f"[AUTO_ADD] {m} 추매 시도: {krw_to_use:,.0f} KRW (이론수량≈{qty_theoretical:.6f}, 현재가 {cur_price:,.0f})")
        else:
            print(f"[AUTO_ADD] {m} 추매 시도: {krw_to_use:,.0f} KRW (고정금액, 현재가 {cur_price:,.0f})")

        volume_filled = 0.0
        avg_price_add = cur_price

        try:
            res = place_market_buy(m, krw_to_use)
            order_uuid = res.get("uuid") if isinstance(res, dict) else None
            od = get_order_result(order_uuid, timeout_sec=15.0) if order_uuid else None  # ★ 6→15초 연장

            if od:
                try:
                    volume_filled = float(od.get("executed_volume") or "0")
                except Exception:
                    volume_filled = 0.0

                trades = od.get("trades") or []
                if trades and volume_filled > 0:
                    total_krw = 0.0
                    total_vol = 0.0
                    for tr in trades:
                        p = float(tr.get("price", "0"))
                        v = float(tr.get("volume", "0"))
                        total_krw += p * v
                        total_vol += v
                    if total_vol > 0:
                        avg_price_add = total_krw / total_vol
                else:
                    if volume_filled > 0:
                        avg_price_add = krw_to_use / volume_filled

            if volume_filled <= 0:
                msg = f"[AUTO_ADD] {m} 추매 체결 0 → 무시"
                print(msg)
                tg_send(f"⚠️ {msg}")
                return False, None

        except requests.HTTPError as e:
            # ★ HTTP 400 상세 사유 로깅
            status = getattr(e.response, "status_code", None)
            body = ""
            try:
                body = e.response.text
            except Exception:
                pass
            reason = body[:300] if body else str(e)
            print(f"[AUTO_ADD HTTP {status}]", reason)
            tg_send(f"⚠️ <b>추매 실패 (HTTP {status})</b> {m}\n{reason}")
            # ★ adding 플래그 해제
            with _POSITION_LOCK:
                pos_err = OPEN_POSITIONS.get(m)
                if pos_err:
                    pos_err["adding"] = False
            return False, None
        except Exception as e:
            print("[AUTO_ADD ERR]", e)
            tg_send(f"⚠️ <b>추매 실패</b> {m}\n사유: {e}")
            # ★ adding 플래그 해제
            with _POSITION_LOCK:
                pos_err = OPEN_POSITIONS.get(m)
                if pos_err:
                    pos_err["adding"] = False
            return False, None

    # 평균단가 갱신
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if not pos:
            return False, None
        old_vol = pos.get("volume", 0.0)
        new_vol = old_vol + volume_filled
        if new_vol <= 0:
            pos["adding"] = False  # ★ adding 플래그 해제
            return False, None
        new_entry_price = (entry_price_old * old_vol + avg_price_add * volume_filled) / new_vol

        pos["entry_price"] = new_entry_price
        pos["volume"] = new_vol
        pos["adds"] = pos.get("adds", 0) + 1     # ✅ 누적 추매회수
        pos["last_add_ts"] = time.time()
        pos["last_add_price"] = avg_price_add   # ★ 추매 검증용
        pos["last_add_volume"] = volume_filled  # ★ 추매 롤백용
        pos["entry_mode"] = "confirm"
        pos["added"] = True                      # (하위호환용, 다른 곳에서 참조할 수도 있으니 유지)
        pos["adding"] = False                    # ★ adding 플래그 해제

    # 추매 금액 계산 및 차수 표시
    add_krw_amount = avg_price_add * volume_filled
    current_adds = pos.get("adds", 0)  # 방금 업데이트된 값 (1, 2, 3, ...)

    # 비율 매핑 (표시용, 품질 우선)
    # ✅ 크리티컬: 실제 리스크와 일치 (0.8%→0.5%)
    risk_pct_map = {1: "0.5%", 2: "0.4%"}
    risk_label = risk_pct_map.get(current_adds, "0.3%")

    # ★ 찌꺼기 KRW 체크 (100원 미만은 정상 범위)
    try:
        accounts_after = get_account_info()
        if accounts_after:
            for a in accounts_after:
                if a.get("currency") == "KRW":
                    remaining_krw = float(a.get("balance", "0"))
                    if 0 < remaining_krw < 100:
                        print(f"[AUTO_ADD] {m} 추매 후 KRW 찌꺼기: {remaining_krw:.0f}원 (정상 범위, 무시)")
                    break
    except Exception:
        pass

    tg_send(
        f"📈 <b>추매 체결 ({current_adds}차 - {risk_label})</b> {m}\n"
        f"• 추가 체결가: {fmt_price(avg_price_add)}원\n"
        f"• 추가 수량: {volume_filled:.6f}\n"
        f"• 추가 금액: {add_krw_amount:,.0f}원\n"
        f"• 총 수량: {new_vol:.6f}\n"
        f"• 새로운 평단: {fmt_price(new_entry_price)}원\n"
        f"{link_for(m)}"
    )

    return True, new_entry_price

