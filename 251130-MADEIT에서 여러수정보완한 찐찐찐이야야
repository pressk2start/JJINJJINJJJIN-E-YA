                tg_send(f"⚠️ 매수 실패 {m}\n{e}")
                with _POSITION_LOCK:
                    OPEN_POSITIONS.pop(m, None)
                return

        # === 포지션 저장 ===
        with _POSITION_LOCK:
            OPEN_POSITIONS[m] = {
