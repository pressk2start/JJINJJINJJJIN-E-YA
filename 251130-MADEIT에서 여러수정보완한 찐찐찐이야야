        try:
            server = HTTPServer(("0.0.0.0", p), HealthHandler)
            thread = threading.Thread(target=server.serve_forever, daemon=True)
            thread.start()
            print(f"🏥 Health check server: http://localhost:{p}/health")
            return
        except OSError:
            continue
    print("[HEALTH_ERR] 포트 사용 불가 (8080~8084)")

