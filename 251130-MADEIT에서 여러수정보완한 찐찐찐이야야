from collections import deque


def postcheck_6s(m, pre):
    # 🔧 틱버스트는 항상 포스트체크 적용 (6초 재확인)
    is_tick_burst = pre.get("detect_type") == "tick_burst"

    if not POSTCHECK_ENABLED and not is_tick_burst:
        return True, "SKIP"
    if pre.get("ign_ok") or pre.get("two_green_break") or pre.get(
            "mega_ok", False):
        return True, "BYPASS_STRONG_BREAK"

    # 🔧 틱버스트용 포스트체크 시작 로그
    if is_tick_burst:
        print(f"[TICK_POSTCHECK] {m} 틱버스트 6초 재확인 시작")

    # ★★★ 장세/야간 완화 노브
    r = relax_knob()
    pc_min_buy = max(0.46, POSTCHECK_MIN_BUY - 0.05 * r)   # 0.48 -> 0.46, 완화폭 살짝↑
    pc_min_rate = max(0.14, POSTCHECK_MIN_RATE - 0.09 * r) # 0.16 -> 0.14
    pc_max_pstd = POSTCHECK_MAX_PSTD + 0.0005 * r          # 살짝 더 관대
    pc_max_cv = POSTCHECK_MAX_CV + 0.18 * r
    pc_max_dd = POSTCHECK_MAX_DD + 0.005 * r

    window = POSTCHECK_WINDOW_SEC
    start = time.time()
    acc = deque(maxlen=400)  # 누수 방지
    seen = set()  # 중복 차단

    last_fetch = 0.0
    net_calls = 0  # ★ 이번 postcheck에서 실제 네트워크 호출 횟수
    # 밤에는 조금 느슨, 주간엔 약간 빠르게
    fetch_interval = 2.0 if (0 <= now_kst().hour < 6) else 1.6
    ok_streak = 0

    base_price = pre["price"]
    peak = base_price
    trough_after_peak = base_price  # 피크 이후 최저가 추적

    # ★★★ 여기 한 줄 추가 (postcheck 중 최대 허용 급등)
    # 🔥 틱버스트는 더 보수적으로 (1.0%), 일반 경로는 1.5%
    MAX_SURGE = 0.010 if is_tick_burst else 0.015

    while True:
        now = time.time()
        if now - start > window:
            break

        # 캐시 재사용 + 네트워크 호출 횟수 제한
        if (now - last_fetch >= fetch_interval) and (net_calls < 2):
            # 최대 2번까지만 실제 API 호출
            ticks = get_recent_ticks(m, 100, allow_network=True)
            last_fetch = now
            net_calls += 1
        else:
            # 나머지는 캐시만 사용
            ticks = get_recent_ticks(m, 100, allow_network=False)

        if not ticks:
            time.sleep(0.45)
            continue

        # acc에 최신 틱만 중복없이 축적
        # 🔧 FIX: appendleft → append (ticks[:12]가 이미 최신→과거 순서)
        for x in ticks[:12]:
            key = (x.get("timestamp"), x.get("trade_price"),
                   x.get("trade_volume"))
            if key in seen:
                continue
            seen.add(key)
            acc.append(x)  # ✅ 최신이 index 0 유지

        curp = ticks[0].get("trade_price", base_price)

        # ★★★ 가격 급등 컷 추가
        if base_price > 0:
            surge = (curp / base_price - 1.0)
            if surge >= MAX_SURGE:
                return False, f"SURGE_IN_POST({surge*100:.2f}%)"

        if curp > peak:
            peak = curp
            trough_after_peak = curp  # 새 피크가 생기면 트로프 리셋
        else:
            trough_after_peak = min(trough_after_peak, curp)

        # ✔ DD는 피크 대비 하락률(음수)로 체크
        dd = (curp / peak - 1.0)

        t10 = micro_tape_stats_from_ticks(list(acc), 10)
        ia = inter_arrival_stats(list(acc), 20)
        pstd = price_band_std(list(acc), 20)

        # ★ 가변 임계치 적용
        pass_now = (t10["buy_ratio"] >= pc_min_buy
                    and t10["rate"] >= pc_min_rate and pstd <= pc_max_pstd
                    and ia["cv"] <= pc_max_cv and dd >= -pc_max_dd)

        if pass_now:
            ok_streak += 1
            if ok_streak >= 2:
                return True, "OK_EARLY"
        else:
            ok_streak = 0

        # 틱이 충분히 느리면 슬립을 더 길게
        time.sleep(0.6 if t10["rate"] >= 0.6 else 1.0)

    if not acc:
        return False, "POST_NO_TICKS"

    # 종료 시점 재평가 (acc 기반으로 피크/트로프 계산)
    prices = [x.get("trade_price", base_price) for x in list(acc)]
    if prices:
        peak2 = max(prices + [base_price])
        curp2 = prices[0]
        dd2 = (curp2 / peak2 - 1.0)
    else:
        dd2 = 0.0

    t10 = micro_tape_stats_from_ticks(list(acc), 10)
    ia = inter_arrival_stats(list(acc), 20)
    pstd = price_band_std(list(acc), 20)

    # ★ 최종 판정도 가변 임계치로
    if t10["buy_ratio"] < pc_min_buy:
        return False, f"BUY_LOW({t10['buy_ratio']:.2f})"
    if t10["rate"] < pc_min_rate: return False, f"RATE_LOW({t10['rate']:.2f})"
    if pstd > pc_max_pstd: return False, f"PSTD_HIGH({pstd:.4f})"
    if ia["cv"] > pc_max_cv: return False, f"CV_HIGH({ia['cv']:.2f})"
    if dd2 < -pc_max_dd: return False, f"DD_TOO_DEEP({dd2:.4f})"
    return True, "OK"

# =========================
# 🎯 틱 기반 손절 헬퍼 함수
# =========================
def upbit_tick_size(price: float) -> float:
    """업비트 KRW 마켓 호가 단위 (보수적: 100~1000원 구간은 1원)"""
    p = float(price)
    if p >= 2_000_000: return 1000.0
    if p >= 1_000_000: return 500.0
    if p >=   500_000: return 100.0
    if p >=   100_000: return 50.0
    if p >=    10_000: return 10.0
    if p >=     1_000: return 5.0
    if p >=       100: return 1.0    # 보수적 (일부 종목 0.1원이지만 1원으로)
    if p >=        10: return 0.1
    if p >=         1: return 0.01
    return 0.001

def round_to_tick(px: float, tick: float) -> float:
    """가격을 틱 단위로 내림"""
    return math.floor(px / tick) * tick

def ticks_between(a: float, b: float, tick: float) -> int:
    """두 가격 사이 틱 수"""
    return int(abs(a - b) / max(tick, 1e-12) + 1e-9)

def compute_tick_distance(cur_price: float, c1: list, ob: dict) -> int:
    """
    시장 컨텍스트 기반 필요 틱 간격 계산
    - 스프레드 틱수 + 여유
    - ATR 기반 틱수
    - 최소 틱수
    """
    tick = upbit_tick_size(cur_price)

    # 스프레드(절대값) → 틱수
    spread_ticks = 0
    try:
        if ob and "raw" in ob:
            u0 = ob["raw"]["orderbook_units"][0]
            ask, bid = float(u0["ask_price"]), float(u0["bid_price"])
            spread_abs = max(ask - bid, 0.0)
            spread_ticks = int(math.ceil(spread_abs / max(tick, 1e-12))) if spread_abs > 0 else 0
    except:
        pass

    # ATR → 틱수
    atr_ticks = 0
    try:
        atr = atr14_from_candles(c1, 14) if c1 else 0.0
        if atr and atr > 0:
            atr_ticks = int(math.ceil((atr * ATR_TICKS_MULT) / max(tick, 1e-12)))
    except:
        pass

    # 최대값 사용
    base_ticks = max(MIN_TICK_DIST, spread_ticks + SPREAD_TICKS_PAD, atr_ticks)
    return int(base_ticks)


# =========================
# 동적 손절 (% 기반, 틱스탑 백업용)
# =========================
def dynamic_stop_loss(entry_price, c1, signal_type=None, current_price=None):
    atr = atr14_from_candles(c1, ATR_PERIOD)
    if not atr or atr <= 0:
        return entry_price * (1 - STOP_LOSS_PCT), STOP_LOSS_PCT, None

    base_pct = (atr / max(entry_price, 1)) * ATR_MULT
    pct = min(max(base_pct, DYN_SL_MIN), DYN_SL_MAX)  # 자동튜닝 값 그대로 적용

    # 🚀 신호 유형별 완화
    if signal_type in ("early", "ign", "mega"):
        pct *= 1.3

    # 💎 익절 중이면 손절폭 더 완화 (눌림 방지)
    if current_price and current_price > entry_price * 1.008:
        pct *= 1.5  # 수익 중에는 SL을 더 멀리 둠

    # ATR 상세 (텔레그램용)
    atr_info = f"ATR{atr:.0f}x{ATR_MULT}={base_pct*100:.2f}%"
    return entry_price * (1 - pct), pct, atr_info

# =========================
# 컨텍스트 기반 청산 점수
# =========================
def context_exit_score(m, ticks, ob_depth_krw, entry_price, last_price, c1):
    """
    휘핑 방지형 컨텍스트 점수:
    - 단일 신호로 청산 유도 금지 (복합 조건 누적)
    - 추세 역전(EMA5/VWAP 이탈 + uptick 부재) 쪽에 가중치
    """
    score = 0
    reasons = []

    # 테이프 변화
    w_now = _win_stats(ticks, 0, 10)
    w_early = _win_stats(ticks, 10, 30)
    decay, _ = buy_decay_flag(ticks)

    if w_now["krw_per_sec"] < w_early["krw_per_sec"] * 0.60:
        score += 1
        reasons.append("FLOW_DROP")
    if not uptick_streak_from_ticks(ticks, need=2):
        score += 1
        reasons.append("NO_UPTICK")
    if w_now["rate"] < 0.25:  # 너무 느리면 1점
        score += 1
        reasons.append("RATE_SLOW")

    # 가격/컨텍스트
    vwap = vwap_from_candles_1m(c1, 20) if c1 else 0
    ema5 = ema_last([x["trade_price"] for x in c1], 5) if c1 else 0
    if vwap and last_price < vwap:
        score += 1
        reasons.append("VWAP_LOSS")
    if ema5 and last_price < ema5:
        score += 1
        reasons.append("EMA5_LOSS")

    # 💎 약상승/횡보 시 청산 점수 완화
    gain_now = (last_price / entry_price - 1.0)
    if -0.004 <= gain_now <= 0.008:  # 완화 범위 확대
        score = max(0, score - 1)
        reasons.append("MILD_GAIN_RELAX")

    # 수익 구간에서의 급감
    if last_price > entry_price * 1.008 and decay:
        score += 1
        reasons.append("DECAY_AFTER_GAIN")

    return score, reasons

# =========================
# ★ 모니터링 시간 결정 (신규 추가)
# =========================
def decide_monitor_secs(pre: dict, tight_mode: bool = False) -> int:
    """
    포지션 모니터링 총 시간(초)을 상황별로 결정.
    - early_ok: 비교적 짧게 추세 확인
    - ignition_ok / mega_ok: 상대적으로 길게 (추세 이어질 가능성)
    - 시장 모드(TIGHT), 야간, BTC 모멘텀, 오더북 깊이 등에 따라 가/감
    """
    try:
        r = relax_knob()  # 0.0 ~ 1.5
    except Exception:
        r = 0.0

    base = 150  # 기본값

    # 신호 유형 가중
    if pre.get("mega_ok"):
        base = 300
    elif pre.get("ign_ok"):
        base = 240
    elif pre.get("botacc_ok"):
        base = 210
    elif pre.get("early_ok"):
        base = 180
    elif pre.get("two_green_break"):
        base = 210

    # 오더북 깊이 기반 (깊으면 여유 있게)
    ob_depth = 0
    try:
        ob_depth = pre.get("ob", {}).get("depth_krw", 0) or 0
    except Exception:
        pass
    if ob_depth >= 30_000_000:
        base += 30
    elif ob_depth <= 6_000_000:
        base -= 30

    # BTC 5분 모멘텀
    try:
        b5 = btc_5m_change()
    except Exception:
        b5 = 0.0
    if b5 >= 0.006:
        base += 30
    elif b5 <= -0.008:
        base -= 30

    # 야간(00~06 KST)엔 흔들림 대비 약간 단축
    h = now_kst().hour
    if 0 <= h < 6:
        base -= 15

    # 장세 완화 노브 반영
    base += int(10 * r)

    # 타이트 모드(급락 방어)면 단축
    if tight_mode:
        base -= 30

    # 하한/상한 클램프
    base = max(90, min(base, 360))
    return int(base)


# =========================
# 끝알람 권고 생성 (END RECO)
# =========================
def _end_reco(entry_price, last_price, c1, ticks, ob_depth_krw, ctx_thr=3):
    """
    끝알람용 권고 생성:
      - 수익/손실, 컨텍스트, 테이프 흐름 종합으로
        👉 유지 / 부분청산 / 전량청산 세 가지 액션 제안
    """
    try:
        ret_pct = ((last_price / entry_price - 1.0) - FEE_RATE) * 100.0
    except:
        ret_pct = 0.0

    # 컨텍스트 스코어(추세역전 신호들)
    try:
        ctx_score, ctx_reasons = context_exit_score(
            "KRW-XXX",
            ticks or [],
            ob_depth_krw or 10_000_000,
            entry_price,
            last_price,
            c1 or [],
        )
    except Exception:
        ctx_score, ctx_reasons = (0, [])

    # 테이프(최근 15s)
    t15 = micro_tape_stats_from_ticks(ticks or [], 15)
    buy = t15.get("buy_ratio", 0.0)
    n = t15.get("n", 0)

    # 컨텍스트(EMA5 / VWAP)
    vwap = vwap_from_candles_1m(c1 or [], 20) if c1 else 0
    ema5 = ema_last([x["trade_price"] for x in (c1 or [])], 5) if c1 else 0
    vwap_ok = bool(vwap and last_price >= vwap)
    ema_ok = bool(ema5 and last_price >= ema5)

    # 💎 거래 둔화 + 약상승 → 본절 익절 유도
    if -0.2 <= ret_pct <= 0.4 and t15.get("krw_per_sec", 0) < 12000 and ctx_score <= ctx_thr:
        action = "부분 청산(본절)"
        rationale = f"거래둔화 구간 본절 익절 ({ret_pct:+.2f}%)"
        return action, rationale

    # -----------------------------
    # 1) 전량 청산 권고 조건 (강한 청산)
    # -----------------------------
    full_exit = False
    why_full = []

    # (1) 손실이 많이 커졌을 때
    if ret_pct <= -2.0:
        full_exit = True
        why_full.append(f"손실 {ret_pct:+.2f}%")

    # (2) 컨텍스트 스코어가 임계치보다 많이 높고, VWAP/EMA도 깨져 있을 때
    if ctx_score >= (ctx_thr + 1) and not vwap_ok and not ema_ok:
        full_exit = True
        why_full.append(f"컨텍스트 {ctx_score}/{ctx_thr}")

    # (3) 약손실 상태에서 매수세·테이프가 많이 죽은 경우
    if ret_pct < -0.8 and buy < 0.50 and n >= 4:
        full_exit = True
        why_full.append(f"매수비 {buy*100:.1f}% / 틱 {n}")

    if full_exit:
        action = "전량 청산 권고"
        rationale = " · ".join(why_full) if why_full else "리스크 우위"
        return action, rationale

    # -----------------------------
    # 2) 부분 청산 권고 (애매/경고 구간)
    # -----------------------------
    partial_exit = False
    why_partial = []

    # 수익이 크지 않은 구간
    if -0.8 < ret_pct < 0.8:
        partial_exit = True
        why_partial.append(f"수익 {ret_pct:+.2f}%")

    # 컨텍스트 경고 레벨
    if ctx_score == ctx_thr:
        partial_exit = True
        why_partial.append(f"컨텍스트 경고 {ctx_score}/{ctx_thr}")

    # 매수비 약하고 틱은 많은 경우
    if buy < 0.55 and n >= 6:
        partial_exit = True
        why_partial.append(f"매수비 {buy*100:.1f}% / 틱 {n}")

    # 🚀 거래둔화 시 자동 부분익절 권고
    if ret_pct >= 1.5 and t15["krw_per_sec"] < 15000:
        partial_exit = True
        why_partial.append(f"거래속도 둔화 {t15['krw_per_sec']:.0f} KRW/s")

    # VWAP/EMA 둘 다 하방일 때
    if not vwap_ok and not ema_ok:
        partial_exit = True
        why_partial.append("VWAP·EMA5 하방")

    if partial_exit:
        action = "부분 청산(50%) 권고"
        rationale = " · ".join(why_partial) if why_partial else "불확실 구간"
        return action, rationale

    # -----------------------------
    # 3) 유지 권고 (추세 유지)
    # -----------------------------
    why_keep = [f"수익 {ret_pct:+.2f}%"]
    if vwap_ok:
        why_keep.append("VWAP 상방")
    if ema_ok:
        why_keep.append("EMA5 상방")
    if buy >= 0.60 and n >= 4:
        why_keep.append(f"매수비 {buy*100:.1f}% / 틱 {n}")

    rationale = " · ".join(why_keep)
    return "유지 권고", rationale


# =========================
# 모니터링(최종형)
# =========================
def monitor_position(m,
                     entry_price,
                     pre,
                     tight_mode=False,
                     horizon=None,
                     reentry=False):
    c1 = get_minutes_candles(1, m, 20)
    base_stop, eff_sl_pct, atr_info = dynamic_stop_loss(entry_price, c1)

    # horizon이 안 들어오면 자동 결정, 들어오면 그 값 사용
    if horizon is None:
        horizon = decide_monitor_secs(pre, tight_mode=tight_mode)
    start_ts = time.time()
    MAX_RUNTIME = horizon * 1.5  # 최대 허용 실행시간 (정상시간의 1.5배)


    # 디바운스/트레일 상태
    # 손절 디바운스용
    stop_first_seen_ts = 0.0
    stop_hits = 0
    # 컨텍스트 청산 디바운스용
    ctx_first_seen_ts = 0.0
    ctx_hits = 0

    trail_armed = False
    trail_stop = 0.0

    # 스파이크/그레이스 기존 로직 재활용
    consecutive_failures = 0
    MAX_CONSECUTIVE_FAILURES = 10
    grace_used = False
    spike_recovery_used = False

    ob = pre.get("ob")
    ob_depth_default = ob.get("depth_krw", 10_000_000) if ob else 10_000_000

    last_price = entry_price
    best = entry_price
    worst = entry_price

    # 실제 보유 수량 확보 (익절 시 매도용)
    with _POSITION_LOCK:
        entry_volume = OPEN_POSITIONS.get(m, {}).get("volume", 0.0)

    verdict = None
    outcome_extra = ""

    # === 🎯 얇은 수익 체크포인트 상태 ===
    checkpoint_reached = False   # 얇은 수익(0.3%) 도달 여부
    strong_mode = False          # 강세 확인 후 트레일링 모드
    strong_peak = entry_price    # 강세 모드 진입 후 고점 추적

    # === 포지션 모드 (probe / confirm) ===
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m, {})
    entry_mode = pos.get("entry_mode", "confirm")

    # === 🎯 틱 기반 트레일링 스탑 상태 ===
    tick_stop_armed = False
    tick_sz = upbit_tick_size(entry_price)
    tick_base = MIN_TICK_DIST  # 초기 틱 간격
    trail_stop_px = entry_price - tick_base * tick_sz  # 초기 스탑가
    tick_stop_hits = 0
    tick_stop_first_seen = 0.0
    last_ob_fetch = 0.0
    last_best_bid = None

    # 🔧 CV 기반 틱스탑 디바운스 조정
    # 봇 느낌(CV 낮음)이면 더 오래 확인, 사람 싸움(CV 높음)이면 빠르게
    try:
        init_ticks = get_recent_ticks(m, 100)
        ia30 = inter_arrival_stats(init_ticks, 30) if init_ticks else {"cv": 1.0}
        cv = ia30.get("cv", 1.0)
        debounce_sec = TICK_STOP_DEBOUNCE_SEC
        debounce_n = TICK_STOP_DEBOUNCE_N
        if cv <= 0.45:
            # 봇 가능성 → 더 엄격하게
            debounce_sec += 1.0
            debounce_n += 1
            tick_base = max(tick_base, MIN_TICK_DIST + 2)
            print(f"[CV_ADJ] {m} cv={cv:.2f} (봇 의심) → debounce↑, tick_base↑")
        elif cv >= 1.2:
            # 사람 싸움 → 빠르게 반응
            debounce_sec = max(1.5, debounce_sec - 0.5)
            print(f"[CV_ADJ] {m} cv={cv:.2f} (변동성↑) → debounce↓")
    except Exception:
        debounce_sec = TICK_STOP_DEBOUNCE_SEC
        debounce_n = TICK_STOP_DEBOUNCE_N

    # === 🎯 스파이크 반락 퀵컷 상태 ===
    spike_window = 4.0
    spike_check_start = time.time()

    try:
        while time.time() - start_ts <= horizon:
            time.sleep(RECHECK_SEC)

            ticks = get_recent_ticks(m, 100)
            if not ticks or len(ticks) < 3:
                consecutive_failures += 1
                if consecutive_failures >= MAX_CONSECUTIVE_FAILURES:
                    time.sleep(3)
                    ticks = get_recent_ticks(m, 100)
                    if not ticks:
                        verdict = "데이터 수신 실패"
                        break
                    consecutive_failures = 0
                continue
            consecutive_failures = 0

            # 현재가
            cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
            if not cur_js or len(cur_js) == 0:
                continue
            curp = cur_js[0].get("trade_price", last_price)
            last_price = curp
            # ✅ 트레일링 래칫 버그 수정: 신고점 판정 먼저
            new_high = curp > best
            best = max(best, curp)
            worst = min(worst, curp)

            # === 🔧 스파이크→즉시 반락 퀵컷 ===
            # 초단기 들어갔는데 2~4초 만에 스파이크 후 절반 이상 반납하면 즉시 컷
            if (time.time() - spike_check_start) <= spike_window:
                gain_now = (curp / entry_price - 1.0)
                drop_from_peak = (best - curp) / best if best > 0 else 0
                if gain_now >= 0.007 and drop_from_peak >= 0.004:
                    # +0.7% 찍고 -0.4% 반락
                    verdict = "스파이크반락 퀵컷"
                    outcome_extra = f"(+{gain_now*100:.2f}%→-{drop_from_peak*100:.2f}% from peak)"
                    break

            # === 1) 웜업 구간: 소폭 되돌림 무시 (단, 급락은 즉시 컷)
            alive_sec = time.time() - start_ts
            dd_now = (curp / best - 1.0)
            cur_gain = (curp / entry_price - 1.0)

            if alive_sec < WARMUP_SEC:
                # 🔧 웜업 중 급락만 하드스탑 (틱/퍼센트 모드 공통)
                if STOP_MODE == "ticks":
                    # 틱 모드: 하드스탑만 적용 (틱스탑은 웜업 후 무장)
                    if HARD_STOP_DD and cur_gain <= -HARD_STOP_DD:
                        verdict = "웜업 하드스탑"
                        outcome_extra = f"({cur_gain*100:.2f}%, 하드-{HARD_STOP_DD*100:.1f}%)"
                        break
                else:
                    # 퍼센트 모드: 동적손절 (3초 지연 - 미세 흔들림 방지)
                    WARMUP_DYN_DELAY = 3.0  # 체결 후 3초간 동적손절 보류
                    if alive_sec >= WARMUP_DYN_DELAY and cur_gain <= -eff_sl_pct:
                        verdict = "웜업 손절"
                        outcome_extra = f"({cur_gain*100:.2f}%, 동적SL-{eff_sl_pct*100:.2f}%)"
                        break
                    # 3초 내에도 하드스탑은 적용 (급락 방어)
                    if alive_sec < WARMUP_DYN_DELAY and HARD_STOP_DD and cur_gain <= -HARD_STOP_DD:
                        verdict = "웜업 하드스탑"
                        outcome_extra = f"({cur_gain*100:.2f}%, 하드-{HARD_STOP_DD*100:.1f}%)"
                        break
                # 웜업 중엔 소프트 스탑 미적용
                continue

            # === 2) 트레일링 손절: 이익이 나야만 무장
            gain_from_entry = (curp / entry_price - 1.0)
            
            # === PROBE → CONFIRM 전환 로직 ===
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m, {})

            if pos.get("entry_mode") == "probe":
                # 전환 조건: 일정 수익 이상 + 거래속도 정상 + 매수세 유지
                t15_now = micro_tape_stats_from_ticks(ticks, 15)
                # 🔧 FIX: Decimal 제거 (float와 비교 시 TypeError 발생)
                gain_now = (curp / entry_price - 1.0)

                strong_flow = (
                    t15_now["buy_ratio"] >= 0.58
                    and t15_now["krw_per_sec"] >= 18000
                    and uptick_streak_from_ticks(ticks, need=2)
                )

                if gain_now >= 0.012 and strong_flow:
                    add_reason = f"상승확정 (수익+{gain_now*100:.1f}% 매수비{t15_now['buy_ratio']:.0%} 초당{t15_now['krw_per_sec']/1000:.0f}K)"
                    ok_add, new_entry = add_auto_position(m, curp, add_reason)
                    if ok_add and new_entry:
                        # 진입모드 승격
                        with _POSITION_LOCK:
                            pos["entry_mode"] = "confirm"
                            pos["entry_price"] = new_entry
                            pos["added"] = True
                            pos["last_add_ts"] = time.time()
                            OPEN_POSITIONS[m] = pos

                        tg_send_mid(
                            f"🔥 {m} 상승 확정 → probe ➜ confirm 전환\n"
                            f"추매 후 평단: {fmt6(new_entry)}원"
                        )

                        # 동적 손절 재계산
                        c1_for_sl = get_minutes_candles(1, m, 20)
                        base_stop, eff_sl_pct, atr_info = dynamic_stop_loss(new_entry, c1_for_sl)
                        trail_armed = False  # 새 기준으로 트레일링 리셋

            if (not trail_armed) and gain_from_entry >= TRAIL_ARM_GAIN:
                trail_armed = True
                # 초기 트레일: ATR 기준 혹은 최소거리
                atr = atr14_from_candles(get_minutes_candles(1, m, 20), 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = curp * (1.0 - trail_dist)

            # === 2-1) 피라미딩(추매): 완화형 로직 (부분청산 후 재상승 대응) ===
            if USE_PYRAMIDING and AUTO_TRADE:
                t15_now = micro_tape_stats_from_ticks(ticks, 15)

                # 💡 조건 완화 — 약상승에서도 반응하도록
                add_cond_price = gain_from_entry >= max(0.005, PYRAMID_ADD_MIN_GAIN * 0.8)
                add_cond_flow = (
                    t15_now["buy_ratio"] >= 0.55 and
                    t15_now["krw_per_sec"] >= PYRAMID_ADD_FLOW_MIN_KRWPSEC * 0.8 and
                    last_two_ticks_fresh(ticks)
                )

                # 📊 단기 EMA 기준으로 단기 상승 전환 감지 (1분봉)
                c1m = get_minutes_candles(1, m, 20)
                ema3 = ema_last([c["trade_price"] for c in c1m], 3)
                ema8 = ema_last([c["trade_price"] for c in c1m], 8)
                short_term_up = ema3 > ema8

                if add_cond_price and add_cond_flow and short_term_up:
                    with _POSITION_LOCK:
                        pos = OPEN_POSITIONS.get(m)
                        already_added = pos.get("added") if pos else True
                        last_add_ts = pos.get("last_add_ts", 0.0) if pos else 0.0

                    # 쿨다운을 40% 단축해 재진입성 향상
                    cooldown_ok = (time.time() - last_add_ts) >= (PYRAMID_ADD_COOLDOWN_SEC * 0.6)

                    if pos and (not already_added) and cooldown_ok:
                        add_reason = f"재상승EMA (수익+{gain_from_entry*100:.1f}% 매수비{t15_now['buy_ratio']:.0%} EMA3>EMA8)"
                        ok_add, new_entry = add_auto_position(m, curp, add_reason)
                        if ok_add and new_entry:
                            entry_price = new_entry
                            c1_for_sl = get_minutes_candles(1, m, 20)
                            base_stop, eff_sl_pct, atr_info = dynamic_stop_loss(entry_price, c1_for_sl)

            # 🔧 FIX: 트레일 업데이트 - new_high 사용 (curp > best는 best 갱신 후라 항상 False)
            if trail_armed and new_high:
                atr = atr14_from_candles(get_minutes_candles(1, m, 20), 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = max(trail_stop, curp * (1.0 - trail_dist))

            # 💎 브레이크이븐 스텝: +0.4% 도달 시 손절가를 진입가+수수료로 올림
            BREAKEVEN_TRIGGER = 0.004  # +0.4%
            if gain_from_entry >= BREAKEVEN_TRIGGER:
                # FEE_RATE는 왕복 수수료율(0.1%)이므로 1회만 적용
                breakeven_price = entry_price * (1 + FEE_RATE)
                base_stop = max(base_stop, breakeven_price)

            # 유효 스탑 = max(기본 동적 SL, 트레일링)
            effective_stop = max(base_stop, trail_stop if trail_armed else 0.0)

            # === 🔥 심플 체크포인트 매도 로직 ===
            cur_gain = (curp / entry_price - 1.0)
            ob_now = pre.get("ob", {})

            # === 🎯 틱 기반 트레일링 스탑 ===
            if STOP_MODE == "ticks":
                # 1) 오더북에서 best bid 주기적 갱신
                now_ts = time.time()
                if USE_BID_FOR_STOP and (now_ts - last_ob_fetch) >= 1.2:
                    try:
                        ob_js = safe_upbit_get("https://api.upbit.com/v1/orderbook", {"markets": m}, timeout=4)
                        if ob_js and isinstance(ob_js, list) and len(ob_js) > 0:
                            u0 = ob_js[0].get("orderbook_units", [{}])[0]
                            last_best_bid = float(u0.get("bid_price", curp))
                    except:
                        last_best_bid = None
                    last_ob_fetch = now_ts

                # 2) 틱스탑 무장 (웜업 종료 후 또는 약간 수익 시)
                if not tick_stop_armed and alive_sec >= WARMUP_SEC:
                    tick_base = compute_tick_distance(curp, c1, ob_now)
                    tick_stop_armed = True
                    trail_stop_px = curp - tick_base * tick_sz
                    print(f"[TICK_STOP] {m} 무장: {tick_base}틱, 스탑={trail_stop_px:.2f}")

                # 3) 신고가 갱신 시 트레일 끌어올리기
                if tick_stop_armed and new_high:
                    tick_base = max(tick_base, compute_tick_distance(curp, c1, ob_now))
                    new_trail = curp - tick_base * tick_sz
                    trail_stop_px = max(trail_stop_px, round_to_tick(new_trail, tick_sz))

                # 4) 스탑 트리거 판정 (디바운스)
                ref_price = last_best_bid if (USE_BID_FOR_STOP and last_best_bid) else curp
                if tick_stop_armed and ref_price <= trail_stop_px:
                    if tick_stop_hits == 0:
                        tick_stop_first_seen = time.time()
                    tick_stop_hits += 1
                    # 디바운스 조건 충족 시 손절
                    if (time.time() - tick_stop_first_seen) >= TICK_STOP_DEBOUNCE_SEC and tick_stop_hits >= TICK_STOP_DEBOUNCE_N:
                        close_auto_position(m, f"틱스탑 {tick_base}틱 (스탑={trail_stop_px:.2f}, ref={ref_price:.2f})")
                        verdict = "TICK_STOP"
                        break
                else:
                    # 2틱 이상 회복 또는 1초 경과 시 디바운스 리셋 (휩쏘 재트리거 방지)
                    if ref_price >= trail_stop_px + tick_sz * 2 or (tick_stop_hits > 0 and (time.time() - tick_stop_first_seen) >= 1.0):
                        tick_stop_hits = 0

                # 5) 하드스탑 백업 (급락 시 즉시 컷)
                if HARD_STOP_DD and cur_gain <= -HARD_STOP_DD:
                    close_auto_position(m, f"하드스탑 급락 -{abs(cur_gain)*100:.2f}% (기준 -{HARD_STOP_DD*100:.1f}%)")
                    verdict = "HARD_DROP"
                    break

            else:
                # ① 기존 동적 손절 (ATR 기반, 0.3%~0.5%)
                if cur_gain <= -eff_sl_pct:
                    atr_detail = f", {atr_info}" if atr_info else ""
                    close_auto_position(m, f"동적손절 -{abs(cur_gain)*100:.2f}% (기준 -{eff_sl_pct*100:.2f}% 초과{atr_detail})")
                    verdict = "DYN_STOP"
                    break

            # ② 얇은 수익 체크포인트 (+0.3%) 도달 시 강세 판단
            # 🔧 FIX: 체크포인트 재평가 - 가격이 0.1% 아래로 떨어지면 리셋
            if checkpoint_reached and not strong_mode and cur_gain < (THIN_PROFIT_CHECKPOINT * 0.3):
                checkpoint_reached = False  # 체크포인트 아래로 떨어짐 → 재평가 허용

            if not checkpoint_reached and cur_gain >= THIN_PROFIT_CHECKPOINT:
                checkpoint_reached = True
                # 강세 여부 체크
                if is_strong_momentum(ticks, ob_now):
                    # 강세 → 트레일링 모드 진입
                    strong_mode = True
                    strong_peak = curp
                    tg_send_mid(f"💪 {m} 진입 후 +{cur_gain*100:.2f}% 강세확인 → 홀딩")
                else:
                    # 약세 → 즉시 매도
                    close_auto_position(m, f"체크포인트 익절 진입 후 +{cur_gain*100:.2f}% 수익에서 약세판정")
                    verdict = "THIN_PROFIT"
                    break

            # ③ 강세 모드: 고점 추적 + 동적 트레일링 (수익률에 따라 폭 확대)
            if strong_mode:
                # 고점 갱신
                if curp > strong_peak:
                    strong_peak = curp

                # 🚀 동적 트레일링 폭: 수익률에 따라 확대
                # +5% 이상 → -3% 허용, +3% 이상 → -2%, +1% 이상 → -1%, 기본 -0.2%
                peak_gain = (strong_peak / entry_price - 1.0)
                if peak_gain >= 0.05:
                    dynamic_trail_drop = 0.03  # 3%
                elif peak_gain >= 0.03:
                    dynamic_trail_drop = 0.02  # 2%
                elif peak_gain >= 0.01:
                    dynamic_trail_drop = 0.01  # 1%
                else:
                    dynamic_trail_drop = STRONG_TRAIL_DROP  # 0.2%

                # 고점 대비 하락률 계산
                drop_from_strong_peak = (strong_peak - curp) / strong_peak

                if drop_from_strong_peak >= dynamic_trail_drop:
                    final_gain = (curp / entry_price - 1.0)
                    peak_gain = (strong_peak / entry_price - 1.0)
                    close_auto_position(m, f"트레일링 익절 진입 후 +{final_gain*100:.2f}% 수익 (최고+{peak_gain*100:.2f}%에서 -{drop_from_strong_peak*100:.1f}% 하락)")
                    verdict = "STRONG_TRAIL_EXIT"
                    break

            # ④ 눌림 후 재상승 감지 → 트레일 강화 (재진입 대신)
            drop_from_high = (best - curp) / best if best > 0 else 0
            if drop_from_high >= 0.005 and uptick_streak_from_ticks(ticks, need=3):
                if trail_armed:
                    # 재진입 대신 트레일 간격 타이트하게 강화
                    trail_stop = max(trail_stop, curp * (1.0 - max(TRAIL_DISTANCE_MIN * 0.8, 0.0025)))
                    tg_send_mid(f"🔧 {m} 재상승 감지 → 트레일 강화")
        
        if verdict is None:
            verdict = "시간 만료(모니터링 종료)"

    finally:
        # ================================
        # 1) 최신 상태 / 수익률 계산
        # ================================
        ticks = get_recent_ticks(m, 100)
        t15 = micro_tape_stats_from_ticks(ticks, 15) if ticks else {
            "buy_ratio": 0,
            "krw": 0,
            "n": 0,
            "krw_per_sec": 0
        }

        ob = pre.get("ob") or {}
        ob_depth_krw = ob.get("depth_krw", 10_000_000)

        try:
            ret_pct = ((last_price / entry_price - 1.0) - FEE_RATE) * 100.0
        except:
            ret_pct = 0.0

        maxrun = (best / entry_price - 1.0) * 100.0
        maxdd = (worst / entry_price - 1.0) * 100.0

        # ================================
        # 2) 끝알람 문구 생성
        # ================================
        action, rationale = _end_reco(entry_price,
                                      last_price,
                                      c1,
                                      ticks,
                                      ob_depth_krw,
                                      ctx_thr=CTX_EXIT_THRESHOLD)

        # ===========================================
        # 끝알람 / 재모니터링 알림 비활성화
        #  (실제 로직은 유지하지만 텔레그램 메시지 과다 방지)
        # ===========================================
        if not reentry:
            pass  # 끝알람 비활성화
        else:
            pass  # 재모니터링 요약 비활성화

        # ===========================================
        # 재모니터링 루프 시작
        #  - 최초 모니터링에서만 호출
        #  - remonitor_until_close()에서 재호출된 경우(reentry=True)는 다시 안 들어감
        # ===========================================
        # ✅ 재모니터링 알림 비활성화 (불필요한 반복 메시지 방지)
        # (실제 로직은 유지하지만, 알림 발송만 차단)
        if AUTO_TRADE and m in OPEN_POSITIONS and not reentry:
            remonitor_until_close(m, entry_price, pre, tight_mode)

        # ===========================================
        # 3) probe 손절 후 빠른 재진입 허용 로직
        # ===========================================
        if AUTO_TRADE and verdict and "손절" in verdict:
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m)
                if pos and pos.get("entry_mode") == "probe":
                    # probe 손절 시 재진입 쿨다운 최소화
                    REMONITOR_QUICK_COOLDOWN_SEC = 120  # 2분 쿨다운
                    REMONITOR_WINDOW_MINUTES = 10       # 10분 내 동일 종목 재기회 허용

                    # 최근 종료 시각 기록
                    pos["last_exit_ts"] = time.time()
                    OPEN_POSITIONS[m] = pos

                    # 🌀 probe 손절 감지 → 재진입 모드 (알림 비활성화)

                    # 빠른 재모니터링 예약
                    time.sleep(REMONITOR_QUICK_COOLDOWN_SEC)
                    remonitor_until_close(m, entry_price, pre, tight_mode)

        # 👇 이 return 은 if 바깥에서 항상 실행되게
        return (
            verdict,
            action,
            rationale,
            ret_pct,
            last_price,
            maxrun,
            maxdd,
        )


