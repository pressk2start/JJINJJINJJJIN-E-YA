def send_remonitor_alert(m, text):
    """
    재모니터링 / 컨텍스트용 요약 알람
    - 텔레그램 과다 방지: TG 전송은 비활성화, 콘솔만 남김
    """
    now = time.time()
    last = REMONITOR_LAST_ALERT.get(m, 0)
    elapsed = now - last

    # 5분 이내면 완전히 스킵 (콘솔에도 출력하지 않음)
    if elapsed < REMONITOR_COOLDOWN_SEC:
        return

    REMONITOR_LAST_ALERT[m] = now
    print(f"[REMONITOR_INFO] {m} {text}")  # 콘솔만 남김
    return  # TG 전송 비활성화

