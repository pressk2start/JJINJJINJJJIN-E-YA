def close_auto_position(m, reason="", attempt=1, max_attempts=5):
    """
    손절/청산 시 자동 매도 - 재시도 + 잔고검증 + 실패시 포지션 유지
    - attempt: 현재 재시도 횟수 (기본 1)
    - max_attempts: 최대 재시도 횟수 (기본 5회, 무한 재귀 방지)
    """
    if not AUTO_TRADE:
        print(f"[AUTO] AUTO_TRADE=0 → 청산 스킵 ({m}, reason={reason})")
        return

    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)

    if not pos:
        print(f"[AUTO] OPEN_POSITIONS에 {m} 포지션 없음 → 청산 스킵 (reason={reason})")
        tg_send_mid(f"⚠️ {m} 청산 시도했는데 OPEN_POSITIONS에 포지션 없음")
        return

    vol = float(pos.get("volume", 0) or 0.0)
    if vol <= 0:
        print(f"[AUTO] {m} volume<=0 ({vol}) → 포지션 제거만 수행")
        with _POSITION_LOCK:
            OPEN_POSITIONS.pop(m, None)
        return

    entry_price = float(pos.get("entry_price", 0) or 0.0)

    print(f"[AUTO] {m} 청산 시도: volume={vol}, reason={reason}")

    # 1) 1차 매도 (sell_market은 이미 재시도 포함)
    ok = sell_market(m, vol, max_attempts=3)

    # 2) 사후 검증: 실제 잔고 조회
    remain = _get_coin_balance(m)
    tries = 0
    while remain * max(entry_price, 1) > MIN_ORDER_KRW and tries < 3:
        tries += 1
        print(f"[POST-SELL] {m} 잔여 수량 재청산 시도 {tries}/3, remain={remain:.6f}")
        ok2 = sell_market(m, remain, max_attempts=3)
        time.sleep(1)  # API 반영 대기
        remain = _get_coin_balance(m)
        if ok2 and remain * max(entry_price, 1) <= MIN_ORDER_KRW:
            break

    # 3) 최종 판정
    final_remain = _get_coin_balance(m)
    # 최소금액 + 근사 0 체크 (미세 잔고 허용)
    if final_remain * max(entry_price, 1) > MIN_ORDER_KRW and final_remain > 1e-8:
        # ⛔ 아직도 남아있다 → 포지션 기록 유지 + 재시도 예약
        if attempt >= max_attempts:
            # 최대 재시도 도달 → 경고만 발송하고 포지션 유지
            tg_send(f"⚠️ <b>자동청산 미완료 (최대 재시도 도달)</b> {m}\n"
                    f"• 사유: {reason}\n"
                    f"• 잔여: {final_remain:.6f} ({final_remain * max(entry_price,1):,.0f}원)\n"
                    f"• 재시도: {attempt}/{max_attempts}\n"
                    f"→ 수동 확인 필요")
            print(f"[AUTO] {m} 청산 재시도 한도 도달 ({attempt}/{max_attempts}), 포지션 유지")
            return

        tg_send(f"⚠️ <b>자동청산 미완료</b> {m}\n"
                f"• 사유: {reason}\n"
                f"• 잔여: {final_remain:.6f} ({final_remain * max(entry_price,1):,.0f}원)\n"
                f"• 재시도: {attempt}/{max_attempts}\n"
                f"→ 15초 후 재시도")
        time.sleep(15)
        return close_auto_position(m, reason=f"{reason} (retry)", attempt=attempt+1, max_attempts=max_attempts)
    else:
        # ✅ 완전 청산: 이제 포지션 제거
        # 최종 수익률 계산 (현재가 기준)
        try:
            cur_js = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m}, timeout=6)
            cur_price = cur_js[0].get("trade_price", entry_price) if cur_js else entry_price
        except Exception:
            cur_price = entry_price

        ret_pct = (cur_price / entry_price - 1.0) * 100.0 if entry_price > 0 else 0.0

        # 거래 결과 기록
        try:
            record_trade(m, ret_pct)
        except Exception as _e:
            print("[TRADE_RECORD_ERR]", _e)

        with _POSITION_LOCK:
            OPEN_POSITIONS.pop(m, None)

        tg_send(f"💥 <b>자동청산 완료</b> {m}\n"
                f"• 사유: {reason}\n"
                f"• 수량: {vol:.6f}\n"
                f"• 매수평단: {entry_price:,.0f}원\n"
                f"• 추정수익률: {ret_pct:+.2f}%\n"
                f"{link_for(m)}")


def safe_partial_sell(m, sell_ratio=0.5, reason=""):
    """
    부분 청산 공용 함수
    - sell_ratio: 0.5 → 50%, 0.3 → 30% 등
    - partial_done 플래그로 1회만 부분청산/부분익절 허용
    반환: (성공여부:bool, 메시지:str, 체결량:float)
    """
    # AUTO_TRADE 가드 (데모/관찰 모드 보호)
    if not AUTO_TRADE:
        msg = f"[REMONITOR] {m} 부분청산 스킵(AUTO_TRADE=0)"
        print(msg)
        return False, msg, 0.0

    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m)
        if not pos or pos.get("volume", 0) <= 0:
            msg = f"[REMONITOR] {m} 부분청산 실패: 포지션 없음/수량 0"
            print(msg)
            return False, msg, 0.0
        if pos.get("partial_done"):
            msg = f"[REMONITOR] {m} 부분청산 이미 수행됨 → 스킵"
            print(msg)
            return False, msg, 0.0
        current_volume = pos["volume"]

    sell_volume = current_volume * sell_ratio
    if sell_volume <= 0:
        msg = f"[REMONITOR] {m} 부분청산 실패: sell_volume<=0"
        print(msg)
        return False, msg, 0.0

    # 최소금액 가드 (Upbit 최소거래금액)
    try:
        tkr = safe_upbit_get("https://api.upbit.com/v1/ticker", {"markets": m})
        curp = tkr[0].get("trade_price") if tkr else None
    except Exception:
        curp = None

    if curp and (sell_volume * curp) < MIN_ORDER_KRW:
        msg = f"[REMONITOR] {m} 부분청산 스킵: 최소금액 미만 ({sell_volume * curp:.0f}원)"
        print(msg)
        return False, msg, 0.0

    try:
        res = place_market_sell(m, sell_volume)
        order_uuid = res.get("uuid") if isinstance(res, dict) else None
        od = get_order_result(order_uuid,
                              timeout_sec=6.0) if order_uuid else None

        executed = 0.0
        avg_price_sell = None
        if od:
            try:
                executed = float(od.get("executed_volume") or "0")
            except Exception:
                executed = 0.0

            # 체결가 평균 계산 (Net BE 계산용)
            trades = od.get("trades") or []
            if trades:
                _sum, _vol = 0.0, 0.0
                for tr in trades:
                    _p = float(tr.get("price", "0") or 0)
                    _v = float(tr.get("volume", "0") or 0)
                    _sum += _p * _v
                    _vol += _v
                if _vol > 0:
                    avg_price_sell = _sum / _vol

        if executed <= 0:
            msg = f"[PARTIAL_SELL_ERR] {m}: executed_volume=0 (요청 {sell_volume:.6f})"
            print(msg)
            # ❗ 부분청산 신호는 계속 오는데 실제 매도가 안 되는 경우를 눈에 보이게
            tg_send_mid(f"⚠️ <b>부분청산 주문 실패</b> {m}\n"
                        f"• 요청 비율: {sell_ratio*100:.0f}%\n"
                        f"• 요청 수량: {sell_volume:.6f}\n"
                        f"• 체결 수량: 0 (실패)\n"
                        f"→ 최소 주문금액 부족 / 주문거절 가능성")

            # 대안: 비율을 올려서 재시도 (수량이 커지면 최소금액 통과 가능)
            alt_ratio = min(1.0, max(0.6, sell_ratio * 1.8))
            print(f"[PARTIAL_SELL] {m} 대안 매도 시도: {alt_ratio*100:.0f}% (원래 {sell_ratio*100:.0f}%)")
            try2 = sell_market(m, current_volume * alt_ratio, max_attempts=3)
            if try2:
                with _POSITION_LOCK:
                    pos2 = OPEN_POSITIONS.get(m)
                    if pos2:
                        pos2["volume"] = max(0.0, current_volume - current_volume * alt_ratio)
                        pos2["partial_done"] = True
                        pos2["partial_sell_time"] = time.time()  # 부분익절 시간 기록 (시간 데드라인용)
                tg_send_mid(f"✅ 부분청산 대안 실행: {alt_ratio*100:.0f}% 전환 매도 성공")
                return True, "[REMONITOR] 대안 부분청산 성공", current_volume * alt_ratio

            return False, msg, 0.0

        remaining_volume = max(current_volume - executed, 0.0)

        # Net BE 스톱 계산 및 저장
        net_be_stop = None
        with _POSITION_LOCK:
            pos2 = OPEN_POSITIONS.get(m)
            if pos2:
                pos2["volume"] = remaining_volume
                pos2["partial_done"] = True
                pos2["partial_sell_time"] = time.time()  # 부분익절 시간 기록 (시간 데드라인용)

                # Net BE 보호 스톱 계산 (부분익절 후 전체 손실 방지)
                if NET_BE_PROTECT and avg_price_sell and remaining_volume > 0:
                    entry_price = float(pos2.get("entry_price", 0))
                    if entry_price > 0:
                        net_be_stop = compute_net_be_price(
                            entry_price=entry_price,
                            total_vol=current_volume,
                            sold_vol=executed,
                            sold_avg=avg_price_sell
                        )
                        pos2["net_be_stop"] = net_be_stop
                        print(f"[NET_BE] {m} Net BE 스톱 설정: {net_be_stop:,.0f}원 (전체 손익 0 보장)")

                # 총손익 giveback 보호를 위한 실현손익 누적
                if executed > 0 and avg_price_sell:
                    entry_price0 = float(pos2.get("entry_price", 0.0) or 0.0)
                    realized_add = (avg_price_sell - entry_price0) * executed
                    pos2["realized_pnl_krw"] = float(pos2.get("realized_pnl_krw", 0.0) or 0.0) + realized_add
                    print(f"[GIVEBACK] {m} 실현손익 누적: {realized_add:+,.0f}원 (총 {pos2['realized_pnl_krw']:+,.0f}원)")

        msg = (f"[REMONITOR] {m} 부분 청산 실행 {sell_ratio*100:.0f}% "
               f"(체결 {executed:.6f}) 잔여 {remaining_volume:.6f}")
        print(msg)

        # 텔레그램 알림 (Net BE 정보 포함)
        tg_msg = (f"🎯 <b>부분 청산</b> {m}\n"
                  f"• 사유: {reason or '부분청산'}\n"
                  f"• 매도 비율: {sell_ratio*100:.0f}%\n")
        if avg_price_sell:
            tg_msg += f"• 체결가: {avg_price_sell:,.0f}원\n"
        tg_msg += f"• 체결 수량: {executed:.6f}\n"
        tg_msg += f"• 잔여 수량: {remaining_volume:.6f}\n"
        if net_be_stop:
            tg_msg += f"• Net BE 스톱: {net_be_stop:,.0f}원 (전체 손익 0 보장)\n"

        tg_send(tg_msg)

        return True, msg, executed

    except Exception as e:
        msg = f"[PARTIAL_SELL_ERR] {m}: {e}"
        print(msg)
        return False, msg, 0.0


def remonitor_until_close(m, entry_price, pre, tight_mode=False):
    """
    끝알람 이후 자동청산 신호가 나올 때까지 반복 모니터링
    - 라운드트립 가드: 고점 대비 이익 많이 반납하면 정리
    - 절대 보유 한계: 시간/사이클 초과 시 강제 청산
    """
    CYCLE_SEC = REMONITOR_CYCLE_SEC  # 환경변수로 조정 가능 (기본 180초)
    cycle = 0
    opened_ts = None
    same_keep = 0  # 동일 판단 반복 카운트
    last_verdict = None

    # 진입 시각 확인
    with _POSITION_LOCK:
        pos0 = OPEN_POSITIONS.get(m)
        if pos0:
            opened_ts = pos0.get("opened_ts", time.time())

    while True:
        cycle += 1

        # ========================================
        # 절대 보유 한계 가드 (무한 재모니터 방지)
        # ========================================
        held_min = (time.time() - (opened_ts or time.time())) / 60.0
        if held_min >= MAX_HOLD_MINUTES or cycle >= MAX_REMONITOR_CYCLES:
            print(f"[REMONITOR] {m} 절대 보유 한계 초과 → 강제 청산 ({int(held_min)}분/{cycle}회)")
            close_auto_position(m, reason=f"ABS_LIMIT({int(held_min)}m/{cycle}cy)")
            return True

        print(f"[REMONITOR] {m} {cycle}회차 재모니터링 시작 (보유 {int(held_min)}분)")

        verdict, action, rationale, ret_pct, last_price, maxrun, maxdd = \
            monitor_position(
                m, entry_price, pre,
                tight_mode=tight_mode,
                horizon=CYCLE_SEC,
                reentry=True
            )

        should_close = False
        reason = verdict or action or "모니터링 종료"

        # ========================================
        # 라운드트립 가드: 감시구간 최고수익은 컸는데 현재 이익이 너무 줄었으면 수익 보호
        # 예) 5분간 +10% 찍었는데 종료 시점에 +0.5% 이하면 50% 털고 계속 / 음전이면 전량
        # ========================================
        try:
            if (maxrun is not None and ret_pct is not None and
                maxrun >= ROUNDTRIP_TP * 100 and (ret_pct / 100.0) <= ROUNDTRIP_KEEP):
                # 현재가가 미세하게라도 플러스면 부분익절, 0 이하로 내려왔으면 전량
                if ret_pct > 0:
                    ok, msg, executed = safe_partial_sell(
                        m, sell_ratio=ROUNDTRIP_PARTIAL,
                        reason=f"라운드트립 가드: 최고 {maxrun:.2f}%→현재 {ret_pct:.2f}%"
                    )
                    if ok and executed > 0:
                        print(msg)
                        tg_send(f"⚠️ {m} 라운드트립 가드 발동\n최고: {maxrun:.2f}% → 현재: {ret_pct:.2f}%\n{ROUNDTRIP_PARTIAL*100:.0f}% 부분청산 완료")
                    continue
                else:
                    should_close = True
                    reason = f"라운드트립 가드: 최고 {maxrun:.2f}%→음전 {ret_pct:.2f}%"
        except Exception as e:
            print(f"[REMONITOR] 라운드트립 가드 오류: {e}")
            pass

        # 1) 급락 / 손절 권고
        if verdict and ("급락" in verdict or "손절" in verdict):
            should_close = True

        # 2) 전량 청산 권고
        elif action and "전량 청산 권고" in action:
            should_close = True

        # 3) 수익 실현:
        #    - 2.5% 이상: 전량 청산
        #    - 1.5% ~ 2.5%: 30% 부분익절(포지션당 1회)
        elif ret_pct is not None and ret_pct >= 2.5:
            should_close = True
            reason = f"수익실현 {ret_pct:.2f}%"

        elif ret_pct is not None and ret_pct >= 1.5:
            # 중간 구간: 30% 부분 수익실현 후 계속 보유
            ok, msg, executed = safe_partial_sell(
                m, sell_ratio=0.3, reason=f"부분 수익실현 {ret_pct:.2f}%")
            if ok and executed > 0:
                print(msg)
            # 부분익절 후에는 계속 재모니터링
            continue

        # 4) 컨텍스트 청산 권고는 → 청산 안 하고 계속 재모니터링
        elif verdict and verdict.startswith("청산 권고("):
            continue

        # 5) 부분 청산(50%) 권고 → 실제 50% 매도 후 계속 재모니터링
        elif action == "부분 청산(50%) 권고":
            ok, msg, executed = safe_partial_sell(m,
                                                  sell_ratio=0.5,
                                                  reason="끝알람 부분청산 50%")
            if ok and executed > 0:
                print(msg)
            continue

        # 5-1) 부분 청산(본절) 권고 → 본절 수준에서 일부 정리
        elif action == "부분 청산(본절)":
            ok, msg, executed = safe_partial_sell(m, sell_ratio=0.5, reason="본절 부분청산")
            if ok and executed > 0:
                print(msg)
                tg_send(f"⚠️ {m} 본절 구간 부분청산\n50% 정리 완료, 나머지 재모니터링")
            continue

        # 6) 유지 권고 → 계속 재모니터링
        elif action == "유지 권고":
            continue

        # 7) 시간 만료 / 시간 연장 → 다시 한 번 사이클 (반복 시 보호익절)
        elif verdict in ("시간 만료(유지)", "시간 만료(모니터링 종료)", "시간 연장(상승추세 보유)"):
            if last_verdict == verdict:
                same_keep += 1
            else:
                same_keep = 1
            last_verdict = verdict

            # 3회 연속 동일 판단이면 보수적 부분익절 30% (수익 보호)
            if same_keep >= 3 and ret_pct is not None and ret_pct > 0:
                ok, msg, executed = safe_partial_sell(m, sell_ratio=0.3, reason="시간만료 반복 보호익절")
                if ok and executed > 0:
                    print(msg)
                    tg_send(f"⏰ {m} 시간만료 {same_keep}회 반복\n보호익절 30% 실행 (현재 {ret_pct:.2f}%)")
                same_keep = 0  # 리셋
            # 3회 연속 동일 판단인데 음전이면 전량 청산 (리스크 통제)
            elif same_keep >= 3 and ret_pct is not None and ret_pct <= 0:
                close_auto_position(m, reason=f"시간만료 {same_keep}회 반복 음전 보호")
                return True
            continue

        if should_close:
            print(f"[REMONITOR] {m} 자동청산 조건 충족 → 청산 ({reason})")
            close_auto_position(m, reason)
            return True


