from collections import deque as _deque_for_risk  # 기존 deque와 별도 alias

TRADE_HISTORY = _deque_for_risk(maxlen=30)  # 최근 30개 거래 기록

# 🔧 크리티컬 핫픽스: streak 전역변수 상단 선언 (NameError 방지)
_lose_streak = 0              # 연속 패배 수
_win_streak = 0               # 연속 승리 수


def record_trade(market: str, pnl_pct: float):
