            krw_to_use = 7000
            print(f"[AUTO] probe 최소금액 적용: {krw_to_use:,.0f}원")
        else:
            print(f"[AUTO] 주문금액 {krw_to_use:,.0f}원 < {min_order_krw:,}원 → 스킵")
