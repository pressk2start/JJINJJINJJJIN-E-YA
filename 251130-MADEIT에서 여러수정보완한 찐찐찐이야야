def monitor_position(m,
                     entry_price,
                     pre,
                     tight_mode=False,
                     horizon=None,
                     reentry=False):
    c1 = get_minutes_candles(1, m, 20)
    base_stop, eff_sl_pct = dynamic_stop_loss(entry_price, c1)

    # horizon이 안 들어오면 자동 결정, 들어오면 그 값 사용
    if horizon is None:
        horizon = decide_monitor_secs(pre, tight_mode=tight_mode)
    start_ts = time.time()

    # 캔들 캐싱 (API 호출 최소화)
    c1_cached = c1[:]  # 초기 캔들
    last_candle_fetch = time.time()

    # 디바운스/트레일 상태
    # 손절 디바운스용
    stop_first_seen_ts = 0.0
    stop_hits = 0
    # 컨텍스트 청산 디바운스용
    ctx_first_seen_ts = 0.0
    ctx_hits = 0

    trail_armed = False
    trail_stop = 0.0
    last_trail_dist = None  # 마지막 트레일 거리 저장 (알림용)

    # 상승추세 보유 락 상태
    lock_on = False
    lock_since = 0.0

    # 스파이크/그레이스 기존 로직 재활용
    consecutive_failures = 0
    MAX_CONSECUTIVE_FAILURES = 10
    grace_used = False
    spike_recovery_used = False

    ob = pre.get("ob")
    ob_depth_default = ob.get("depth_krw", 10_000_000) if ob else 10_000_000

    last_price = entry_price
    best = entry_price
    worst = entry_price

    # 실제 보유 수량 확보 (익절 시 매도용)
    with _POSITION_LOCK:
        entry_volume = OPEN_POSITIONS.get(m, {}).get("volume", 0.0)

    verdict = None
    outcome_extra = ""

    # === 포지션 모드 (probe / confirm) ===
    with _POSITION_LOCK:
        pos = OPEN_POSITIONS.get(m, {})
    entry_mode = pos.get("entry_mode", "confirm")

    # 총손익 giveback 추적용 (부분익절 후)
    total_pnl_peak = 0.0

    try:
        while time.time() - start_ts <= horizon:
            time.sleep(RECHECK_SEC)

            # 캔들 캐시 갱신 (12초마다만 API 호출)
            if time.time() - last_candle_fetch >= 12:
                fresh_candles = get_minutes_candles(1, m, 20)
                if fresh_candles:
                    c1_cached = fresh_candles
                last_candle_fetch = time.time()

            ticks = get_recent_ticks(m, 100)
            if not ticks or len(ticks) < 3:
                consecutive_failures += 1
                if consecutive_failures >= MAX_CONSECUTIVE_FAILURES:
                    time.sleep(3)
                    ticks = get_recent_ticks(m, 100)
                    if not ticks:
                        verdict = "데이터 수신 실패"
                        break
                    consecutive_failures = 0
                continue
            consecutive_failures = 0

            # 현재가 (이미 가져온 ticks에서 사용, API 중복 호출 제거)
            curp = ticks[0].get("trade_price", last_price) if ticks else last_price
            last_price = curp
            best = max(best, curp)
            worst = min(worst, curp)

            # === 1) 웜업 구간: 소폭 되돌림 무시 (단, 급락은 즉시 컷)
            alive_sec = time.time() - start_ts
            dd_now = (curp / best - 1.0)
            if alive_sec < WARMUP_SEC:
                if (curp / entry_price - 1.0) <= -HARD_STOP_DD:
                    verdict = "급락 즉시 손절"
                    outcome_extra = f"(DD {dd_now*100:.2f}%)"
                    break  # 청산은 finally에서 한 번만
                # 웜업 중엔 소프트 스탑 미적용
                continue

            # === 2) 트레일링 손절: 이익이 나야만 무장
            gain_from_entry = (curp / entry_price - 1.0)

            # === 상승추세 보유 락 제어 ===
            if HOLD_ON_UPTREND:
                c1_for_lock = c1_cached if c1_cached and len(c1_cached) >= 20 else c1
                if (not lock_on) and (gain_from_entry >= HOLD_LOCK_MIN_GAIN) and uptrend_lock_ok(c1_for_lock, ticks):
                    lock_on = True
                    lock_since = time.time()
                    tg_send_mid(f"🟢 {m} 상승추세 락 ON (최소 {HOLD_LOCK_MIN_SEC}s 보유)")
                elif lock_on:
                    # 해제 조건: 고점대비 급하락, 매수비 약화, 컨텍스트 악화
                    t15_now = micro_tape_stats_from_ticks(ticks, 15)
                    ctx_score, _ = context_exit_score(m, ticks, ob_depth_default, entry_price, curp, c1_for_lock)
                    drop_from_high = (best / max(curp, 1) - 1.0)
                    hold_time_ok = (time.time() - lock_since) >= HOLD_LOCK_MIN_SEC
                    unlock = False
                    if drop_from_high >= HOLD_UNLOCK_DROP_FROM_HIGH:
                        unlock = True
                    if t15_now["buy_ratio"] < HOLD_UNLOCK_BUY_MAX and t15_now["n"] >= 5:
                        unlock = True
                    if ctx_score >= (CTX_EXIT_THRESHOLD + HOLD_UNLOCK_CTX):
                        unlock = True
                    if unlock and hold_time_ok:
                        lock_on = False
                        tg_send_mid(f"🔓 {m} 상승추세 락 OFF (보유 {int(time.time()-lock_since)}s)")

            # === PROBE → CONFIRM 전환 로직 ===
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m, {})

            if pos.get("entry_mode") == "probe":
                # 전환 조건: 일정 수익 이상 + 거래속도 정상 + 매수세 유지
                t15_now = micro_tape_stats_from_ticks(ticks, 15)
                from decimal import Decimal, getcontext
                getcontext().prec = 10  # 소수점 정밀도 설정

                gain_now = (Decimal(curp) / Decimal(entry_price) - Decimal(1))

                strong_flow = (
                    t15_now["buy_ratio"] >= 0.58
                    and t15_now["krw_per_sec"] >= 18000
                    and uptick_streak_from_ticks(ticks, need=2)
                )

                if gain_now >= 0.012 and strong_flow:
                    ok_add, new_entry = add_auto_position(m, curp)
                    if ok_add and new_entry:
                        # 진입모드 승격
                        with _POSITION_LOCK:
                            pos["entry_mode"] = "confirm"
                            pos["entry_price"] = new_entry
                            pos["added"] = True
                            pos["last_add_ts"] = time.time()
                            OPEN_POSITIONS[m] = pos

                        tg_send_mid(
                            f"🔥 {m} 상승 확정 → probe ➜ confirm 전환\n"
                            f"추매 후 평단: {fmt6(new_entry)}원"
                        )

                        # 동적 손절 재계산
                        c1_for_sl = get_minutes_candles(1, m, 20)
                        base_stop, eff_sl_pct = dynamic_stop_loss(new_entry, c1_for_sl)
                        trail_armed = False  # 새 기준으로 트레일링 리셋

            # === PROBE 실패 빠른 손절 (45초 제한) ===
            # 프로브가 45초 내에 성과를 내지 못하면 빠르게 컷
            if PROBE_FAIL_QUICK_EXIT and pos.get("entry_mode") == "probe":
                opened_ts = float(pos.get("opened_ts", 0) or 0)
                if opened_ts > 0:
                    probe_elapsed = time.time() - opened_ts
                    if probe_elapsed >= PROBE_FAIL_EXIT_SEC and gain_from_entry < 0.005:  # 45초 경과 + 0.5% 미만 수익
                        if AUTO_TRADE and entry_volume > 0:
                            sell_market(m, entry_volume)
                        alert = format_sell_alert(m, f"프로브 실패 빠른 컷 ({int(probe_elapsed)}초)", entry_volume, entry_price, curp,
                                                 f"제한 {PROBE_FAIL_EXIT_SEC}초")
                        tg_send(alert)
                        verdict = "PROBE_FAIL_QUICK_EXIT"
                        break

            if (not trail_armed) and gain_from_entry >= TRAIL_ARM_GAIN:
                trail_armed = True
                # 초기 트레일: ATR 기준 혹은 최소거리
                atr = atr14_from_candles(c1_cached, 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = curp * (1.0 - trail_dist)

            # === 2-1) 피라미딩(추매): 완화형 로직 (부분청산 후 재상승 대응) ===
            if USE_PYRAMIDING and AUTO_TRADE:
                t15_now = micro_tape_stats_from_ticks(ticks, 15)

                # 💡 조건 완화 — 약상승에서도 반응하도록
                add_cond_price = gain_from_entry >= max(0.005, PYRAMID_ADD_MIN_GAIN * 0.8)
                add_cond_flow = (
                    t15_now["buy_ratio"] >= 0.55 and
                    t15_now["krw_per_sec"] >= PYRAMID_ADD_FLOW_MIN_KRWPSEC * 0.8 and
                    last_two_ticks_fresh(ticks)
                )

                # 📊 단기 EMA 기준으로 단기 상승 전환 감지 (1분봉)
                c1m = get_minutes_candles(1, m, 20)
                ema3 = ema_last([c["trade_price"] for c in c1m], 3)
                ema8 = ema_last([c["trade_price"] for c in c1m], 8)
                short_term_up = ema3 > ema8

                if add_cond_price and add_cond_flow and short_term_up:
                    with _POSITION_LOCK:
                        pos = OPEN_POSITIONS.get(m)
                        already_added = pos.get("added") if pos else True
                        last_add_ts = pos.get("last_add_ts", 0.0) if pos else 0.0

                    # 쿨다운을 40% 단축해 재진입성 향상
                    cooldown_ok = (time.time() - last_add_ts) >= (PYRAMID_ADD_COOLDOWN_SEC * 0.6)

                    if pos and (not already_added) and cooldown_ok:
                        ok_add, new_entry = add_auto_position(m, curp)
                        if ok_add and new_entry:
                            entry_price = new_entry
                            c1_for_sl = get_minutes_candles(1, m, 20)
                            base_stop, eff_sl_pct = dynamic_stop_loss(entry_price, c1_for_sl)
                            tg_send_mid(
                                f"➕ <b>{m}</b> 재상승 감지 → 추매 체결<br>"
                                f"💵 새 평단 {entry_price:,.0f}원<br>"
                                f"🧯 손절 {base_stop:,.0f}원 ({eff_sl_pct*100:.2f}%)"
                            )

            # 트레일 업데이트(이익 확대 시에만 상향)
            if trail_armed and curp > best:
                atr = atr14_from_candles(c1_cached, 14)
                if atr and atr > 0:
                    trail_dist = max(TRAIL_DISTANCE_MIN,
                                     (atr / max(curp, 1)) * TRAIL_ATR_MULT)
                else:
                    trail_dist = TRAIL_DISTANCE_MIN
                trail_stop = max(trail_stop, curp * (1.0 - trail_dist))

            # 유효 스탑 = max(기본 동적 SL, 트레일링)
            effective_stop = max(base_stop, trail_stop if trail_armed else 0.0)

            # === 🔥 프로 매도 로직 (손실 최소화 + 익절 최대화) ===
            t15 = micro_tape_stats_from_ticks(ticks, 15)
            t30 = micro_tape_stats_from_ticks(ticks, 30)

            cur_gain = (curp / entry_price - 1.0)
            drop_from_high = (best - curp) / best

            # ATR 계산 (동적 조정용, 캐시된 캔들 사용으로 API 호출 최소화)
            atr = atr14_from_candles(c1_cached, 14)
            atr_ratio = (atr / max(curp, 1)) if atr and atr > 0 else 0.01

            # 부분익절 플래그 (1회만 허용)
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m, {})
                partial_done = pos.get("partial_done", False)

            # ========================================
            # 우선순위 0: Net BE 스톱 (부분익절 후 전체 손실 방지)
            # ========================================
            # 부분익절 발생 후, 전체 거래 손익이 0 미만으로 가지 않도록 강제 청산
            if NET_BE_PROTECT and pos and pos.get("partial_done"):
                net_be = float(pos.get("net_be_stop", 0) or 0)
                if net_be > 0 and curp <= net_be:
                    if AUTO_TRADE and entry_volume > 0:
                        sell_market(m, entry_volume)
                    alert = format_sell_alert(m, "Net BE 스톱 (전체 손익 0 보장)", entry_volume, entry_price, curp,
                                             f"Net BE {fmt6(net_be)}원")
                    tg_send(alert)
                    verdict = "NET_BREAKEVEN_STOP"
                    break

            # ========================================
            # 우선순위 0.5: 부분익절 후 시간 데드라인
            # ========================================
            # 부분익절 후 너무 오래 끌지 않도록 최대 보유 시간 제한
            if pos and pos.get("partial_done"):
                partial_sell_time = pos.get("partial_sell_time", 0)
                if partial_sell_time > 0:
                    elapsed = time.time() - partial_sell_time
                    if elapsed >= PARTIAL_MAX_HOLD_SEC:
                        if AUTO_TRADE and entry_volume > 0:
                            sell_market(m, entry_volume)
                        alert = format_sell_alert(m, f"부분익절 시간초과 ({int(elapsed)}초)", entry_volume, entry_price, curp,
                                                 f"제한 {PARTIAL_MAX_HOLD_SEC}초")
                        tg_send(alert)
                        verdict = "PARTIAL_TIME_LIMIT"
                        break

            # ========================================
            # 우선순위 0.6: 총손익 giveback 보호
            # ========================================
            # 부분익절 후 실현+미실현 총합이 피크 대비 과도하게 반납되면 전량 청산
            if pos and pos.get("partial_done"):
                with _POSITION_LOCK:
                    _pos_now = OPEN_POSITIONS.get(m, {})
                sold_pnl = float(_pos_now.get("realized_pnl_krw", 0.0) or 0.0)
                unreal = (curp - entry_price) * float(_pos_now.get("volume", 0.0) or 0.0)
                total_pnl = sold_pnl + unreal
                total_pnl_peak = max(total_pnl_peak, total_pnl)

                if total_pnl_peak > 0 and total_pnl <= total_pnl_peak * (1 - TOTAL_PNL_GIVEBACK):
                    if AUTO_TRADE and entry_volume > 0:
                        sell_market(m, entry_volume)
                    alert = format_sell_alert(m, "총손익 giveback 컷", entry_volume, entry_price, curp,
                                             f"피크 {total_pnl_peak:+,.0f}원 → 현재 {total_pnl:+,.0f}원")
                    tg_send(alert)
                    verdict = "TOTAL_PNL_GIVEBACK"
                    break

            # ========================================
            # 우선순위 1: 손절 (하드스톱 + 동적 손절)
            # ========================================
            # 하드 스톱 (-1.5%)
            if cur_gain <= -0.015:
                if AUTO_TRADE and entry_volume > 0:
                    sell_market(m, entry_volume)
                alert = format_sell_alert(m, "하드스톱 (-1.5% 급락)", entry_volume, entry_price, curp)
                tg_send(alert)
                verdict = "HARD_STOP"
                break

            # 동적 손절 (base_stop 터치)
            if curp <= base_stop:
                if AUTO_TRADE and entry_volume > 0:
                    sell_market(m, entry_volume)
                alert = format_sell_alert(m, "동적 손절", entry_volume, entry_price, curp,
                                         f"손절가 {fmt6(base_stop)}원")
                tg_send(alert)
                verdict = "DYNAMIC_STOP"
                break

            # ========================================
            # 우선순위 2: BE(본절) 승격 (손실 최소화 핵심)
            # ========================================
            # 수정: 0.6% → 1.0% 늦춤, FEE*2 → FEE*1 (미세손절 방지)
            if cur_gain >= 0.010:
                be_lock = entry_price * (1 + FEE_RATE)  # 본절 + 수수료만
                base_stop = max(base_stop, be_lock)

            # ========================================
            # 우선순위 3: 부분익절 3단계 (익절 최대화)
            # ========================================
            # TP1: 1.2% or ATR*1.5 중 큰 값 (기존 0.8% → 1.2% 상향)
            tp1 = entry_price * (1 + max(0.012, atr_ratio * 1.5))
            # TP2: 2.0% or ATR*2.2 중 큰 값 (기존 1.5% → 2.0% 상향)
            tp2 = entry_price * (1 + max(0.020, atr_ratio * 2.2))

            # ========================================
            # 우선순위 3.5: 꼭대기 스톨 익절 (고점 부근 70% 선제 회수)
            # ========================================
            if top_stall_exit_signal(ticks, best, entry_price):
                # 락 중에는 최소 +2.5% 이상일 때만 스톨 익절 허용
                if lock_on and gain_from_entry < 0.025:
                    pass  # 스킵
                else:
                    take = entry_volume * 0.70
                    remaining_volume = entry_volume * 0.30
                    remaining_value = remaining_volume * curp

                    if remaining_value < MIN_ORDER_KRW:
                        # 남을 잔고가 소액이면 전량 매도
                        if AUTO_TRADE and entry_volume > 0 and sell_market(m, entry_volume):
                            alert = format_sell_alert(m, "꼭대기 스톨 전량익절", entry_volume, entry_price, curp,
                                                     f"잔고소액 방지 ({remaining_value:.0f}원)")
                            tg_send(alert)
                            verdict = "TOP_STALL_FULL_EXIT"
                            break
                    else:
                        # 정상 부분 익절
                        if AUTO_TRADE and take > 0 and sell_market(m, take):
                            entry_volume = entry_volume * 0.30
                            with _POSITION_LOCK:
                                if m in OPEN_POSITIONS:
                                    OPEN_POSITIONS[m]["volume"] = entry_volume
                                    OPEN_POSITIONS[m]["partial_done"] = True
                            # 매도 후 실제 수량 재동기화 (race 방지)
                            with _POSITION_LOCK:
                                pos_now = OPEN_POSITIONS.get(m)
                                entry_volume = pos_now["volume"] if pos_now else 0.0
                            # stop 승격 + 트레일 활성화
                            base_stop = max(base_stop, entry_price * 1.005)  # 본절+0.5%
                            trail_armed = True
                            # 남은 30%는 고점대비 0.8% 트레일
                            atr = atr14_from_candles(c1_cached, 14)
                            atr_ratio = (atr / max(curp, 1)) if atr else 0.01
                            trail_stop = max(trail_stop, best * (1.0 - max(0.008, atr_ratio * 1.2)))
                            alert = format_sell_alert(m, "꼭대기 스톨 70% 익절", take, entry_price, curp,
                                                     "남은 30% 촘촘 트레일")
                            tg_send(alert)
                            verdict = "TOP_STALL_EXIT"
                        continue

            # 강한 신호 확인 (점화/메가/봇매집)
            strong_signal = pre.get("ign_ok") or pre.get("mega_ok") or pre.get("botacc_ok")

            # 락 상태에 따른 TP1/TP2 제어
            skip_tp1 = lock_on
            light_tp2 = lock_on

            # TP1은 약한 신호에서만 실행 (강한 신호는 스킵 → 익절 극대화)
            if not skip_tp1 and not partial_done and not strong_signal and curp >= tp1 and curp < tp2:
                # TP1 도달: 30% 부분익절 (단, 남을 잔고가 최소금액 미만이면 전량매도)
                remaining_volume = entry_volume * 0.7
                remaining_value = remaining_volume * curp

                if remaining_value < MIN_ORDER_KRW:
                    # 남을 잔고가 소액이면 전량 매도
                    if AUTO_TRADE and entry_volume > 0 and sell_market(m, entry_volume):
                        alert = format_sell_alert(m, "TP1 전량익절", entry_volume, entry_price, curp,
                                                 f"잔고소액 방지 ({remaining_value:.0f}원)")
                        tg_send(alert)
                        verdict = "TP1_FULL_EXIT"
                        break
                else:
                    # 정상 부분 익절
                    partial_volume = entry_volume * 0.3
                    if AUTO_TRADE and partial_volume > 0 and sell_market(m, partial_volume):
                        entry_volume = entry_volume * 0.7
                        with _POSITION_LOCK:
                            if m in OPEN_POSITIONS:
                                OPEN_POSITIONS[m]["partial_done"] = True
                                OPEN_POSITIONS[m]["volume"] = entry_volume
                        # 매도 후 실제 수량 재동기화 (race 방지)
                        with _POSITION_LOCK:
                            pos_now = OPEN_POSITIONS.get(m)
                            entry_volume = pos_now["volume"] if pos_now else 0.0
                        # stop 승격 + 트레일 활성화
                        base_stop = max(base_stop, entry_price * 1.005)  # 본절+0.5%
                        trail_armed = True  # 남은 70%는 트레일로 보호
                        alert = format_sell_alert(m, "TP1 부분익절 30%", partial_volume, entry_price, curp,
                                                 "남은 70%는 트레일")
                        tg_send(alert)
                        verdict = "TP1_PARTIAL"
                continue

            if not partial_done and curp >= tp2:
                # TP2 도달: 락중엔 20%만, 아니면 40% 부분익절
                if light_tp2:
                    partial_ratio = 0.2
                    remaining_ratio = 0.8
                else:
                    partial_ratio = 0.4
                    remaining_ratio = 0.6

                remaining_volume = entry_volume * remaining_ratio
                remaining_value = remaining_volume * curp

                if remaining_value < MIN_ORDER_KRW:
                    # 남을 잔고가 소액이면 전량 매도
                    if AUTO_TRADE and entry_volume > 0 and sell_market(m, entry_volume):
                        alert = format_sell_alert(m, "TP2 전량익절", entry_volume, entry_price, curp,
                                                 f"잔고소액 방지 ({remaining_value:.0f}원)")
                        tg_send(alert)
                        verdict = "TP2_FULL_EXIT"
                        break
                else:
                    # 정상 부분 익절
                    partial_volume = entry_volume * partial_ratio
                    if AUTO_TRADE and partial_volume > 0 and sell_market(m, partial_volume):
                        entry_volume = entry_volume * remaining_ratio
                        with _POSITION_LOCK:
                            if m in OPEN_POSITIONS:
                                OPEN_POSITIONS[m]["partial_done"] = True
                                OPEN_POSITIONS[m]["volume"] = entry_volume
                        # 매도 후 실제 수량 재동기화 (race 방지)
                        with _POSITION_LOCK:
                            pos_now = OPEN_POSITIONS.get(m)
                            entry_volume = pos_now["volume"] if pos_now else 0.0
                        # stop 승격 + 트레일 활성화
                        base_stop = max(base_stop, entry_price * 1.005)  # 본절+0.5%
                        trail_armed = True
                        trail_stop = max(trail_stop, curp * (1.0 - max(0.010, atr_ratio * 1.25)))
                        ratio_pct = int(partial_ratio * 100)
                        remain_pct = int(remaining_ratio * 100)
                        alert = format_sell_alert(m, f"TP2 부분익절 {ratio_pct}%", partial_volume, entry_price, curp,
                                                 f"남은 {remain_pct}%는 트레일")
                        tg_send(alert)
                        verdict = "TP2_PARTIAL"
                continue

            # ========================================
            # 우선순위 4: 테이프 투표 전량매도 (흐름 붕괴)
            # ========================================
            # 초반 30초는 웜업 기간 (노이즈 무시)
            alive_sec = time.time() - start_ts
            flow_votes = 0

            if alive_sec >= 30 and not lock_on and cur_gain > 0.0:  # 수익 구간에서만 발동 (손실은 스톱이 담당)
                flow_votes += int(t15["krw_per_sec"] < 0.65 * t30["krw_per_sec"])  # 거래량 급락
                flow_votes += int(t15["buy_ratio"] < 0.52)  # 매수세 약화
                flow_votes += int(not uptick_streak_from_ticks(ticks, need=2))  # uptick 부재

                # 상단 투표 완화: 2.5% 이상 먹은 상태면 2/3로 완화 → 꼭대기 근처 회수율↑
                need_votes = 3  # 기본: 모든 신호가 나빠야 (3/3)
                if cur_gain >= 0.025:  # 2.5% 이상 고수익 구간
                    need_votes = 2  # 2/3로 완화 (빠른 피크 탈출)

                if flow_votes >= need_votes and cur_gain > -0.005:
                    if AUTO_TRADE and entry_volume > 0:
                        sell_market(m, entry_volume)
                    alert = format_sell_alert(m, "테이프 투표", entry_volume, entry_price, curp,
                                             f"흐름 붕괴 ({flow_votes}/{need_votes})")
                    tg_send(alert)
                    verdict = "FLOW_VOTED_EXIT"
                    break

            # ========================================
            # 우선순위 5: 고점 되돌림 매도
            # ========================================
            # 수정: -0.5% → -0.8% 완화, 최소 이익 조건 추가
            # 락 중에는 -1.5%로 더 크게
            peak_partial_trigger = 0.015 if lock_on else 0.008
            if drop_from_high >= peak_partial_trigger and t15["buy_ratio"] < 0.53 and not partial_done and cur_gain >= 0.006:
                # -0.8% 되돌림 + 매수세 약화 → 부분 30% (단, 남을 잔고가 최소금액 미만이면 전량매도)
                remaining_volume = entry_volume * 0.7
                remaining_value = remaining_volume * curp

                if remaining_value < MIN_ORDER_KRW:
                    # 남을 잔고가 소액이면 전량 매도
                    if AUTO_TRADE and entry_volume > 0 and sell_market(m, entry_volume):
                        alert = format_sell_alert(m, "고점 되돌림 전량", entry_volume, entry_price, curp,
                                                 f"잔고소액 방지 ({remaining_value:.0f}원)")
                        tg_send(alert)
                        verdict = "PEAK_FADE_FULL_EXIT"
                        break
                else:
                    # 정상 부분 익절
                    partial_volume = entry_volume * 0.3
                    if AUTO_TRADE and partial_volume > 0 and sell_market(m, partial_volume):
                        entry_volume = entry_volume * 0.7
                        with _POSITION_LOCK:
                            if m in OPEN_POSITIONS:
                                OPEN_POSITIONS[m]["partial_done"] = True
                                OPEN_POSITIONS[m]["volume"] = entry_volume
                        # 매도 후 실제 수량 재동기화 (race 방지)
                        with _POSITION_LOCK:
                            pos_now = OPEN_POSITIONS.get(m)
                            entry_volume = pos_now["volume"] if pos_now else 0.0
                        alert = format_sell_alert(m, "고점 되돌림 부분 30%", partial_volume, entry_price, curp,
                                                 "고점 대비 -0.8%, 남은 70% 보유")
                        tg_send(alert)
                        verdict = "PEAK_FADE_PARTIAL"
                continue

            # 수정: -1.0% → -1.5% 완화, 최소 이익 조건 추가
            if drop_from_high >= 0.015 and cur_gain >= 0.008:
                # -1.5% 되돌림 + 최소 0.8% 이익 → 전량
                if AUTO_TRADE and entry_volume > 0:
                    sell_market(m, entry_volume)
                alert = format_sell_alert(m, "고점 급락 전량익절", entry_volume, entry_price, curp,
                                         "고점 대비 -1.5% 하락")
                tg_send(alert)
                verdict = "PEAK_CASCADE"
                break

            # ========================================
            # 우선순위 6: 이익락 (ATR 기반 동적 + 고수익 타이트닝)
            # ========================================
            if lock_on:
                # 락 중에는 이익락을 한 단계 느슨하게 (쫓겨나지 않게)
                if cur_gain >= 0.03:
                    profit_lock = best * (1.0 - max(0.007, atr_ratio * 0.9))
                elif cur_gain >= 0.015:
                    profit_lock = best * (1.0 - max(0.010, atr_ratio * 1.1))
                else:
                    profit_lock = base_stop
            else:
                # 기존 이익락 로직
                if cur_gain >= 0.05:
                    # 5% 이상: 고점 대비 매우 촘촘 (최소 0.4%)
                    profit_lock = best * (1.0 - max(0.004, atr_ratio * 0.5))
                    trail_armed = True  # 강제 트레일 활성화
                elif cur_gain >= 0.03:
                    # 3% 이상: 고점 대비 촘촘 (최소 0.5%)
                    profit_lock = best * (1.0 - max(0.005, atr_ratio * 0.7))
                    trail_armed = True  # 강제 트레일 활성화
                elif cur_gain >= 0.015:
                    # 1.5% 이상: 고점 대비 ATR*1.0 (최소 0.8%)
                    profit_lock = best * (1.0 - max(0.008, atr_ratio * 1.0))
                elif cur_gain >= 0.010:
                    # 1.0% 이상: 고점 대비 ATR*0.8 (최소 0.6%)
                    profit_lock = best * (1.0 - max(0.006, atr_ratio * 0.8))
                else:
                    profit_lock = base_stop

            if curp <= profit_lock and cur_gain > 0:
                if AUTO_TRADE and entry_volume > 0:
                    sell_market(m, entry_volume)
                alert = format_sell_alert(m, "이익락 발동", entry_volume, entry_price, curp,
                                         f"락 가격 {fmt6(profit_lock)}원")
                tg_send(alert)
                verdict = "PROFIT_LOCK"
                break

            # ========================================
            # 우선순위 7: 트레일링 스탑 (ATR 기반 동적 + 고수익 타이트닝)
            # ========================================
            if trail_armed and curp > best:
                # 고수익 구간은 트레일 거리 축소 (꼭대기 회수율↑)
                if lock_on:
                    # 락 중에는 트레일 간격을 한 단계 여유있게 (쫓겨나지 않게)
                    if cur_gain >= 0.03:
                        trail_dist = max(0.008, atr_ratio * 1.0)
                    else:
                        trail_dist = max(0.012, atr_ratio * 1.3)
                else:
                    # 기존 트레일 로직
                    if cur_gain >= 0.05:
                        # 5% 이상: 매우 촘촘 (최소 0.4%)
                        trail_dist = max(0.004, atr_ratio * 0.6)
                    elif cur_gain >= 0.03:
                        # 3% 이상: 촘촘 (최소 0.6%)
                        trail_dist = max(0.006, atr_ratio * 0.8)
                    else:
                        # 기본: (최소 1.0%)
                        trail_dist = max(0.010, atr_ratio * 1.25)
                trail_stop = max(trail_stop, curp * (1.0 - trail_dist))
                last_trail_dist = trail_dist  # 마지막 계산값 저장

            if trail_armed and curp <= trail_stop:
                if AUTO_TRADE and entry_volume > 0:
                    sell_market(m, entry_volume)
                dist_pct = (last_trail_dist * 100) if last_trail_dist is not None else None
                detail = f"스탑 {fmt6(trail_stop)}원"
                if dist_pct is not None:
                    detail += f" (고점 대비 -{dist_pct:.1f}%)"
                alert = format_sell_alert(m, "트레일링 스탑", entry_volume, entry_price, curp, detail)
                tg_send(alert)
                verdict = "TRAIL_EXIT"
                break

            # ========================================
            # 추가: 재진입 로직 (기존 유지)
            # ========================================
            if drop_from_high >= 0.008 and uptick_streak_from_ticks(ticks, need=3):
                tg_send(f"🔄 {m} 눌림 후 재상승 감지 → 재진입")
                open_auto_position(m, pre, base_stop, eff_sl_pct)

        # ========================================
        # 시간 만료 시 매도 안전장치 (매도 미실행 방지)
        # ========================================
        if verdict is None:
            if lock_on:
                # 락 중에는 시간만료 무시 (락이 풀릴 때까지 계속 관찰)
                verdict = "시간 연장(상승추세 보유)"
            else:
                # 수정: 0.3% → -0.25% (손실일 때만 강제청산, 수익은 유지)
                if cur_gain <= -0.0025:  # 진짜 손실일 때만 → 전량매도
                    if AUTO_TRADE and entry_volume > 0:
                        sell_market(m, entry_volume)
                    alert = format_sell_alert(m, "시간만료 안전청산", entry_volume, entry_price, curp,
                                             "시간만료 + 손실")
                    tg_send(alert)
                    verdict = "TIME_EXPIRED_SAFE_EXIT"
                else:
                    # 수익/본절 구간은 강제 청산 없음 (재모니터링으로 기회 보존)
                    verdict = "시간 만료(유지)"

    finally:
        # ================================
        # 1) 최신 상태 / 수익률 계산
        # ================================
        ticks = get_recent_ticks(m, 100)
        t15 = micro_tape_stats_from_ticks(ticks, 15) if ticks else {
            "buy_ratio": 0,
            "krw": 0,
            "n": 0,
            "krw_per_sec": 0
        }

        ob = pre.get("ob") or {}
        ob_depth_krw = ob.get("depth_krw", 10_000_000)

        try:
            ret_pct = ((last_price / entry_price - 1.0) - FEE_RATE) * 100.0
        except:
            ret_pct = 0.0

        maxrun = (best / entry_price - 1.0) * 100.0
        maxdd = (worst / entry_price - 1.0) * 100.0

        # ================================
        # 2) 끝알람 문구 생성
        # ================================
        action, rationale = _end_reco(
            m,  # 종목 코드
            entry_price,
            last_price,
            c1,
            ticks,
            ob_depth_krw,
            ctx_thr=CTX_EXIT_THRESHOLD
        )

        # ===========================================
        # 끝알람 / 재모니터링 알림 비활성화
        #  (실제 로직은 유지하지만 텔레그램 메시지 과다 방지)
        # ===========================================
        if not reentry:
            pass  # 끝알람 비활성화
        else:
            pass  # 재모니터링 요약 비활성화

        # ===========================================
        # 재모니터링 루프 시작
        #  - 최초 모니터링에서만 호출
        #  - remonitor_until_close()에서 재호출된 경우(reentry=True)는 다시 안 들어감
        # ===========================================
        # ✅ 재모니터링 알림 비활성화 (불필요한 반복 메시지 방지)
        # (실제 로직은 유지하지만, 알림 발송만 차단)
        if AUTO_TRADE and m in OPEN_POSITIONS and not reentry:
            remonitor_until_close(m, entry_price, pre, tight_mode)

        # ===========================================
        # 3) probe 손절 후 빠른 재진입 허용 로직
        # ===========================================
        if AUTO_TRADE and verdict and "손절" in verdict:
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m)
                if pos and pos.get("entry_mode") == "probe":
                    # probe 손절 시 재진입 쿨다운 최소화
                    REMONITOR_QUICK_COOLDOWN_SEC = 120  # 2분 쿨다운
                    REMONITOR_WINDOW_MINUTES = 10       # 10분 내 동일 종목 재기회 허용

                    # 최근 종료 시각 기록
                    pos["last_exit_ts"] = time.time()
                    OPEN_POSITIONS[m] = pos

                    # 🌀 probe 손절 감지 → 재진입 모드 (알림 비활성화)

                    # 빠른 재모니터링 예약
                    time.sleep(REMONITOR_QUICK_COOLDOWN_SEC)
                    remonitor_until_close(m, entry_price, pre, tight_mode)

        # 👇 이 return 은 if 바깥에서 항상 실행되게
        return (
            verdict,
            action,
            rationale,
            ret_pct,
            last_price,
            maxrun,
            maxdd,
        )


