def remonitor_until_close(m, entry_price, pre, tight_mode=False):
    """
    끝알람 이후 자동청산 신호가 나올 때까지 반복 모니터링
    - 무한 루프 방지: 벽시계 상한 + 점진 백오프
    """
    CYCLE_SEC = 300
    MAX_WALL = 1800  # 30분 상한
    start_wall = time.time()
    backoff = 30
    cycle = 0

    while time.time() - start_wall < MAX_WALL:
        cycle += 1
        print(f"[REMONITOR] {m} {cycle}회차 재모니터링 시작")

        verdict, action, rationale, ret_pct, last_price, maxrun, maxdd = \
            monitor_position(
                m, entry_price, pre,
                tight_mode=tight_mode,
                horizon=CYCLE_SEC,
                reentry=True
            )

        should_close = False
        reason = verdict or action or "모니터링 종료"

        if verdict and ("급락" in verdict or "손절" in verdict):
            should_close = True
        elif action and "전량 청산 권고" in action:
            should_close = True
        elif ret_pct is not None and ret_pct >= 2.5:
            should_close = True
            reason = f"수익실현 {ret_pct:.2f}%"
        elif ret_pct is not None and ret_pct >= 1.5:
            ok, msg, executed = safe_partial_sell(
                m, sell_ratio=0.3, reason=f"부분 수익실현 {ret_pct:.2f}%")
            if ok and executed > 0:
                print(msg)
            time.sleep(backoff)
            backoff = min(backoff + 30, 120)
            continue
        elif verdict and verdict.startswith("청산 권고("):
            time.sleep(backoff)
            backoff = min(backoff + 30, 120)
            continue
        elif action in ("부분 청산(50%) 권고", "부분 청산(본절)"):
            ok, msg, executed = safe_partial_sell(m, sell_ratio=0.5, reason="부분청산 50%")
            if ok and executed > 0:
                print(msg)
            time.sleep(backoff)
            backoff = min(backoff + 30, 120)
            continue
        elif action == "유지 권고":
            time.sleep(backoff)
            backoff = min(backoff + 30, 120)
            continue
        elif verdict == "시간 만료(모니터링 종료)":
            time.sleep(backoff)
            backoff = min(backoff + 30, 120)
            continue

        if should_close:
            with _POSITION_LOCK:
                pos = OPEN_POSITIONS.get(m)
                if not pos or pos.get("closing"):
                    return False  # 이미 청산 중/없음
                pos["closing"] = True
                OPEN_POSITIONS[m] = pos

            print(f"[REMONITOR] {m} 자동청산 조건 충족 → 청산 ({reason})")
            try:
                close_auto_position(m, reason)
                return True
            except Exception as e:
                print(f"[REMONITOR_ERR] {m} 청산 실패: {e}")
                return False
            finally:
                # ★ 안전망: 예외 발생해도 closing 플래그 해제
                with _POSITION_LOCK:
                    pos = OPEN_POSITIONS.get(m)
                    if pos:
                        pos["closing"] = False

        time.sleep(backoff)
        backoff = min(backoff + 30, 120)

    print(f"[REMONITOR] {m} 타임아웃 종료 (MAX_WALL={MAX_WALL}s)")
    return False

