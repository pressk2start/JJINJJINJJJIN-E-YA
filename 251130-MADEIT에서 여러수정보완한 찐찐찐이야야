        errors.append(f"MIN_TURNOVER={MIN_TURNOVER} 범위 오류 (0~1)")
    if TICKS_BUY_RATIO < 0.5 or TICKS_BUY_RATIO > 1:
        errors.append(f"TICKS_BUY_RATIO={TICKS_BUY_RATIO} 범위 오류 (0.5~1)")
    if not TG_TOKEN or not CHAT_IDS: warnings.append("텔레그램 미설정 - 콘솔 출력만 사용")

    # 토큰버킷 안전 클램프 (시작 시점에 강제 보정)
    if _BUCKET.get("rate", 0) <= 0:
        warnings.append("토큰버킷 rate<=0 → 0.1로 클램프")
        _BUCKET["rate"] = 0.1
    if _BUCKET.get("cap", 0) <= 0:
        warnings.append("토큰버킷 cap<=0 → 1.0로 클램프")
        _BUCKET["cap"] = 1.0
    if warnings:
        print("[CONFIG_WARNING]")
        for w in warnings:
            print("  ⚠️", w)
    if errors:
        print("[CONFIG_ERROR]")
        for e in errors:
            print("  ❌", e)
        sys.exit(1)
    print("✅ 설정 검증 완료")


