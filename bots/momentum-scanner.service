[Unit]
Description=Upbit Momentum Scanner (Paper Trading)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=5

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/bot/bots
ExecStart=/usr/bin/python3 /home/ubuntu/bot/bots/momentum_scanner.py
EnvironmentFile=/home/ubuntu/bot/.env
Restart=on-failure
RestartSec=30
StandardOutput=append:/tmp/momentum_scanner.log
StandardError=append:/tmp/momentum_scanner.log

[Install]
WantedBy=multi-user.target
